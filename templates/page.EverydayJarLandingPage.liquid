<script>
  document.addEventListener("DOMContentLoaded", function () {
    const rlGallery = document.getElementById('real-life-gallery');
    const rlProgress = document.getElementById('real-life-progress-bar');

    function updateProgress() {
      const scrollLeft = rlGallery.scrollLeft;
      const scrollWidth = rlGallery.scrollWidth - rlGallery.clientWidth;
      const percent = scrollWidth > 0 ? (scrollLeft / scrollWidth) * 100 : 0;
      rlProgress.style.width = percent + "%";
