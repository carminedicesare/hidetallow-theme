f7f7f7"}},"chapter_xhQHwL":{"type":"chapter","settings":{"icon_svg":"<svg fill=\"#000000\" version=\"1.1\" id=\"Capa_1\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\" viewbox=\"0 0 342.382 342.382\" xmlns:xlink=\"http:\/\/www.w3.org\/1999\/xlink\" xml:space=\"preserve\"><g id=\"SVGRepo_bgCarrier\" stroke-width=\"0\"><\/g><g id=\"SVGRepo_tracerCarrier\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><\/g><g id=\"SVGRepo_iconCarrier\"> <g> <g> <g> <path d=\"M45.225,125.972C20.284,125.972,0,146.256,0,171.191c0,24.94,20.284,45.219,45.225,45.219 c24.926,0,45.219-20.278,45.219-45.219C90.444,146.256,70.151,125.972,45.225,125.972z\"><\/path> <\/g> <g> <path d=\"M173.409,125.972c-24.938,0-45.225,20.284-45.225,45.219c0,24.94,20.287,45.219,45.225,45.219 c24.936,0,45.226-20.278,45.226-45.219C218.635,146.256,198.345,125.972,173.409,125.972z\"><\/path> <\/g> <g> <path d=\"M297.165,125.972c-24.932,0-45.222,20.284-45.222,45.219c0,24.94,20.29,45.219,45.222,45.219 c24.926,0,45.217-20.278,45.217-45.219C342.382,146.256,322.091,125.972,297.165,125.972z\"><\/path> <\/g> <\/g> <\/g> <\/g><\/svg>","icon_color":"#1a1a1a","icon_size":48,"title":"How To Use Tallow","caption":"","story":"<p>People reach for tallow when their skin feels <em>fed up<\/em> — dry patches, redness, breakouts from harsh products, or that tight, flaky feeling nothing fixes. It’s not a treatment, but people love it because it behaves like skin: simple, gentle, and supportive.<\/p><p>Many say their skin feels calmer and less reactive — whether it’s acne-prone moments, eczema-related dryness, or everyday irritation.<\/p><p>And the best part? The use cases are endless. Face moisturizer, lip balm, post-shave, baby skin, elbows, cuticles, deodorant — one jar replaces half a routine<\/p>","media_layout":"scroll","media_snap":true,"media_height":360,"media_gap":12,"media_radius":12,"media_bg":"#f7f7f7"}},"chapter_MaMNTG":{"type":"chapter","settings":{"icon_img":"shopify:\/\/shop_images\/Hide_Tallow_Co._1.png","icon_svg":"","icon_color":"#1a1a1a","icon_size":100,"title":"Find Your Tallow","caption":"","story":"<p>Now that you know the basics, here’s the easy part — choosing the product that fits your routine. Whether you want something for daily moisture, dry spots, travel, or an all-purpose go-to, every option below starts with the same clean, grass-fed simplicity. Pick the one that feels right.<\/p>","media_layout":"scroll","media_snap":true,"media_height":360,"media_gap":12,"media_radius":12,"media_bg":"#f7f7f7"}}},"block_order":["chapter_RQmBUw","chapter_Q6xibz","chapter_k9bY8Y","chapter_XNPBFR","chapter_xhQHwL","chapter_MaMNTG"],"name":"HT • About Story","settings":{"heading":"Tallow 101","heading_size":40,"heading_mb":12,"pad_y":40,"bg":"#ffffff","text_color":"#1a1a1a","copy_align":"center","copy_max":70,"copy_mb":16,"chapter_gap":44,"pillar_title_color":"#1a1a1a","pillar_title_size":18,"pillar_caption_color":"#333333","pillar_caption_size":13,"heading_color":"#1a1a1a"}},"featured_collection_XYgUX4":{"type":"featured-collection","name":"t:sections.featured-collection.presets.name","settings":{"collection":"home-page-products","products_to_show":4,"title":"","heading_size":"h1","description":"","show_description":false,"description_style":"body","columns_desktop":1,"enable_desktop_slider":true,"full_width":true,"show_view_all":true,"view_all_style":"solid","color_scheme":"scheme-29e1d30b-12a1-4aa8-8769-9863a4f4a582","image_ratio":"adapt","image_shape":"default","show_secondary_image":false,"show_vendor":false,"show_rating":false,"quick_add":"standard","columns_mobile":"1","swipe_on_mobile":true,"padding_top":0,"padding_bottom":0}}},"order":["main","ht_social_micro_T6jtkW","featured_collection_XYgUX4"]}