{%- comment -%}
  HT • Bundle Feature
  Single bundle card styled to match product cards from Featured Collection.
{%- endcomment -%}

{%- if section.settings.bundle_product != blank -%}
  {%- assign bundle_product = section.settings.bundle_product -%}

  {%- liquid
    assign ratio = 1
    if bundle_product.featured_media
      assign ratio = bundle_product.featured_media.aspect_ratio
    endif
    if ratio == 0 or ratio == null
      assign ratio = 1
    endif
  -%}

  <section
    id="ht-bundle-feature-{{ section.id }}"
    class="section-{{ section.id }}-padding"
  >
    <div class="page-width ht-bundle-feature__wrap">
      <div class="card-wrapper product-card-wrapper underline-links-hover ht-bundle-feature__card-wrapper">
        <div
          class="
            card card--{{ settings.card_style }}
            {% if bundle_product.featured_media %} card--media{% else %} card--text{% endif %}
            {% if settings.card_style == 'card' %} color-{{ settings.card_color_scheme }} gradient{% endif %}
            card--extend-height
          "
          style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;"
        >
          {%- comment -%} Image area (same pattern as card-product) {%- endcomment -%}
          <div
            class="card__inner {% if settings.card_style == 'standard' %}color-{{ settings.card_color_scheme }} gradient{% endif %}{% if bundle_product.featured_media or settings.card_style == 'standard' %} ratio{% endif %}"
            style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;"
          >
            {%- if bundle_product.featured_media -%}
              <div class="card__media">
                <div class="media media--transparent">
                  {% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
                  <img
                    srcset="
                      {%- if bundle_product.featured_media.width >= 165 -%}{{ bundle_product.featured_media | image_url: width: 165 }} 165w,{%- endif -%}
                      {%- if bundle_product.featured_media.width >= 360 -%}{{ bundle_product.featured_media | image_url: width: 360 }} 360w,{%- endif -%}
                      {%- if bundle_product.featured_media.width >= 533 -%}{{ bundle_product.featured_media | image_url: width: 533 }} 533w,{%- endif -%}
                      {%- if bundle_product.featured_media.width >= 720 -%}{{ bundle_product.featured_media | image_url: width: 720 }} 720w,{%- endif -%}
                      {%- if bundle_product.featured_media.width >= 940 -%}{{ bundle_product.featured_media | image_url: width: 940 }} 940w,{%- endif -%}
                      {%- if bundle_product.featured_media.width >= 1066 -%}{{ bundle_product.featured_media | image_url: width: 1066 }} 1066w,{%- endif -%}
                      {{ bundle_product.featured_media | image_url }} {{ bundle_product.featured_media.width }}w
                    "
                    src="{{ bundle_product.featured_media | image_url: width: 533 }}"
                    sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                    alt="{{ bundle_product.featured_media.alt | escape }}"
                    class="motion-reduce"
                    loading="lazy"
                    width="{{ bundle_product.featured_media.width }}"
                    height="{{ bundle_product.featured_media.height }}"
                  >
                  {% comment %}theme-check-enable ImgLazyLoading{% endcomment %}
                </div>
              </div>
            {%- endif -%}
          </div>

          {%- comment -%} Top-right badge on image for Starter Kit {%- endcomment -%}
          {% if bundle_product.handle == 'the-starter-kit' %}
            <div class="ht-bundle-feature__top-badge">
              SAVE 20%!
            </div>
          {% endif %}

          {%- comment -%} Text + CTA {%- endcomment -%}
          <div class="card__content">
            <div class="card__information">
              {%- if section.settings.eyebrow != blank -%}
                <p class="ht-bundle-feature__eyebrow">
                  {{ section.settings.eyebrow }}
                </p>
              {%- endif -%}

              <h3 class="card__heading h5">
                <a
                  href="{{ bundle_product.url }}"
                  class="full-unstyled-link"
                >
                  {{ section.settings.title | default: bundle_product.title | escape }}
                </a>
              </h3>

              {%- if section.settings.subtitle != blank -%}
                <p class="card__subtitle">
                  {{ section.settings.subtitle }}
                </p>
              {%- endif -%}

              {%- if section.settings.hint != blank -%}
                <p class="ht-bundle-feature__hint">
                  {{ section.settings.hint }}
                </p>
              {%- endif -%}
            </div>

            <a
              href="{{ bundle_product.url }}"
              class="button button--full-width button--secondary ht-bundle-feature__button"
            >
              {{ section.settings.button_label | default: 'Build Your Starter Kit' }}
            </a>
          </div>

        </div>
      </div>
    </div>
  </section>

  {%- style -%}
    /* Vertical spacing */
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.v_margin_mobile }}px;
      padding-bottom: {{ section.settings.v_margin_mobile }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.v_margin_desktop }}px;
        padding-bottom: {{ section.settings.v_margin_desktop }}px;
      }
    }

    /* Center the single card */
    #shopify-section-{{ section.id }} .ht-bundle-feature__wrap {
      display: flex;
      justify-content: center;
    }

    /* Match Featured Collection card styling */
    #shopify-section-{{ section.id }} .card-wrapper {
      max-width: 320px;
      margin-inline: auto;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    #shopify-section-{{ section.id }} .card-wrapper:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.14);
    }

    #shopify-section-{{ section.id }} .card {
      position: relative;
      border-radius: 18px;
      border: 1px solid #E5E7EB;
      background: {{ section.settings.bg_color }};
      padding: 14px 14px 18px;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .card__inner {
      border-radius: 14px;
      overflow: hidden;
      background: transparent;
    }

    #shopify-section-{{ section.id }} .card__media {
      padding: 0;
    }

    #shopify-section-{{ section.id }} .card__media img {
      display: block;
      width: 100%;
      height: auto;
      object-fit: cover;
      border-radius: 20px;
    }

    /* Make content column flex so button can sit at bottom */
    #shopify-section-{{ section.id }} .card__content {
      display: flex;
      flex-direction: column;
      height: 100%;
    }

    #shopify-section-{{ section.id }} .card__heading {
      margin-top: 14px;
      margin-bottom: 4px;
      font-size: 2.05rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: #111827;
    }

    #shopify-section-{{ section.id }} .card__subtitle {
      margin-top: 0;
      margin-bottom: 6px;
      font-size: 1.5rem;
      line-height: 1.35;
      color: #6B7280;
    }

    #shopify-section-{{ section.id }} .card__subtitle::after {
      content: "";
      display: block;
      width: 40%;
      height: 1px;
      background: rgba(156, 163, 175, 0.5);
      margin: 10px auto 12px;
    }

    /* CTA pill — reuse Featured Collection button look */
    #shopify-section-{{ section.id }} .card__content .button.button--full-width {
      width: auto !important;
      min-width: 180px;
      display: inline-flex;
      justify-content: center;
      padding: 10px 22px !important;
      font-size: 1.5rem;
      letter-spacing: 0.02em;
      border-width: 1.5px;
      border-radius: 999px !important;
    }

    #shopify-section-{{ section.id }} .card__content .button.button--full-width::before,
    #shopify-section-{{ section.id }} .card__content .button.button--full-width::after {
      border-radius: 999px !important;
    }

    /* Push Starter Kit button to bottom of card */
    #shopify-section-{{ section.id }} .ht-bundle-feature__button {
      margin-top: auto;
    }

    /* Hint text */
    #shopify-section-{{ section.id }} .ht-bundle-feature__hint {
      margin: 0.3rem 0 0.4rem;
      font-size: 0.8rem;
      opacity: 0.75;
    }

    #shopify-section-{{ section.id }} .ht-bundle-feature__eyebrow {
      font-size: 1.25rem;
      text-transform: uppercase;
      letter-spacing: .08em;
      margin: 0 0 2px;
      opacity: 0.7;
    }

    /* Top-right Starter Kit badge (larger) */
    #shopify-section-{{ section.id }} .ht-bundle-feature__top-badge {
      position: absolute;
      top: 14px;
      right: 14px;
      background: #0f3b27;
      color: #ffffff;
      padding: 6px 14px;
      font-size: 0.95rem;
      font-weight: 700;
      border-radius: 999px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      z-index: 30;
      border: 1px solid rgba(255, 255, 255, 0.35);
      box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    }

    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} .ht-bundle-feature__top-badge {
        padding: 7px 16px;
        font-size: 1rem;
      }
    }

    /* Badge position class (if you ever use .card__badge again) */
    #shopify-section-{{ section.id }} .card__badge {
      top: auto;
      bottom: 2px;
      right: 16px;
      left: auto;
    }

    #shopify-section-{{ section.id }} .badge {
      border-radius: 999px;
      padding: 4px 14px;
      font-size: 1.5rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      background: rgba(249, 250, 251, 0.95);
      color: #111827;
      border: 1px solid #E5E7EB;
    }
  {%- endstyle -%}

{%- endif -%}

{% schema %}
{
  "name": "HT • Bundle Feature",
  "settings": [
    {
      "type": "product",
      "id": "bundle_product",
      "label": "Bundle product"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Build and Save 20%"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "The Starter Kit"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Everyday Jar, On-The-Go Tin, and Chapstick in your choice of scents."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Build Your Starter Kit"
    },
    {
      "type": "textarea",
      "id": "hint",
      "label": "Small hint text",
      "default": "Add an Everyday Jar, On-The-Go Tin, and Pocket Stick to your cart — 20% off each is applied automatically."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Card background color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "v_margin_desktop",
      "label": "Vertical spacing (desktop)",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 40
    },
    {
      "type": "range",
      "id": "v_margin_mobile",
      "label": "Vertical spacing (mobile)",
      "min": 0,
      "max": 80,
      "step": 8,
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "HT • Bundle Feature",
      "category": "Promotional"
    }
  ]
}
{% endschema %}
