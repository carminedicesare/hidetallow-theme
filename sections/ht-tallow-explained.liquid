{%- comment -%} HT • Fully Dynamic Explained Section {%- endcomment -%}

<div class="ht-explained-container" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="ht-explained-inner">
    <div class="ht-explained-header">
      {%- if section.settings.sub_heading != blank -%}
        <p class="ht-subheading" style="color: {{ section.settings.text_color }};">{{ section.settings.sub_heading }}</p>
      {%- endif -%}
      <h2 class="ht-main-heading" style="color: {{ section.settings.text_color }};">{{ section.settings.main_heading }}</h2>
    </div>

    <div class="ht-explained-content">
      {%- for block in section.blocks -%}
        <div class="ht-accordion-wrapper" {{ block.shopify_attributes }}>
          <button class="ht-accordion-trigger" aria-expanded="false" style="color: {{ section.settings.text_color }};">
            <span class="ht-section-label">{{ block.settings.title }}</span>
            <span class="ht-icon-toggle"></span>
          </button>
          <div class="ht-accordion-panel">
            <div class="ht-section-text" style="color: {{ section.settings.text_color }};">
              {{ block.settings.content }}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div class="ht-explained-hero">
      {%- if section.settings.hero_image != blank -%}
        <img src="{{ section.settings.hero_image | image_url: width: 1200 }}" alt="{{ section.settings.main_heading }}" loading="lazy">
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Questrial&display=swap');

  .ht-explained-container { padding: 60px 20px; text-align: center; }
  .ht-explained-inner { max-width: 900px; margin: 0 auto; }

  /* HEADINGS */
  .ht-main-heading, .ht-section-label { font-family: "Bricolage Grotesque", sans-serif; text-transform: uppercase; }
  .ht-main-heading { font-size: 42px; font-weight: 800; letter-spacing: -0.04em; margin: 0 0 40px 0; line-height: 1.1; }
  .ht-section-label { font-size: 15px; font-weight: 800; letter-spacing: 0.05em; margin: 0; }
  .ht-subheading, .ht-section-text { font-family: "Questrial", sans-serif; }
  .ht-subheading { text-transform: uppercase; font-size: 14px; font-weight: 400; letter-spacing: 0.15em; margin-bottom: 12px; opacity: 0.9; }

  /* ACCORDION */
  .ht-explained-content { border-top: 1px solid rgba(0,0,0,0.1); margin-bottom: 20px; }
  .ht-accordion-wrapper { border-bottom: 1px solid rgba(0,0,0,0.1); }
  
  .ht-accordion-trigger {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: none;
    border: none;
    padding: 25px 0;
    cursor: pointer;
    text-align: left;
  }

  .ht-icon-toggle { position: relative; width: 16px; height: 16px; flex-shrink: 0; }
  .ht-icon-toggle::before, .ht-icon-toggle::after {
    content: ''; position: absolute; background: currentColor; transition: transform 0.3s ease;
  }
  .ht-icon-toggle::before { width: 100%; height: 2px; top: 50%; left: 0; transform: translateY(-50%); }
  .ht-icon-toggle::after { width: 2px; height: 100%; left: 50%; top: 0; transform: translateX(-50%); }

  .ht-accordion-trigger[aria-expanded="true"] .ht-icon-toggle::after { transform: translateX(-50%) rotate(90deg); opacity: 0; }
  .ht-accordion-trigger[aria-expanded="true"] + .ht-accordion-panel { max-height: 1000px; opacity: 1; padding-bottom: 30px; }

  .ht-accordion-panel {
    max-height: 0;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
  }

  .ht-section-text { font-size: 16px; line-height: 1.6; text-align: left; }
  .ht-section-text p { margin: 0 0 15px 0; }
  .ht-section-text p:last-child { margin: 0; }

  .ht-explained-hero { margin: 60px auto 0; border-radius: 20px; overflow: hidden; }
  .ht-explained-hero img { width: 100%; display: block; }

  @media screen and (max-width: 749px) {
    .ht-main-heading { font-size: 32px; }
    .ht-explained-container { padding: 40px 15px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const triggers = document.querySelectorAll('.ht-accordion-trigger');
    triggers.forEach(trigger => {
      trigger.addEventListener('click', function() {
        const expanded = this.getAttribute('aria-expanded') === 'true';
        // Close others for a cleaner experience
        triggers.forEach(t => t.setAttribute('aria-expanded', 'false'));
        // Toggle current
        this.setAttribute('aria-expanded', !expanded);
      });
    });
  });
</script>

{% schema %}
{
  "name": "HT Explained Hub",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text & Icon Color", "default": "#0E3A27" },
    { "type": "text", "id": "sub_heading", "label": "Sub Heading", "default": "NATURE'S SKIN-NATIVE REMEDY" },
    { "type": "text", "id": "main_heading", "label": "Main Heading", "default": "Tallow Explained" },
    { "type": "image_picker", "id": "hero_image", "label": "Featured Image (Bottom)" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Accordion Item",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "What is Tallow?" },
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Tallow is a nutrient-dense form of grass-fed beef fat.</p>" }
      ]
    }
  ],
  "presets": [ { "name": "HT Explained Hub" } ]
}
{% endschema %}