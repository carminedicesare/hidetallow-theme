<style>
  /* --- Hide Tallow Global Branding --- */
  #shopify-section-{{ section.id }} .ht-hero-button {
    border-radius: 8px !important; 
    padding: 1rem 5rem !important; 
    text-transform: uppercase;
    letter-spacing: 0.15rem;
    font-weight: 600;
    font-size: 1.1rem !important; 
    transition: all 0.3s ease;
    border: none !important;      
    outline: none !important;     
    background-color: #0e3a27 !important; 
    color: #ffffff !important;           
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    min-width: 300px; 
    cursor: pointer;
  }

  /* --- Desktop: Split Hero with CSS Gradient Fade --- */
  @media screen and (min-width: 750px) {
    .ht-hero-wrapper {
      position: relative;
      height: {{ section.settings.desktop_height }}px;
      width: 100%;
      overflow: hidden;
      background-color: #0e3a27; 
      z-index: 1;
    }
    
    .ht-hero-wrapper::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(to right, #0e3a27 0%, #0e3a27 30%, rgba(14, 58, 39, 0) 60%);
      z-index: 2;
    }

  .ht-hero-bg-desktop {
      display: block;
      position: absolute;
      top: 0;
      right: 0;
      width: 100%; 
      height: 100%;
      object-fit: contain; 
      object-position: right center; 
      z-index: 1;
    }
    
    .ht-hero-bg-mobile { display: none; }
    
    .ht-hero-content {
      position: relative;
      z-index: 3; 
      height: 100%;
      display: flex;
      align-items: center;
      padding-left: {{ section.settings.desktop_padding_left }}%;
    }
    
    .ht-hero-text-box {
      max-width: {{ section.settings.desktop_max_width }}px;
      color: #ffffff;
      text-align: left;
    }
    
    /* --- Desktop Trust Badge --- */
    .ht-hero-trust-badge {
      display: flex;
      align-items: center;
      justify-content: flex-start; 
      gap: 10px;
      margin-bottom: 1.5rem; 
      min-height: 24px;
    }
    .ht-hero-review-text {
      font-size: 1.4rem;
      font-family: "Questrial", sans-serif;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    .ht-hero-h1 { 
      font-size: {{ section.settings.desktop_title_size | divided_by: 10.0 }}rem; 
      line-height: 1.1; 
      margin-bottom: {{ section.settings.desktop_title_margin | divided_by: 10.0 }}rem; 
      max-width: {{ section.settings.desktop_title_max_width }}px; /* Added Title Width Control */
    }
    .ht-hero-p { 
      font-size: {{ section.settings.desktop_sub_size | divided_by: 10.0 }}rem; 
      margin-bottom: {{ section.settings.desktop_sub_margin | divided_by: 10.0 }}rem; 
    }
    
    #shopify-section-{{ section.id }} .ht-hero-button {
      background-color: #ffffff !important;
      color: #0e3a27 !important;
    }
  }

  /* --- Mobile: Ultra-High Anchor (Untouched) --- */
  @media screen and (max-width: 749px) {
    .ht-hero-wrapper {
      position: relative !important;
      height: 600px !important; 
      width: 100%;
      display: block !important;
      overflow: hidden;
      z-index: 1 !important; 
    }
    
    .ht-hero-bg-desktop { display: none; }
    .ht-hero-bg-mobile {
      display: block;
      position: absolute !important;
      top: 0;
      left: 0;
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
      z-index: 1;
    }
    
    .ht-hero-content {
      position: absolute !important;
      top: 0 !important; 
      left: 0;
      width: 100% !important;
      z-index: 2 !important; 
      padding: 1.5rem 2rem 0 !important; 
      text-align: center !important;
    }
    
    .ht-hero-text-box {
      margin: 0 auto !important;
      color: #ffffff !important;
    }
    
    /* --- Mobile Trust Badge --- */
    .ht-hero-trust-badge {
      display: flex;
      align-items: center;
      justify-content: center; 
      gap: 8px;
      margin-bottom: 1rem; 
      min-height: 24px;
    }
    .ht-hero-review-text {
      font-size: 1.2rem; 
      font-family: "Questrial", sans-serif;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    .ht-hero-h1 {
      font-size: 3.2rem !important;
      line-height: 1;
      margin-bottom: 0.5rem !important;
      font-weight: 700;
    }
    .ht-hero-p {
      font-size: 1.4rem !important;
      margin-bottom: 1.5rem !important; 
      line-height: 1.3;
      max-width: 260px;
      margin-left: auto;
      margin-right: auto;
    }
    #shopify-section-{{ section.id }} .ht-hero-button {
      width: 90% !important; 
      max-width: 320px;
    }
  }

  /* Global Star Style */
  .ht-hero-stars {
    display: flex;
    gap: 2px;
    align-items: center;
  }
</style>

<section class="ht-hero-wrapper">
  {%- if section.settings.image_desktop != blank -%}
    <img src="{{ section.settings.image_desktop | image_url: width: 2500 }}" 
         class="ht-hero-bg-desktop" 
         alt="{{ section.settings.image_desktop.alt | escape }}"
         loading="eager">
  {%- endif -%}

  {%- if section.settings.image_mobile != blank -%}
    <img src="{{ section.settings.image_mobile | image_url: width: 1200 }}" 
         class="ht-hero-bg-mobile" 
         alt="{{ section.settings.image_mobile.alt | escape }}"
         loading="eager">
  {%- else -%}
     <img src="{{ section.settings.image_desktop | image_url: width: 1200 }}" class="ht-hero-bg-mobile">
  {%- endif -%}

  <div class="ht-hero-content">
    <div class="ht-hero-text-box">
      
      {%- if section.settings.show_trust_badge -%}
        <div class="ht-hero-trust-badge">
          
          <div class="ht-hero-stars" style="color: {{ section.settings.star_color }};">
            {%- for i in (1..5) -%}
              <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
              </svg>
            {%- endfor -%}
          </div>
          
          <span class="ht-hero-review-text" style="color: {{ section.settings.review_text_color }};">
            {{ section.settings.review_text }}
          </span>
          
        </div>
      {%- endif -%}

      <h1 class="ht-hero-h1">{{ section.settings.heading }}</h1>
      <p class="ht-hero-p">{{ section.settings.subheading }}</p>
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.link }}" class="ht-hero-button">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "HT Banner Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "image_picker", "id": "image_desktop", "label": "Desktop Image (Wide/Marble on Right)" },
    { "type": "image_picker", "id": "image_mobile", "label": "Mobile Image (Product at Bottom)" },
    
    { "type": "header", "content": "Desktop Formatting Controls" },
    { "type": "range", "id": "desktop_height", "label": "Banner Height", "min": 400, "max": 900, "step": 10, "unit": "px", "default": 650 },
    { "type": "range", "id": "desktop_padding_left", "label": "Text Box Position (Left Indent)", "min": 0, "max": 30, "step": 1, "unit": "%", "default": 10 },
    { "type": "range", "id": "desktop_max_width", "label": "Total Text Box Max Width", "min": 300, "max": 800, "step": 10, "unit": "px", "default": 500 },
    { "type": "range", "id": "desktop_title_max_width", "label": "Title Only Max Width", "min": 200, "max": 800, "step": 10, "unit": "px", "default": 500 },
    { "type": "range", "id": "desktop_title_size", "label": "Title Font Size", "min": 20, "max": 80, "step": 1, "default": 42 },
    { "type": "range", "id": "desktop_title_margin", "label": "Space Below Title", "min": 0, "max": 50, "step": 1, "default": 20 },
    { "type": "range", "id": "desktop_sub_size", "label": "Subtitle Font Size", "min": 10, "max": 40, "step": 1, "default": 18 },
    { "type": "range", "id": "desktop_sub_margin", "label": "Space Below Subtitle", "min": 0, "max": 60, "step": 1, "default": 35 },

    { "type": "header", "content": "Trust Badge (Stars)" },
    { "type": "checkbox", "id": "show_trust_badge", "label": "Show Trust Badge", "default": true },
    { "type": "color", "id": "star_color", "label": "Star Color", "default": "#FF8A00" },
    { "type": "text", "id": "review_text", "label": "Banner Review Text", "default": "4.7/5 based on 46 reviews" },
    { "type": "color", "id": "review_text_color", "label": "Review Text Color", "default": "#ffffff" },

    { "type": "header", "content": "Hero Text" },
    { "type": "inline_richtext", "id": "heading", "default": "Unlock Your Skin's Full Potential", "label": "Heading" },
    { "type": "inline_richtext", "id": "subheading", "default": "Pure, nutrient-rich, grass-fed tallow.", "label": "Subheading" },
    { "type": "text", "id": "button_label", "default": "SHOP THE EVERYDAY JAR", "label": "Button label" },
    { "type": "url", "id": "link", "label": "Button link" }
  ],
  "presets": [ { "name": "HT Banner Hero" } ]
}
{% endschema %}