{%- comment -%} HT • Premium Scrolling Strip with Mixed Icon Logic {%- endcomment -%}

<section class="ht-ticker-section" id="ht-ticker-{{ section.id }}">
  <div class="ht-ticker-container">
    <div class="ht-ticker-track">
      {%- capture ticker_items -%}
        {%- for block in section.blocks -%}
          <div class="ht-ticker-item" {{ block.shopify_attributes }}>
            {%- if block.settings.icon == 'check' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12.5l3 3 7-7"/></svg>
            {%- elsif block.settings.icon == 'shipping' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            {%- elsif block.settings.icon == 'fast' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            {%- elsif block.settings.icon == 'clock' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            {%- elsif block.settings.icon == 'usa' -%}
              <svg viewBox="0 0 512 512"><path d="M0 80v352h512V80H0zm480 320H32V112h448v288z"/><path d="M32 112h176v128H32z"/><path d="M208 139.5h272v27H208zM208 193.5h272v27H208zM32 268.5h448v27H32zM32 322.5h448v27H32z"/></svg>
            {%- elsif block.settings.icon == 'cow' -%}
              <svg viewBox="0 0 256 256"><path d="M104,192a8,8,0,0,1-8,8H80a8,8,0,0,1,0-16H96A8,8,0,0,1,104,192Zm72-8H160a8,8,0,0,0,0,16h16a8,8,0,0,0,0-16Zm-76-48a12,12,0,1,0-12-12A12,12,0,0,0,100,136Zm56,0a12,12,0,1,0-12-12A12,12,0,0,0,156,136Zm88.39-13.88A16,16,0,0,1,232,128H200v32a40,40,0,0,1-24,72H80a40,40,0,0,1-24-72V128H24A16,16,0,0,1,8.31,109,56.13,56.13,0,0,1,63.22,64h1.64A55.83,55.83,0,0,1,48,24a8,8,0,0,1,16,0,40,40,0,0,0,40,40h48a40,40,0,0,0,40-40,8,8,0,0,1,16,0,55.83,55.83,0,0,1-16.86,40h1.64a56.13,56.13,0,0,1,54.91,45A15.82,15.82,0,0,1,244.39,122.12ZM72,152.8a40.57,40.57,0,0,1,8-.8h96a40.57,40.57,0,0,1,8,.8V104a24,24,0,0,0-24-24H96a24,24,0,0,0-24,24ZM56,112v-8a39.81,39.81,0,0,1,8-24h-.8A40.09,40.09,0,0,0,24,112Zm144,80a24,24,0,0,0-24-24H80a24,24,0,0,0,0,48h96A24,24,0,0,0,200,192Zm32-80a40.08,40.08,0,0,0-39.2-32H192a39.81,39.81,0,0,1,8,24v8Z"/></svg>
            {%- endif -%}
            <span>{{ block.settings.text }}</span>
          </div>
        {%- endfor -%}
      {%- endcapture -%}

      {{ ticker_items }}{{ ticker_items }}{{ ticker_items }}{{ ticker_items }}
    </div>
  </div>
</section>

<style>
  .ht-ticker-section {
    position: relative;
    overflow: hidden;
    padding: 18px 0;
    width: 100%;
    margin: {{ section.settings.margin_top }}px 0 {{ section.settings.margin_bottom }}px 0;
    border-top: 1px solid #E5E9E4;
    border-bottom: 1px solid #E5E9E4;
    
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% else %}
      background-color: #ffffff;
    {% endif %}
  }

  .ht-ticker-section::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(255, 255, 255, {{ section.settings.overlay_opacity | divided_by: 100.0 }}); 
    z-index: 1;
  }

  .ht-ticker-container {
    position: relative;
    z-index: 2;
    display: flex;
    width: 100%;
  }

  .ht-ticker-track {
    display: flex;
    white-space: nowrap;
    animation: ht-scroll {{ section.settings.speed }}s linear infinite;
    will-change: transform;
  }

  .ht-ticker-item {
    display: flex;
    align-items: center;
    padding: 0 45px;
    color: #0E3A27; /* Brand Dark Green */
    font-family: "Bricolage Grotesque", sans-serif;
    font-weight: 800;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .ht-ticker-item svg {
    width: 18px;
    height: 18px;
    margin-right: 12px;
    flex-shrink: 0;
    stroke: #0E3A27; 
    fill: #0E3A27; 
  }

  .ht-ticker-item svg[stroke-width] {
    fill: none !important;
  }

  .ht-ticker-item svg:not([stroke-width]) {
    stroke: none !important;
  }

  @keyframes ht-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media screen and (max-width: 749px) {
    .ht-ticker-section { padding: 14px 0; }
    .ht-ticker-item { padding: 0 25px; font-size: 12px; }
    .ht-ticker-item svg { width: 16px; height: 16px; margin-right: 8px; }
  }
</style>

{% schema %}
{
  "name": "HT Scrolling Strip",
  "settings": [
    { "type": "image_picker", "id": "bg_image", "label": "Marble Background Image" },
    { "type": "range", "id": "overlay_opacity", "label": "White Overlay Opacity", "min": 0, "max": 100, "step": 5, "default": 30 },
    { "type": "range", "id": "speed", "label": "Scroll Speed (seconds)", "min": 10, "max": 60, "step": 5, "default": 25 },
    { "type": "range", "id": "margin_top", "label": "Margin Top", "min": 0, "max": 100, "step": 5, "default": 20 },
    { "type": "range", "id": "margin_bottom", "label": "Margin Bottom", "min": 0, "max": 100, "step": 5, "default": 20 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Ticker Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Free Shipping" },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "check", "label": "Checkmark" },
            { "value": "shipping", "label": "Truck" },
            { "value": "fast", "label": "Lightning" },
            { "value": "clock", "label": "Clock" },
            { "value": "usa", "label": "American Flag" },
            { "value": "cow", "label": "Cow / Grass Fed" }
          ],
          "default": "check"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HT Scrolling Strip",
      "blocks": [
        { "type": "item", "settings": { "text": "Always Grass Fed", "icon": "cow" } },
        { "type": "item", "settings": { "text": "Made in the USA", "icon": "usa" } },
        { "type": "item", "settings": { "text": "Free Shipping", "icon": "shipping" } }
      ]
    }
  ]
}
{% endschema %}