<div class="tallow-section-wrapper">
  <div class="tallow-content-container">
    <p class="tallow-eyebrow">THE MODERN ALL-IN-ONE</p>
    <h2 class="tallow-headline">
      <span class="line-one">Nourished by Tallow,</span>
      <span class="line-two">Perfected by Nature.</span>
    </h2>
    <p class="tallow-subtext">
      One jar for every skin need. No fillers, no synthetics—just the bio-available nutrients your skin was built to absorb.
    </p>
    <a href="/products/your-product-handle" class="tallow-button">SHOP THE BALM</a>
  </div>
</div>

<style>
  .tallow-section-wrapper {
    background-color: #f9f9f7; /* Soft off-white bone color */
    padding: 80px 20px;
    text-align: center;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .tallow-content-container {
    max-width: 800px;
  }
  .tallow-eyebrow {
    font-size: 14px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #666;
    margin-bottom: 20px;
    font-weight: 500;
  }
  .tallow-headline {
    font-size: clamp(32px, 5vw, 56px); /* Responsive sizing */
    line-height: 1.1;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 24px 0;
  }
  .tallow-headline span {
    display: block;
  }
  .tallow-subtext {
    font-size: 18px;
    line-height: 1.6;
    color: #444;
    max-width: 600px;
    margin: 0 auto 32px auto;
  }
  .tallow-button {
    display: inline-block;
    padding: 12px 32px;
    background-color: #1a1a1a;
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    letter-spacing: 0.1em;
    font-size: 13px;
    transition: opacity 0.3s;
  }
  .tallow-button:hover {
    opacity: 0.8;
  }
</style>

{% schema %}
{
  "name": "Tallow Modern Hero",
  "settings": [],
  "presets": [
    {
      "name": "Tallow Modern Hero"
    }
  ]
}
{% endschema %}