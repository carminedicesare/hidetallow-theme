{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}

<style>
  /* --- Hide Tallow Global Branding --- */
  #shopify-section-{{ section.id }} .button {
    border-radius: 50px !important;
    padding: 1.2rem 3rem !important;
    text-transform: uppercase;
    letter-spacing: 0.1rem;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none !important;      
    outline: none !important;     
    background-color: #0e3a27 !important; 
    color: #ffffff !important;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    margin-top: 1rem;
    position: relative !important;
    z-index: 2 !important;
  }

  /* --- Navigation Fix: White dots on top of image area --- */
  #shopify-section-{{ section.id }} .slideshow__controls {
    position: absolute !important;
    z-index: 5 !important;
    background: transparent !important;
  }
  #shopify-section-{{ section.id }} .slider-button {
    color: #ffffff !important;
  }
  #shopify-section-{{ section.id }} .dot {
    background-color: #ffffff !important;
  }

  /* --- Desktop: Clean Split Layout (Working) --- */
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .slideshow__slide {
      display: flex !important;
      flex-direction: row !important;
      height: 650px !important; 
      background: #ffffff;
      width: 100%;
    }
    #shopify-section-{{ section.id }} .slideshow__media {
      width: 50% !important;
      flex: 0 0 50% !important;
      height: 100% !important;
      position: relative !important;
    }
    #shopify-section-{{ section.id }} .slideshow__media img {
      width: 100%;
      height: 100%;
      object-fit: cover !important;
    }
    #shopify-section-{{ section.id }} .slideshow__text-wrapper {
      width: 50% !important;
      flex: 0 0 50% !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center;
      padding: 5rem;
      position: static !important; /* Prevents overlay behavior */
    }
    #shopify-section-{{ section.id }} .slideshow__text {
      max-width: 45rem;
      text-align: center;
    }
    #shopify-section-{{ section.id }} .slideshow__controls {
      left: 25% !important; 
      bottom: 20px !important;
    }
  }

  /* --- Mobile: Vertical Stacked Fix --- */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .slideshow__slide {
      display: flex !important;
      flex-direction: column !important; /* Image top, text bottom */
      height: auto !important;
      background: #ffffff !important;
    }
    #shopify-section-{{ section.id }} .slideshow__media {
      width: 100% !important;
      height: 350px !important; /* Locked height to prevent "messed up" photo */
      position: relative !important;
      flex: 0 0 350px !important;
    }
    #shopify-section-{{ section.id }} .slideshow__media img {
      width: 100%;
      height: 100%;
      object-fit: cover !important;
    }
    #shopify-section-{{ section.id }} .slideshow__text-wrapper {
      width: 100% !important;
      padding: 3rem 2rem !important;
      background: #ffffff !important;
      position: relative !important; /* Moves it out of overlay mode */
      display: flex !important;
      align-items: center;
      justify-content: center;
      flex: 1 1 auto !important;
    }
    #shopify-section-{{ section.id }} .slideshow__text {
      text-align: center !important;
      width: 100%;
    }
    #shopify-section-{{ section.id }} .banner__heading {
      color: #0e3a27 !important; 
      font-size: 2.6rem !important;
      margin-bottom: 1rem !important;
    }
    #shopify-section-{{ section.id }} .banner__text {
      color: #0e3a27 !important;
      margin-bottom: 1.5rem !important;
    }
    #shopify-section-{{ section.id }} .button {
      width: 100% !important;
    }
    /* Move Dots to bottom of IMAGE area on mobile */
    #shopify-section-{{ section.id }} .slideshow__controls {
      top: 310px !important;
      bottom: auto !important;
      left: 50% !important;
      transform: translateX(-50%);
    }
  }
</style>

<slideshow-component class="slider-mobile-gutter" role="region" aria-roledescription="Carousel">
  <div class="slideshow banner grid grid--1-col slider slider--everywhere"
    id="Slider-{{ section.id }}"
    aria-live="polite"
    aria-atomic="true"
    data-autoplay="{{ section.settings.auto_rotate }}"
    data-speed="{{ section.settings.change_slides_speed }}"
  >
    {%- for block in section.blocks -%}
      <div class="slideshow__slide grid__item grid--1-col slider__slide"
        id="Slide-{{ section.id }}-{{ forloop.index }}"
        {{ block.shopify_attributes }}
        role="group"
        tabindex="-1"
      >
        <div class="slideshow__media">
          {%- if block.settings.image -%}
            <img
              src="{{ block.settings.image | image_url: width: 1500 }}"
              alt="{{ block.settings.image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>

        <div class="slideshow__text-wrapper">
          <div class="slideshow__text">
            {%- if block.settings.heading != blank -%}
              <h2 class="banner__heading inline-richtext h1" style="color: #0e3a27;">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.subheading != blank -%}
              <div class="banner__text rte" style="color: #0e3a27;"><p>{{ block.settings.subheading }}</p></div>
            {%- endif -%}
            {%- if block.settings.button_label != blank -%}
              <div class="banner__buttons">
                <a href="{{ block.settings.link }}" class="button">{{ block.settings.button_label }}</a>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="slideshow__controls slider-buttons no-js-hidden">
      <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="Previous">
        <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
      </button>
      <div class="slider-counter slider-counter--dots">
        <div class="slideshow__control-wrapper">
          {%- for block in section.blocks -%}
            <button class="slider-counter__link slider-counter__link--dots link" aria-label="Slide {{ forloop.index }}">
              <span class="dot"></span>
            </button>
          {%- endfor -%}
        </div>
      </div>
      <button type="button" class="slider-button slider-button--next" name="next" aria-label="Next">
        <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
      </button>
    </div>
  {%- endif -%}
</slideshow-component>

{% schema %}
{
  "name": "Split Stack Slideshow",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "checkbox", "id": "auto_rotate", "label": "Auto-rotate slides", "default": false },
    { "type": "range", "id": "change_slides_speed", "min": 3, "max": 9, "step": 2, "unit": "s", "label": "Change speed", "default": 5 }
  ],
  "blocks": [
    { "type": "slide", "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Slide Image" },
        { "type": "inline_richtext", "id": "heading", "default": "Your Daily Skin Essential", "label": "Heading" },
        { "type": "inline_richtext", "id": "subheading", "default": "Naturally nutrient-rich.", "label": "Subheading" },
        { "type": "text", "id": "button_label", "default": "Shop Now", "label": "Button label" },
        { "type": "url", "id": "link", "label": "Button link" }
      ]
    }
  ],
  "presets": [
    { "name": "Split Stack Slideshow", "blocks": [ { "type": "slide" } ] }
  ]
}
{% endschema %}