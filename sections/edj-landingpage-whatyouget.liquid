<style>
  .ht-value-section-{{ section.id }} {
    /* Map Schema settings to CSS variables for clean, maintainable code */
    --bg-color: {{ section.settings.bg_color }};
    --text-color: {{ section.settings.text_color }};
    --title-color: {{ section.settings.title_color }};
    --icon-color: {{ section.settings.icon_color }};
    
    /* Mobile Sizing */
    --padding-mobile: {{ section.settings.padding_mobile }}rem 1.5rem;
    --icon-size-mobile: 40px;
    --title-size-mobile: 1.1rem;
    --text-size-mobile: 0.9rem;
    
    /* Desktop Sizing (Controlled via Schema) */
    --padding-desktop: {{ section.settings.padding_desktop }}rem 2rem;
    --icon-size-desktop: {{ section.settings.icon_size_desktop }}px;
    --title-size-desktop: {{ section.settings.title_size_desktop }}px;
    --text-size-desktop: {{ section.settings.text_size_desktop }}px;

    background-color: var(--bg-color);
    color: var(--text-color);
    padding: var(--padding-mobile);
    border-top: 1px solid rgba(0,0,0,0.05);
  }

  .ht-value-section-{{ section.id }} .ht-value-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* --- Mobile: 2x2 Grid --- */
  .ht-value-section-{{ section.id }} .ht-value-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem 1rem;
  }

  .ht-value-section-{{ section.id }} .ht-value-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .ht-value-section-{{ section.id }} .ht-value-icon {
    width: var(--icon-size-mobile);
    height: var(--icon-size-mobile);
    margin-bottom: 1rem;
    color: var(--icon-color);
    display: flex;
    justify-content: center;
    align-items: center;
    transition: transform 0.3s ease;
  }
  
  .ht-value-section-{{ section.id }} .ht-value-icon svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .ht-value-section-{{ section.id }} .ht-value-title {
    color: var(--title-color);
    font-size: var(--title-size-mobile);
    font-weight: 700;
    margin-bottom: 0.4rem;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ht-value-section-{{ section.id }} .ht-value-text {
    font-size: var(--text-size-mobile);
    line-height: 1.4;
    opacity: 0.85;
    margin: 0;
  }

  /* --- Desktop: 4-Column Row --- */
  @media screen and (min-width: 750px) {
    .ht-value-section-{{ section.id }} {
      padding: var(--padding-desktop);
    }
    
    .ht-value-section-{{ section.id }} .ht-value-container {
      max-width: 1400px; /* Wider container to accommodate larger elements */
    }

    .ht-value-section-{{ section.id }} .ht-value-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 4rem; /* Increased gap to prevent crowding */
    }

    .ht-value-section-{{ section.id }} .ht-value-icon {
      width: var(--icon-size-desktop);
      height: var(--icon-size-desktop);
      margin-bottom: 1.5rem;
    }

    .ht-value-section-{{ section.id }} .ht-value-title {
      font-size: calc(var(--title-size-desktop) / 16 * 1rem); /* Converts px to rem securely */
      margin-bottom: 0.75rem;
    }

    .ht-value-section-{{ section.id }} .ht-value-text {
      font-size: calc(var(--text-size-desktop) / 16 * 1rem);
      line-height: 1.5;
    }
    
    /* Pro Touch: Subtle hover effect for desktop */
    .ht-value-section-{{ section.id }} .ht-value-item:hover .ht-value-icon {
      transform: translateY(-5px) scale(1.05);
    }
  }
</style>

<section class="ht-value-section-{{ section.id }}">
  <div class="ht-value-container">
    <div class="ht-value-grid">

      <div class="ht-value-item">
        <div class="ht-value-icon">
          {%- if section.settings.icon_1 != blank -%}
            {{ section.settings.icon_1 }}
          {%- else -%}
            <svg viewBox="0 0 24 24"><path d="M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22L6.66,19.7C7.14,19.87 7.64,20 8,20C19,20 22,3 22,3C21,5 14,5.25 9,6.25C4,7.25 2,11.5 2,13.5C2,15.5 3.75,17.25 3.75,17.25C7,8 17,8 17,8Z"/></svg>
          {%- endif -%}
        </div>
        <h3 class="ht-value-title">{{ section.settings.title_1 }}</h3>
        <p class="ht-value-text">{{ section.settings.text_1 }}</p>
      </div>

      <div class="ht-value-item">
        <div class="ht-value-icon">
          {%- if section.settings.icon_2 != blank -%}
            {{ section.settings.icon_2 }}
          {%- else -%}
            <svg viewBox="0 0 24 24"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/></svg>
          {%- endif -%}
        </div>
        <h3 class="ht-value-title">{{ section.settings.title_2 }}</h3>
        <p class="ht-value-text">{{ section.settings.text_2 }}</p>
      </div>

      <div class="ht-value-item">
        <div class="ht-value-icon">
          {%- if section.settings.icon_3 != blank -%}
            {{ section.settings.icon_3 }}
          {%- else -%}
            <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1.41 16.09V20h-2.67v-1.93c-1.71-.36-3.16-1.46-3.27-3.4h1.96c.1 1.05.82 1.87 2.65 1.87 1.96 0 2.4-.98 2.4-1.59 0-.83-.44-1.61-2.67-2.14-2.48-.6-4.18-1.62-4.18-3.67 0-1.72 1.39-2.84 3.11-3.21V4h2.67v1.95c1.86.45 2.79 1.86 2.85 3.39H14.3c-.05-1.11-.64-1.87-2.22-1.87-1.5 0-2.4.68-2.4 1.64 0 .84.65 1.39 2.67 1.91s4.18 1.39 4.18 3.91c-.01 1.83-1.38 2.83-3.12 3.16z"/></svg>
          {%- endif -%}
        </div>
        <h3 class="ht-value-title">{{ section.settings.title_3 }}</h3>
        <p class="ht-value-text">{{ section.settings.text_3 }}</p>
      </div>

      <div class="ht-value-item">
        <div class="ht-value-icon">
          {%- if section.settings.icon_4 != blank -%}
            {{ section.settings.icon_4 }}
          {%- else -%}
            <svg viewBox="0 0 24 24"><path d="M20.08,9.08L14.92,3.92C14.14,3.14 12.87,3.14 12.09,3.92L6.26,9.75C5.87,10.14 5.68,10.65 5.68,11.16C5.68,11.67 5.87,12.18 6.26,12.57L11.42,17.73C12.2,18.5 13.47,18.5 14.25,17.73L20.08,11.9C20.86,11.12 20.86,9.86 20.08,9.08M12.83,16.32L7.67,11.16L13.5,5.33L18.66,10.5L12.83,16.32M2.5,19V21H21.5V19H2.5Z"/></svg>
          {%- endif -%}
        </div>
        <h3 class="ht-value-title">{{ section.settings.title_4 }}</h3>
        <p class="ht-value-text">{{ section.settings.text_4 }}</p>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Value Prop Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Colors & Spacing"
    },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "color", "id": "title_color", "label": "Title Color", "default": "#0e3a27" },
    { "type": "color", "id": "text_color", "label": "Description Text Color", "default": "#0e3a27" },
    { "type": "color", "id": "icon_color", "label": "Icon Color", "default": "#0e3a27" },
    { "type": "range", "id": "padding_desktop", "label": "Desktop Top/Bottom Padding", "min": 2, "max": 8, "step": 1, "unit": "rem", "default": 4 },
    { "type": "range", "id": "padding_mobile", "label": "Mobile Top/Bottom Padding", "min": 1, "max": 6, "step": 1, "unit": "rem", "default": 3 },
    
    {
      "type": "header",
      "content": "Desktop Element Sizing"
    },
    { "type": "range", "id": "icon_size_desktop", "label": "Desktop Icon Size", "min": 32, "max": 100, "step": 2, "unit": "px", "default": 64 },
    { "type": "range", "id": "title_size_desktop", "label": "Desktop Title Size", "min": 14, "max": 36, "step": 1, "unit": "px", "default": 24 },
    { "type": "range", "id": "text_size_desktop", "label": "Desktop Text Size", "min": 12, "max": 24, "step": 1, "unit": "px", "default": 18 },

    {
      "type": "header",
      "content": "Block 1: Ingredient"
    },
    { "type": "html", "id": "icon_1", "label": "Custom SVG Icon Code (Optional)" },
    { "type": "text", "id": "title_1", "label": "Heading", "default": "1 Ingredient" },
    { "type": "textarea", "id": "text_1", "label": "Description", "default": "100% pure, unrefined grass-fed tallow. Nothing else." },

    {
      "type": "header",
      "content": "Block 2: Lifespan"
    },
    { "type": "html", "id": "icon_2", "label": "Custom SVG Icon Code (Optional)" },
    { "type": "text", "id": "title_2", "label": "Heading", "default": "Lasts 30-60 Days" },
    { "type": "textarea", "id": "text_2", "label": "Description", "default": "A little goes a long way. Just a pea-sized amount covers your whole face." },

    {
      "type": "header",
      "content": "Block 3: Math"
    },
    { "type": "html", "id": "icon_3", "label": "Custom SVG Icon Code (Optional)" },
    { "type": "text", "id": "title_3", "label": "Heading", "default": "16¢ – 33¢ A Day" },
    { "type": "textarea", "id": "text_3", "label": "Description", "default": "Premium, sensitive-skin safe hydration for just pennies a day." },

    {
      "type": "header",
      "content": "Block 4: Texture & Scent"
    },
    { "type": "html", "id": "icon_4", "label": "Custom SVG Icon Code (Optional)" },
    { "type": "text", "id": "title_4", "label": "Heading", "default": "Odorless & Buttery" },
    { "type": "textarea", "id": "text_4", "label": "Description", "default": "Rich, non-greasy texture with a completely neutral, clean scent." }
  ],
  "presets": [ { "name": "Value Prop Grid" } ]
}
{% endschema %}