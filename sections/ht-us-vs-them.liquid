<div class="ht-comparison-section">
  <div class="ht-comp-header">
    <h2 class="ht-comp-title">{{ section.settings.heading }}</h2>
    <p class="ht-comp-subtitle">{{ section.settings.subheading }}</p>
  </div>

  <div class="ht-comp-grid">
    
    {% comment %} --- THEM (Competitors) --- {% endcomment %}
    <div class="ht-comp-card ht-them">
      <div class="ht-comp-image-wrapper">
        {%- if section.settings.them_image != blank -%}
          <img src="{{ section.settings.them_image | image_url: width: 600 }}" alt="Competitor" loading="lazy">
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'ht-placeholder-svg' }}
        {%- endif -%}
      </div>
      
      <div class="ht-card-content">
        <h3 class="ht-card-title">{{ section.settings.them_title }}</h3>
        <ul class="ht-comp-list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'them_point' -%}
              <li class="ht-comp-item">
                <span class="ht-icon-x">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    </div>

    {% comment %} --- US (Hide Tallow) --- {% endcomment %}
    <div class="ht-comp-card ht-us">
      {%- if section.settings.show_badge -%}
        <div class="ht-best-choice-badge">BEST CHOICE</div>
      {%- endif -%}
      
      <div class="ht-comp-image-wrapper">
        {%- if section.settings.us_image != blank -%}
          <img src="{{ section.settings.us_image | image_url: width: 600 }}" alt="Hide Tallow" loading="lazy">
        {%- else -%}
          {{ 'product-2' | placeholder_svg_tag: 'ht-placeholder-svg' }}
        {%- endif -%}
      </div>

      <div class="ht-card-content">
        <h3 class="ht-card-title">{{ section.settings.us_title }}</h3>
        <ul class="ht-comp-list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'us_point' -%}
              <li class="ht-comp-item">
                <span class="ht-icon-check">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    </div>

  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&display=swap');

  .ht-comparison-section {
    padding: 80px 20px;
    background-color: #fcfcfc;
    font-family: "Bricolage Grotesque", sans-serif;
    text-align: center;
    overflow: hidden;
  }

  .ht-comp-header { margin-bottom: 50px; }
  
  .ht-comp-title {
    font-size: 42px;
    font-weight: 800;
    color: #0E3A27;
    margin: 0 0 15px 0;
    text-transform: uppercase;
    line-height: 1.1;
  }
  
  .ht-comp-subtitle { font-size: 16px; color: #0E3A27; max-width: 600px; margin: 0 auto; }

  /* --- GRID LAYOUT --- */
  .ht-comp-grid {
    display: flex;
    justify-content: center;
    gap: 20px; 
    max-width: 1000px;
    margin: 0 auto;
    align-items: stretch;
  }

  /* --- CARDS --- */
  .ht-comp-card {
    flex: 1;
    background: #ffffff;
    border-radius: 20px;
    overflow: hidden; 
    text-align: left;
    position: relative;
    border: 1px solid #0E3A27;
    display: flex;
    flex-direction: column;
  }

  .ht-comp-image-wrapper {
    width: 100%;
    height: 400px; /* Adjusted height for desktop */
    background: #f4f4f4;
    position: relative;
    overflow: hidden;
  }
  
  .ht-comp-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover; /* Changed to cover for full bleed, but container height is taller to prevent zoom */
    display: block;
    object-position: center center; 
  }

  /* ADDED: Padding for the text and icons inside the card */
  .ht-card-content {
    padding: 30px 40px; /* First number is Top/Bottom, Second is Left/Right */
  }

  /* "THEM" STYLES */
  .ht-comp-card.ht-them {
    background: #f9f9f9;
    border: 1px solid #e0e0e0;
  }
  .ht-them .ht-card-title { color: #0E3A27; font-size: 24px; font-weight: 700; margin-bottom: 25px; }
  .ht-them .ht-comp-image-wrapper { filter: grayscale(100%); opacity: 0.8; } 

  /* "US" STYLES */
  .ht-comp-card.ht-us {
    background: #ffffff;
    border: 2px solid #0E3A27; 
    box-shadow: 0 15px 40px rgba(14, 58, 39, 0.1);
    transform: scale(1.02);
    z-index: 2;
  }
  .ht-us .ht-card-title { color: #0E3A27; font-size: 28px; font-weight: 800; margin-bottom: 25px; }

  /* BADGE */
  .ht-best-choice-badge {
    position: absolute;
    top: 15px;
    right: 15px; 
    background: #D4AF37;
    color: #0E3A27;
    font-size: 11px;
    font-weight: 800;
    padding: 6px 12px;
    border-radius: 6px;
    letter-spacing: 0.1em;
    z-index: 10;
    box-shadow: 0 4px 10px rgba(0,0,0,0.2);
  }

  /* --- LIST ITEMS --- */
  .ht-comp-list { list-style: none; padding: 0; margin: 0; }
  
  .ht-comp-item {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
    font-size: 15px;
    font-weight: 600;
    line-height: 1.4;
    color: #0E3A27;
  }

  /* ICONS */
  .ht-icon-x {
    min-width: 22px; height: 22px;
    background: #eeeeee;
    color: #0E3A27;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  
  .ht-icon-check {
    min-width: 22px; height: 22px;
    background: #0E3A27;
    color: #ffffff;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }

  /* --- MOBILE RESPONSIVE --- */
  @media screen and (max-width: 768px) {
    .ht-comparison-section { padding: 40px 10px; }
    .ht-comp-header { margin-bottom: 30px; }
    .ht-comp-title { font-size: 28px; }

    .ht-comp-grid { 
      flex-direction: row; 
      gap: 8px; 
      align-items: stretch;
    }
    
    .ht-comp-card { 
      border-radius: 12px !important; 
      margin: 0 !important; 
      transform: none !important; 
      flex: 1; 
    }

    .ht-comp-image-wrapper { height: 180px; }
    .ht-us .ht-comp-image-wrapper img { object-position: center center; }

    /* Mobile Padding Adjustment */
    .ht-card-content { padding: 15px 12px; }
    
    .ht-them .ht-card-title, .ht-us .ht-card-title { 
      font-size: 14px; 
      margin-bottom: 15px; 
    }

    .ht-comp-item { 
      font-size: 10px; 
      gap: 6px; 
      margin-bottom: 10px;
    }

    .ht-icon-x, .ht-icon-check { min-width: 14px; height: 14px; }
    .ht-icon-x svg, .ht-icon-check svg { width: 8px; height: 8px; }

    .ht-best-choice-badge {
      font-size: 8px;
      padding: 3px 5px;
      top: 5px;
      right: 5px;
    }
  }
</style>

{% schema %}
{
  "name": "HT Us vs Them",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why We Are Different" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "See why customers are making the switch." },
    
    { "type": "header", "content": "Competitor Settings" },
    { "type": "image_picker", "id": "them_image", "label": "Competitor Image" },
    { "type": "text", "id": "them_title", "label": "Competitor Title", "default": "The Other Guys" },
    
    { "type": "header", "content": "Our Brand Settings" },
    { "type": "image_picker", "id": "us_image", "label": "Our Brand Image" },
    { "type": "text", "id": "us_title", "label": "Our Brand Title", "default": "Hide Tallow" },
    { "type": "checkbox", "id": "show_badge", "label": "Show 'Best Choice' Badge", "default": true }
  ],
  "blocks": [
    {
      "type": "them_point",
      "name": "Them Point (Negative)",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Grainy & Inconsistent Texture" }
      ]
    },
    {
      "type": "us_point",
      "name": "Us Point (Positive)",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Triple-Purified & Silky Smooth" }
      ]
    }
  ],
  "presets": [
    {
      "name": "HT Us vs Them",
      "blocks": [
        { "type": "them_point", "settings": { "text": "Pungent \"Beefy\" Odor" } },
        { "type": "them_point", "settings": { "text": "Heavy, Greasy & Clogs Pores" } },
        { "type": "them_point", "settings": { "text": "Mass-Produced Industrial Tallow" } },
        { "type": "them_point", "settings": { "text": "Leaching Plastic Containers" } },
        { "type": "them_point", "settings": { "text": "Grainy & Inconsistent Texture" } },
        
        { "type": "us_point", "settings": { "text": "Naturally Odorless & Clean" } },
        { "type": "us_point", "settings": { "text": "Bio-Identical Deep Absorption" } },
        { "type": "us_point", "settings": { "text": "100% Regenerative Grass-Fed" } },
        { "type": "us_point", "settings": { "text": "Premium UV-Protected Glass" } },
        { "type": "us_point", "settings": { "text": "Triple-Purified & Silky Smooth" } }
      ]
    }
  ]
}
{% endschema %}