<div id="HT-BA-{{ section.id }}" class="ht-ba-section">
  <div class="ht-ba-container">
    <div class="ht-ba-content">
      
      {%- if section.settings.subheading != blank -%}
        <span class="ht-ba-subheading">{{ section.settings.subheading }}</span>
      {%- endif -%}
      
      <h2 class="ht-ba-heading">{{ section.settings.heading }}</h2>

      <div class="ht-pill-grid">
        
        <div class="ht-pill-card ht-pill-before">
          <span class="ht-pill-label">Before {{ section.settings.brand_name }}</span>
          <div class="ht-pill-text">{{ section.settings.before_list }}</div>
          
          {%- if section.settings.before_image != blank -%}
            <div class="ht-ba-img-wrapper">
              <img src="{{ section.settings.before_image | image_url: width: 600 }}" 
                   alt="Before" 
                   loading="lazy" 
                   class="ht-ba-img">
            </div>
          {%- endif -%}
        </div>
        
        <div class="ht-pill-card ht-pill-after">
          <span class="ht-pill-label">After {{ section.settings.brand_name }}</span>
          <div class="ht-pill-text">{{ section.settings.after_list }}</div>

          {%- if section.settings.after_image != blank -%}
            <div class="ht-ba-img-wrapper">
              <img src="{{ section.settings.after_image | image_url: width: 600 }}" 
                   alt="After" 
                   loading="lazy" 
                   class="ht-ba-img">
            </div>
          {%- endif -%}
        </div>

      </div>

    </div>
  </div>
</div>

<style>
  #HT-BA-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    color: {{ section.settings.text_color }};
  }

  .ht-ba-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ht-ba-content {
    text-align: center;
    max-width: 900px; /* Widened slightly to accommodate photos */
    margin: 0 auto;
  }

  .ht-ba-subheading {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 12px;
    opacity: 0.7;
    display: block;
    margin-bottom: 10px;
  }

  .ht-ba-heading {
    font-weight: 700;
    margin: 0 0 40px 0;
    line-height: 1.1;
    color: inherit;
    font-size: {{ section.settings.heading_size_mobile }}px;
  }

  /* Pills Grid */
  .ht-pill-grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ht-pill-card {
    border-radius: 30px; /* Reduced slightly to look better with square photos */
    padding: 30px 25px;
    text-align: center;
    transition: transform 0.2s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
  }

  /* Before Styling */
  .ht-pill-before {
    background: {{ section.settings.card_bg }};
    border: 1px solid transparent;
  }

  /* After Styling */
  .ht-pill-after {
    background: #ffffff;
    border: 1px solid {{ section.settings.border_color }};
    box-shadow: 0 5px 20px rgba(0,0,0,0.06);
  }

  .ht-pill-label {
    font-size: 11px;
    text-transform: uppercase;
    font-weight: 700;
    opacity: 0.6;
    display: block;
    margin-bottom: 8px;
  }
  
  .ht-pill-after .ht-pill-label { opacity: 1; color: {{ section.settings.accent_color }}; }

  .ht-pill-text {
    font-weight: 600;
    font-size: {{ section.settings.pill_font_size }}px;
    line-height: 1.4;
    margin-bottom: 20px; /* Space between text and image */
  }

  /* Image Styling */
  .ht-ba-img-wrapper {
    width: 100%;
    border-radius: 20px;
    overflow: hidden;
    margin-top: auto; /* Pushes image to bottom if cards uneven */
  }

  .ht-ba-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  @media screen and (min-width: 750px) {
    .ht-ba-heading { font-size: {{ section.settings.heading_size_desktop }}px; }
    
    .ht-pill-grid {
      flex-direction: row;
      align-items: stretch; /* Makes cards same height */
      gap: 30px;
    }
    
    .ht-pill-card {
      flex: 1;
      padding: 40px 30px;
    }
  }
</style>

{% schema %}
{
  "name": "Before & After Pills",
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" },
    { "type": "color", "id": "card_bg", "label": "Grey Card Background", "default": "#f9f9f9" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#0e3a27" },
    { "type": "color", "id": "accent_color", "label": "Accent Color", "default": "#0e3a27" },
    { "type": "color", "id": "border_color", "label": "Border Color", "default": "#eeeeee" },

    { "type": "header", "content": "Copywriting" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "EXPERIENCE THE TRANSFORMATION" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Proven Transformation" },
    { "type": "text", "id": "brand_name", "label": "Brand Name", "default": "Hide Tallow" },
    
    { "type": "header", "content": "Before Card" },
    { "type": "textarea", "id": "before_list", "label": "Before Text", "default": "Dull, Dry, Irritated Skin" },
    { "type": "image_picker", "id": "before_image", "label": "Before Image" },

    { "type": "header", "content": "After Card" },
    { "type": "textarea", "id": "after_list", "label": "After Text", "default": "Hydrated, Glowing, Calm Skin" },
    { "type": "image_picker", "id": "after_image", "label": "After Image" },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_size_desktop", "min": 30, "max": 100, "step": 2, "unit": "px", "label": "Heading Size (Desktop)", "default": 56 },
    { "type": "range", "id": "heading_size_mobile", "min": 20, "max": 50, "step": 1, "unit": "px", "label": "Heading Size (Mobile)", "default": 32 },
    { "type": "range", "id": "pill_font_size", "min": 12, "max": 30, "step": 1, "unit": "px", "label": "Pill Font Size", "default": 18 },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Top Padding", "default": 60 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Bottom Padding", "default": 60 }
  ],
  "presets": [ { "name": "Landing Page - Before & After" } ]
}
{% endschema %}