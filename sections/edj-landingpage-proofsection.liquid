<style>
  .ht-proof-section-{{ section.id }} {
    /* Color Variables */
    --bg-color: {{ section.settings.bg_color }};
    --heading-color: {{ section.settings.heading_color }};
    --card-bg-color: {{ section.settings.card_bg_color }};
    --quote-color: {{ section.settings.quote_color }};
    --text-color: {{ section.settings.text_color }};
    --tag-bg-color: {{ section.settings.tag_bg_color }};
    --tag-text-color: {{ section.settings.tag_text_color }};
    --star-color: {{ section.settings.star_color }};
    --empty-star-color: {{ section.settings.empty_star_color }};

    /* Spacing & Sizing Variables */
    --padding-mobile: {{ section.settings.padding_mobile }}rem 0;
    --padding-desktop: {{ section.settings.padding_desktop }}rem 0;
    
    --heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --quote-size-desktop: {{ section.settings.quote_size_desktop }}px;
    --text-size-desktop: {{ section.settings.text_size_desktop }}px;
    --star-size-desktop: {{ section.settings.star_size_desktop }}px;

    background-color: var(--bg-color);
    padding: var(--padding-mobile); 
    overflow: hidden;
  }

  .ht-proof-section-{{ section.id }} .ht-proof-header {
    text-align: center;
    padding: 0 1.5rem;
    margin-bottom: 2rem;
  }

  /* --- Dynamic Fractional Stars --- */
  .ht-proof-section-{{ section.id }} .ht-proof-global-stars-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-bottom: 0.5rem;
  }

  .ht-proof-section-{{ section.id }} .ht-star-rating {
    position: relative;
    display: inline-flex;
  }

  .ht-proof-section-{{ section.id }} .ht-star-bg {
    display: flex;
    gap: 2px;
    color: var(--empty-star-color);
  }

  .ht-proof-section-{{ section.id }} .ht-star-fg {
    display: flex;
    gap: 2px;
    position: absolute;
    top: 0;
    left: 0;
    overflow: hidden;
    color: var(--star-color);
    width: var(--rating-width, 100%);
  }

  .ht-proof-section-{{ section.id }} .ht-star-rating svg {
    width: 24px;
    height: 24px;
    fill: currentColor;
    flex-shrink: 0;
  }

  .ht-proof-section-{{ section.id }} .ht-rating-text {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--heading-color);
    margin-left: 4px;
  }

  .ht-proof-section-{{ section.id }} .ht-proof-h2 {
    color: var(--heading-color);
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
    letter-spacing: 0.02em;
  }

  /* --- Mobile: Swipeable Track --- */
  .ht-proof-section-{{ section.id }} .ht-proof-track {
    display: flex;
    align-items: stretch; 
    gap: 1rem;
    padding: 0 1.5rem 1.5rem 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; 
    -ms-overflow-style: none;  
  }
  
  .ht-proof-section-{{ section.id }} .ht-proof-track::-webkit-scrollbar {
    display: none; 
  }

  .ht-proof-section-{{ section.id }} .ht-proof-card {
    position: relative; 
    flex: 0 0 85%; 
    scroll-snap-align: center;
    background-color: var(--card-bg-color);
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 12px;
    padding: 1.5rem;
    text-align: left;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  /* Issue Tag in Top Right - Locked & Proportionate */
  .ht-proof-section-{{ section.id }} .ht-card-tag {
    position: absolute;
    top: 1.2rem;
    right: 1.2rem;
    background-color: var(--tag-bg-color);
    color: var(--tag-text-color);
    font-size: 11px; /* Hardcoded safe mobile size */
    font-weight: 700;
    padding: 4px 10px; 
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1; /* Stops pill from getting fat */
    z-index: 2;
  }

  .ht-proof-section-{{ section.id }} .ht-card-stars {
    display: flex;
    gap: 2px;
    color: var(--star-color);
    margin-bottom: 0.8rem;
    padding-right: 80px; 
  }

  .ht-proof-section-{{ section.id }} .ht-card-stars svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
    transition: width 0.3s ease, height 0.3s ease;
  }

  .ht-proof-section-{{ section.id }} .ht-card-quote {
    color: var(--quote-color);
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.5rem;
    padding-right: 0; 
  }

  .ht-proof-section-{{ section.id }} .ht-card-body {
    color: var(--text-color);
    font-size: 0.95rem;
    line-height: 1.4;
    opacity: 0.85;
    margin-bottom: 1.5rem;
  }

  .ht-proof-section-{{ section.id }} .ht-card-author {
    color: var(--text-color);
    margin-top: auto; 
    font-size: 0.85rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ht-proof-section-{{ section.id }} .ht-verified-check {
    width: 14px;
    height: 14px;
    color: #4CAF50; /* Trust Green */
  }

  /* --- Desktop: 3-Column Grid & Scaling --- */
  @media screen and (min-width: 750px) {
    .ht-proof-section-{{ section.id }} {
      padding: var(--padding-desktop);
    }

    .ht-proof-section-{{ section.id }} .ht-proof-header {
      margin-bottom: 3.5rem;
    }

    .ht-proof-section-{{ section.id }} .ht-proof-h2 {
      font-size: calc(var(--heading-size-desktop) / 16 * 1rem);
    }

    .ht-proof-section-{{ section.id }} .ht-proof-track {
      max-width: 1400px; 
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2.5rem;
      overflow-x: visible;
      padding: 0 2rem;
    }

    .ht-proof-section-{{ section.id }} .ht-proof-card {
      flex: unset;
      padding: 2.5rem; 
    }

    .ht-proof-section-{{ section.id }} .ht-proof-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.06);
    }

    /* Locked Desktop Badge */
    .ht-proof-section-{{ section.id }} .ht-card-tag {
      top: 1.5rem;
      right: 1.5rem;
      font-size: 13px; /* Proportionately larger than mobile, but tight enough to be a micro-label */
      padding: 5px 14px; 
    }
    
    .ht-proof-section-{{ section.id }} .ht-card-stars {
       padding-right: 0; 
       margin-bottom: 1.2rem;
    }

    .ht-proof-section-{{ section.id }} .ht-card-stars svg {
      width: var(--star-size-desktop);
      height: var(--star-size-desktop);
    }

    .ht-proof-section-{{ section.id }} .ht-card-quote {
      font-size: calc(var(--quote-size-desktop) / 16 * 1rem);
      margin-bottom: 0.75rem;
    }

    .ht-proof-section-{{ section.id }} .ht-card-body {
      font-size: calc(var(--text-size-desktop) / 16 * 1rem);
      line-height: 1.5;
    }

    .ht-proof-section-{{ section.id }} .ht-card-author {
      font-size: calc((var(--text-size-desktop) - 2) / 16 * 1rem); 
    }
  }
</style>

<section class="ht-proof-section-{{ section.id }}">
  
  <div class="ht-proof-header">
    <div class="ht-proof-global-stars-wrapper">
      
      {%- assign rating_percentage = section.settings.global_rating | divided_by: 5.0 | times: 100 -%}
      
      <div class="ht-star-rating" style="--rating-width: {{ rating_percentage }}%;">
        <div class="ht-star-bg">
          {%- for i in (1..5) -%}
            <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
          {%- endfor -%}
        </div>
        <div class="ht-star-fg">
          {%- for i in (1..5) -%}
            <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
          {%- endfor -%}
        </div>
      </div>

      {%- if section.settings.show_rating_text -%}
        <span class="ht-rating-text">{{ section.settings.global_rating }} / 5.0</span>
      {%- endif -%}

    </div>
    
    {%- if section.settings.main_heading != blank -%}
      <h2 class="ht-proof-h2">{{ section.settings.main_heading }}</h2>
    {%- endif -%}
  </div>

  <div class="ht-proof-track">

    <div class="ht-proof-card">
      {%- if section.settings.tag_1 != blank -%}
        <div class="ht-card-tag">{{ section.settings.tag_1 }}</div>
      {%- endif -%}
      <div class="ht-card-stars">
        {%- for i in (1..5) -%}
          <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
        {%- endfor -%}
      </div>
      <div class="ht-card-quote">{{ section.settings.quote_1 }}</div>
      <div class="ht-card-body">{{ section.settings.body_1 }}</div>
      <div class="ht-card-author">
        {{ section.settings.author_1 }}
        <svg class="ht-verified-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm-2 15l-5-5 1.4-1.4 3.6 3.6 7.6-7.6L19 8l-9 9z"/></svg>
      </div>
    </div>

    <div class="ht-proof-card">
      {%- if section.settings.tag_2 != blank -%}
        <div class="ht-card-tag">{{ section.settings.tag_2 }}</div>
      {%- endif -%}
      <div class="ht-card-stars">
        {%- for i in (1..5) -%}
          <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
        {%- endfor -%}
      </div>
      <div class="ht-card-quote">{{ section.settings.quote_2 }}</div>
      <div class="ht-card-body">{{ section.settings.body_2 }}</div>
      <div class="ht-card-author">
        {{ section.settings.author_2 }}
        <svg class="ht-verified-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm-2 15l-5-5 1.4-1.4 3.6 3.6 7.6-7.6L19 8l-9 9z"/></svg>
      </div>
    </div>

    <div class="ht-proof-card">
      {%- if section.settings.tag_3 != blank -%}
        <div class="ht-card-tag">{{ section.settings.tag_3 }}</div>
      {%- endif -%}
      <div class="ht-card-stars">
        {%- for i in (1..5) -%}
          <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
        {%- endfor -%}
      </div>
      <div class="ht-card-quote">{{ section.settings.quote_3 }}</div>
      <div class="ht-card-body">{{ section.settings.body_3 }}</div>
      <div class="ht-card-author">
        {{ section.settings.author_3 }}
        <svg class="ht-verified-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm-2 15l-5-5 1.4-1.4 3.6 3.6 7.6-7.6L19 8l-9 9z"/></svg>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Mini Proof Strip",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Global Rating Average"
    },
    { "type": "range", "id": "global_rating", "label": "Average Rating", "min": 1.0, "max": 5.0, "step": 0.1, "default": 4.8, "info": "This will partially fill the final star to accurately reflect your average." },
    { "type": "checkbox", "id": "show_rating_text", "label": "Show Rating Text (e.g. 4.8 / 5.0)", "default": true },
    { "type": "color", "id": "star_color", "label": "Filled Star Color", "default": "#FFB800" },
    { "type": "color", "id": "empty_star_color", "label": "Empty Star Color", "default": "#e5e5e5" },

    {
      "type": "header",
      "content": "Colors & Layout"
    },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#F8F8F8" },
    { "type": "color", "id": "heading_color", "label": "Main Heading Color", "default": "#0e3a27" },
    { "type": "color", "id": "card_bg_color", "label": "Card Background Color", "default": "#ffffff" },
    { "type": "color", "id": "quote_color", "label": "Review Quote Color", "default": "#0e3a27" },
    { "type": "color", "id": "text_color", "label": "Review Body & Author Color", "default": "#0e3a27" },
    { "type": "color", "id": "tag_bg_color", "label": "Issue Tag Background", "default": "#e8e8e8" },
    { "type": "color", "id": "tag_text_color", "label": "Issue Tag Text", "default": "#0e3a27" },
    { "type": "range", "id": "padding_desktop", "label": "Desktop Top/Bottom Padding", "min": 2, "max": 8, "step": 1, "unit": "rem", "default": 4 },
    { "type": "range", "id": "padding_mobile", "label": "Mobile Top/Bottom Padding", "min": 1, "max": 6, "step": 1, "unit": "rem", "default": 3 },

    {
      "type": "header",
      "content": "Desktop Element Sizing"
    },
    { "type": "range", "id": "heading_size_desktop", "label": "Main Heading Size", "min": 20, "max": 48, "step": 2, "unit": "px", "default": 36 },
    { "type": "range", "id": "quote_size_desktop", "label": "Review Quote Size", "min": 14, "max": 32, "step": 1, "unit": "px", "default": 20 },
    { "type": "range", "id": "text_size_desktop", "label": "Review Body Text Size", "min": 12, "max": 24, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "star_size_desktop", "label": "Card Star Size", "min": 14, "max": 32, "step": 1, "unit": "px", "default": 20 },

    {
      "type": "header",
      "content": "Section Hook"
    },
    { "type": "text", "id": "main_heading", "label": "Main Heading", "default": "Join over 1,500 happy skin barriers." },

    {
      "type": "header",
      "content": "Review 1 (Focus: Dryness)"
    },
    { "type": "text", "id": "tag_1", "label": "Issue Tag", "default": "Dryness" },
    { "type": "text", "id": "quote_1", "label": "Pull Quote", "default": "“Saved my winter skin.”" },
    { "type": "textarea", "id": "body_1", "label": "Review Body", "default": "I get terribly dry, flaky patches on my forehead every winter. Nothing worked until I tried this. It absorbs so fast and my skin feels plump all day." },
    { "type": "text", "id": "author_1", "label": "Author Name", "default": "Sarah M." },

    {
      "type": "header",
      "content": "Review 2 (Focus: Sensitive/Irritation)"
    },
    { "type": "text", "id": "tag_2", "label": "Issue Tag", "default": "Sensitive Skin" },
    { "type": "text", "id": "quote_2", "label": "Pull Quote", "default": "“Finally, zero irritation.”" },
    { "type": "textarea", "id": "body_2", "label": "Review Body", "default": "My skin reacts to absolutely everything. Because this is just one ingredient, it completely calmed down my redness in less than a week." },
    { "type": "text", "id": "author_2", "label": "Author Name", "default": "Jessica T." },

    {
      "type": "header",
      "content": "Review 3 (Focus: Scent/General)"
    },
    { "type": "text", "id": "tag_3", "label": "Issue Tag", "default": "Scent" },
    { "type": "text", "id": "quote_3", "label": "Pull Quote", "default": "“No beef smell at all!”" },
    { "type": "textarea", "id": "body_3", "label": "Review Body", "default": "I was so worried it would smell like a kitchen, but it is completely odorless. It goes on like butter and doesn't leave me feeling greasy." },
    { "type": "text", "id": "author_3", "label": "Author Name", "default": "Emily R." }
  ],
  "presets": [ { "name": "Landing Page - Mini Proof Strip" } ]
}
{% endschema %}