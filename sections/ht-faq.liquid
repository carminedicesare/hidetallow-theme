{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,800&family=Questrial&display=swap');

  .ht-faq-wrapper-{{ section.id }} {
    background-color: {{ section.settings.color_section_bg }};
    padding: {{ section.settings.margin_top }}px 0 {{ section.settings.margin_bottom }}px 0;
    width: 100%;
  }

  #ht-faq-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ht-faq-header {
    text-align: center;
    margin-bottom: {{ section.settings.header_spacing }}px;
  }

  .ht-faq-main-title {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: {{ section.settings.title_size }}px;
    font-weight: 800;
    color: {{ section.settings.color_heading }};
    text-transform: uppercase;
    margin: 0 0 15px 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .ht-faq-main-subtext {
    font-family: 'Questrial', sans-serif;
    font-size: {{ section.settings.subheading_size }}px;
    color: {{ section.settings.color_subheading }};
    margin: 0 auto;
    max-width: 700px;
    line-height: 1.5;
  }

  .ht-faq-container {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.item_gap }}px;
  }

  .ht-faq-item {
    background: {{ section.settings.color_item_bg }};
    border-radius: {{ section.settings.border_radius }}px;
    border: 1px solid {{ section.settings.color_border }};
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .ht-faq-question {
    width: 100%;
    padding: {{ section.settings.padding_y }}px {{ section.settings.padding_x }}px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    background: {{ section.settings.color_question_bg }};
    border: none;
    text-align: left;
    color: {{ section.settings.color_question_text }};
  }

  .ht-faq-question span {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: {{ section.settings.question_size }}px;
    font-weight: 800;
  }

  .ht-faq-icon {
    width: 20px;
    height: 20px;
    color: {{ section.settings.color_question_text }};
    transition: transform 0.4s ease;
  }

  .ht-faq-inner {
    font-family: 'Questrial', sans-serif;
    font-size: {{ section.settings.body_size }}px;
    padding: {{ section.settings.padding_y }}px {{ section.settings.padding_x }}px;
    color: {{ section.settings.color_body_text }};
    line-height: 1.7;
    background: {{ section.settings.color_answer_bg }};
    border-top: 1px solid {{ section.settings.color_border }};
  }

  .ht-faq-answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s ease;
  }

  .ht-faq-item.is-open {
    border-color: {{ section.settings.color_active_border }};
  }

  .ht-faq-item.is-open .ht-faq-answer {
    grid-template-rows: 1fr;
  }

  .ht-faq-item.is-open .ht-faq-icon {
    transform: rotate(180deg);
  }

  .ht-faq-inner-wrapper { overflow: hidden; }

  @media (max-width: 768px) {
    .ht-faq-main-title { font-size: calc({{ section.settings.title_size }}px * 0.75); }
    .ht-faq-question span { font-size: calc({{ section.settings.question_size }}px * 0.9); }
  }
{%- endstyle -%}

<div class="ht-faq-wrapper-{{ section.id }}">
  <div class="ht-faq-section" id="ht-faq-{{ section.id }}">
    
    {%- if section.settings.main_title != blank or section.settings.main_subtext != blank -%}
    <div class="ht-faq-header">
      {% if section.settings.main_title != blank %}
        <h2 class="ht-faq-main-title">{{ section.settings.main_title }}</h2>
      {% endif %}
      {% if section.settings.main_subtext != blank %}
        <p class="ht-faq-main-subtext">{{ section.settings.main_subtext }}</p>
      {% endif %}
    </div>
    {%- endif -%}

    <div class="ht-faq-container">
      {% for block in section.blocks %}
        <div class="ht-faq-item" {{ block.shopify_attributes }}>
          <button class="ht-faq-question" type="button">
            <span>{{ block.settings.question }}</span>
            <span class="ht-faq-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </span>
          </button>
          <div class="ht-faq-answer">
            <div class="ht-faq-inner-wrapper">
              <div class="ht-faq-inner">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const container = document.querySelector('#ht-faq-{{ section.id }}');
    if(!container) return;
    container.addEventListener('click', function(e) {
      const btn = e.target.closest('.ht-faq-question');
      if (!btn) return;
      const item = btn.closest('.ht-faq-item');
      const wasOpen = item.classList.contains('is-open');
      
      container.querySelectorAll('.ht-faq-item').forEach(el => el.classList.remove('is-open'));
      if (!wasOpen) item.classList.add('is-open');
    });
  });
</script>

{% schema %}
{
  "name": "HT FAQ Premium",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    { "type": "text", "id": "main_title", "label": "Main Title", "default": "Common Questions" },
    { "type": "textarea", "id": "main_subtext", "label": "Subtext", "default": "Everything you need to know about Hide Tallow." },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "max_width", "label": "Max Width", "min": 600, "max": 1400, "step": 50, "default": 900, "unit": "px" },
    { "type": "range", "id": "margin_top", "label": "Section Padding Top", "min": 0, "max": 150, "step": 5, "default": 80 },
    { "type": "range", "id": "margin_bottom", "label": "Section Padding Bottom", "min": 0, "max": 150, "step": 5, "default": 80 },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "color_section_bg", "label": "Global Section Background", "default": "#ffffff" },
    { "type": "color", "id": "color_heading", "label": "Header Text Color", "default": "#0E3A27" },
    { "type": "color", "id": "color_subheading", "label": "Subtext Color", "default": "#4A4A4A" },
    { "type": "color", "id": "color_question_bg", "label": "Question Box Background", "default": "#F9FAF8" },
    { "type": "color", "id": "color_question_text", "label": "Question Text Color", "default": "#0E3A27" },
    { "type": "color", "id": "color_answer_bg", "label": "Answer Background", "default": "#FFFFFF" },
    { "type": "color", "id": "color_body_text", "label": "Answer Text Color", "default": "#333333" },
    { "type": "color", "id": "color_border", "label": "Border Color", "default": "#E5E7E2" },
    { "type": "color", "id": "color_active_border", "label": "Active Border Color", "default": "#0E3A27" },
    { "type": "header", "content": "Typography & Spacing" },
    { "type": "range", "id": "title_size", "label": "Main Title Font Size", "min": 20, "max": 80, "default": 42 },
    { "type": "range", "id": "subheading_size", "label": "Main Subtext Font Size", "min": 12, "max": 30, "default": 18 },
    { "type": "range", "id": "header_spacing", "label": "Header Bottom Spacing", "min": 10, "max": 100, "default": 50 },
    { "type": "range", "id": "question_size", "label": "Question Font Size", "min": 14, "max": 30, "default": 20 },
    { "type": "range", "id": "body_size", "label": "Answer Font Size", "min": 12, "max": 24, "default": 16 },
    { "type": "range", "id": "padding_y", "label": "Internal Vertical Padding", "min": 10, "max": 50, "default": 25 },
    { "type": "range", "id": "padding_x", "label": "Internal Horizontal Padding", "min": 10, "max": 50, "default": 30 },
    { "type": "range", "id": "item_gap", "label": "Gap Between Items", "min": 0, "max": 40, "default": 16 },
    { "type": "range", "id": "border_radius", "label": "Border Radius", "min": 0, "max": 30, "default": 12 }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Why use Tallow?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Tallow is skin-identical nourishment.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "HT FAQ Premium",
      "blocks": [
        { 
          "type": "faq_item", 
          "settings": { 
            "question": "Where is Hide Tallow Based?", 
            "answer": "<p>We were proudly founded in 2024 and are currently based in Scottsdale, Arizona.</p>" 
          } 
        },
        { 
          "type": "faq_item", 
          "settings": { 
            "question": "Where are Hide Tallow's Products manufactured?", 
            "answer": "<p>All of our products are proudly manufactured in the USA. We handle everything in small batches, from rendering and purifying to whipping and pouring, to ensure every jar meets our high standards for ancestral skin nutrition.</p>" 
          } 
        },
        { 
          "type": "faq_item", 
          "settings": { 
            "question": "Where does Hide Tallow source their Tallow?", 
            "answer": "<p>We believe the quality of the tallow is only as good as the life of the animal. We meticulously source our suet from trusted regenerative farmers across the United States who prioritize soil health and animal welfare. Currently, our 100% grass-fed and finished tallow is sourced from a small family farm in Delaware, ensuring we use only the highest quality nutrient density available.</p>" 
          } 
        },
        { 
          "type": "faq_item", 
          "settings": { 
            "question": "How long of a shelf life do Hide Tallow products have?", 
            "answer": "<p>Our products are naturally shelf-stable and have a shelf life of 12 months from the date of opening. To maintain maximum nutrient density, we recommend storing your jars in a cool, dry place away from direct sunlight.</p>" 
          } 
        }
      ]
    }
  ]
}
{% endschema %}