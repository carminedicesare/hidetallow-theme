{% comment %}
  HT - FOUNDER MISSION SPLIT SECTION
  - Desktop: 50/50 Split (Image Left / Text Right)
  - Mobile: Stacked (Image Top / Text Bottom)
{% endcomment %}

<div class="ht-mission-section">
  <div class="ht-mission-container">
    
    {% comment %} LEFT COLUMN: IMAGE {% endcomment %}
    <div class="ht-mission-image-col">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'ht-mission-img' }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'ht-mission-placeholder' }}
      {%- endif -%}
    </div>

    {% comment %} RIGHT COLUMN: CONTENT {% endcomment %}
    <div class="ht-mission-content-col">
      <div class="ht-mission-inner">
        
        {%- if section.settings.subheading != blank -%}
          <span class="ht-mission-sub">{{ section.settings.subheading }}</span>
        {%- endif -%}

        <h2 class="ht-mission-title">{{ section.settings.heading }}</h2>
        
        <div class="ht-mission-text">
          {{ section.settings.text }}
        </div>

        {%- if section.settings.btn_label != blank -%}
          <a href="{{ section.settings.btn_link }}" class="ht-mission-btn">
            {{ section.settings.btn_label }}
          </a>
        {%- endif -%}

      </div>
    </div>

  </div>
</div>

<style>
  /* --- VARIABLES --- */
  .ht-mission-section {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    width: 100%;
    overflow: hidden;
  }

  .ht-mission-container {
    display: flex;
    flex-direction: column; /* Mobile First */
    width: 100%;
  }

  /* --- MOBILE STYLES (UNCHANGED - "PERFECT") --- */
  .ht-mission-image-col {
    width: 100%;
    aspect-ratio: 1 / 1; /* Square on mobile */
    position: relative;
    overflow: hidden;
  }

  .ht-mission-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center; 
    display: block;
    transition: transform 0.6s ease;
  }
  
  .ht-mission-image-col:hover .ht-mission-img {
    transform: scale(1.03);
  }

  /* --- CONTENT COLUMN --- */
  .ht-mission-content-col {
    width: 100%;
    padding: 50px 25px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .ht-mission-inner {
    max-width: 480px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ht-mission-sub {
    font-family: "Questrial", sans-serif;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 700;
    opacity: 0.8;
  }

  .ht-mission-title {
    font-family: "Bricolage Grotesque", sans-serif;
    font-size: 32px;
    font-weight: 800;
    line-height: 1.1;
    margin: 0;
    color: inherit;
    text-transform: uppercase;
  }

  .ht-mission-text {
    font-family: "Questrial", sans-serif;
    font-size: 16px;
    line-height: 1.6;
    opacity: 0.9;
  }

  .ht-mission-text p { margin: 0 0 15px 0; }
  .ht-mission-text p:last-child { margin: 0; }

  /* --- BUTTON --- */
  .ht-mission-btn {
    display: inline-block;
    margin-top: 10px;
    padding: 14px 32px;
    font-family: "Questrial", sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid {{ section.settings.text_color }};
    color: {{ section.settings.text_color }};
    background: transparent;
    transition: all 0.3s ease;
    align-self: center;
  }

  .ht-mission-btn:hover {
    background: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
  }

  /* --- DESKTOP STYLES (THE FIX) --- */
  @media (min-width: 990px) {
    .ht-mission-container {
      flex-direction: row; 
      height: auto; 
      align-items: center; /* Center vertically */
    }

    .ht-mission-image-col {
      width: 50%;
      height: auto;
      aspect-ratio: auto;
      
      /* THIS CREATES THE "CONTAINER WITHIN A CONTAINER" LOOK */
      padding: 60px; 
      display: flex;
      justify-content: center;
      align-items: center;
    }

    /* Override the mobile image styles for desktop */
    .ht-mission-image-col .ht-mission-img {
      width: 100%;
      max-width: 450px; /* Cap the width so it never gets huge */
      height: auto;     /* Let height adjust naturally */
      aspect-ratio: 4/5; /* Portrait ratio */
      border-radius: 8px; /* Subtle rounded corners since it floats now */
      box-shadow: 0 10px 30px rgba(0,0,0,0.15); /* Nice shadow to pop it off the bg */
    }

    /* Remove the hover zoom on desktop since it has a border-radius now */
    .ht-mission-image-col:hover .ht-mission-img {
      transform: none;
    }

    .ht-mission-content-col {
      width: 50%;
      padding: 60px;
      text-align: left;
      justify-content: flex-start;
    }

    .ht-mission-inner {
      margin-left: 0;
      margin-right: auto;
      align-items: flex-start;
      max-width: 550px;
    }

    .ht-mission-btn { align-self: flex-start; }

    .ht-mission-title { font-size: 48px; } 
    .ht-mission-text { font-size: 18px; }
  }
</style>
{% schema %}
{
  "name": "HT • Founder Mission",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Founder/Mission Image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Born From Purpose"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We didn't start this to join an industry."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body Text",
      "default": "<p>When my wife was diagnosed with breast cancer, we threw out everything we couldn't trust. Hide Tallow was born from a need to heal, not just a need to sell.</p>"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Read Our Story"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0E3A27"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "HT • Home Page Mission"
    }
  ]
}
{% endschema %}