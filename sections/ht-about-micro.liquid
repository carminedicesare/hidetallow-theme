{% comment %}
HT • About Micro (V5 - Minimalist Mission Version)
{% endcomment %}

<section id="ht-about-{{ section.id }}" class="ht-about-section">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,800&family=Questrial&display=swap');

    #ht-about-{{ section.id }} {
      background-color: {{ section.settings.bg }} !important;
      padding: {{ section.settings.vpad_top }}px {{ section.settings.hpad }}px {{ section.settings.vpad_bottom }}px !important;
      width: 100% !important;
      display: block !important;
    }
    
    #ht-about-{{ section.id }} .outer-wrap {
      max-width: {{ section.settings.maxw }}px !important;
      margin: 0 auto !important;
      text-align: center !important;
    }

    #ht-about-{{ section.id }} .title {
      margin: 0 0 20px !important;
      color: {{ section.settings.heading_color }};
      font-family: 'Bricolage Grotesque', sans-serif !important;
      font-weight: 800;
      line-height: 1.05;
      font-size: {{ section.settings.title_size }}px !important;
      letter-spacing: -0.04em;
    }

    #ht-about-{{ section.id }} .mission-blurb {
      margin: 0 auto 15px !important;
      color: {{ section.settings.sub_color }};
      font-family: 'Questrial', sans-serif !important;
      font-size: {{ section.settings.sub_size }}px !important;
      max-width: {{ section.settings.content_maxw }}px !important; 
      line-height: 1.5;
      font-weight: 600; /* Makes it stand out */
    }

    #ht-about-{{ section.id }} .mission-sub {
      margin: 0 auto {{ section.settings.gap }}px !important;
      color: {{ section.settings.sub_color }};
      font-family: 'Questrial', sans-serif !important;
      font-size: calc({{ section.settings.sub_size }}px * 0.85);
      max-width: {{ section.settings.content_maxw }}px !important; 
      line-height: 1.6;
      opacity: 0.8;
    }

    #ht-about-{{ section.id }} .pillars {
      display: flex;
      flex-wrap: wrap;
      gap: 30px;
      justify-content: center;
      margin-bottom: {{ section.settings.gap }}px !important;
    }

    #ht-about-{{ section.id }} .pillar {
      flex: 0 1 auto;
      min-width: 120px;
    }

    #ht-about-{{ section.id }} .pillar h4 {
      margin: 0 !important;
      color: {{ section.settings.pillar_head_color }};
      font-family: 'Questrial', sans-serif !important;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      border-bottom: 1px solid {{ section.settings.pillar_head_color }};
      padding-bottom: 5px;
      display: inline-block;
    }

    #ht-about-{{ section.id }} .cta {
      display: inline-block !important;
      padding: {{ section.settings.btn_vpad }}px {{ section.settings.btn_hpad }}px !important;
      background: {{ section.settings.accent }} !important;
      color: {{ section.settings.btn_text_color }} !important;
      font-family: 'Questrial', sans-serif !important;
      text-decoration: none !important;
      font-weight: 700 !important;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      border-radius: {{ section.settings.btn_radius }}px !important;
    }
  </style>

  <div class="outer-wrap">
    <h2 class="title">{{ section.settings.title }}</h2>
    
    <p class="mission-blurb">{{ section.settings.mission_blurb }}</p>
    <p class="mission-sub">{{ section.settings.mission_sub }}</p>

    <div class="pillars">
      {% for block in section.blocks %}
        <div class="pillar" {{ block.shopify_attributes }}>
          <h4>{{ block.settings.label }}</h4>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.btn_label != blank %}
      <a class="cta" href="{{ section.settings.btn_link }}">
        {{ section.settings.btn_label }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "HT • Mission Micro",
  "settings": [
    { "type": "header", "content": "Mission Copy" },
    { "type": "text", "id": "title", "label": "Headline", "default": "A standard born from necessity." },
    { "type": "text", "id": "mission_blurb", "label": "Main Blurb", "default": "When my wife was diagnosed with breast cancer, 'clean' wasn't good enough." },
    { "type": "text", "id": "mission_sub", "label": "Secondary Blurb", "default": "We needed absolute purity. Hide Tallow is a husband's promise to never compromise." },
    { "type": "text", "id": "btn_label", "label": "Button Label", "default": "Our Story" },
    { "type": "url", "id": "btn_link", "label": "Button Link" },
    
    { "type": "header", "content": "Sizing & Width" },
    { "type": "range", "id": "maxw", "label": "Section Max Width (px)", "min": 600, "max": 1600, "step": 20, "default": 1000 },
    { "type": "range", "id": "content_maxw", "label": "Text Max Width (px)", "min": 300, "max": 800, "step": 10, "default": 600 },
    { "type": "range", "id": "vpad_top", "label": "Padding Top", "min": 0, "max": 150, "step": 5, "default": 100 },
    { "type": "range", "id": "vpad_bottom", "label": "Padding Bottom", "min": 0, "max": 150, "step": 5, "default": 100 },
    { "type": "range", "id": "hpad", "label": "Side Padding", "min": 10, "max": 100, "step": 5, "default": 20 },
    { "type": "range", "id": "gap", "label": "Gap Before Pillars", "min": 10, "max": 100, "step": 5, "default": 50 },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "title_size", "label": "Headline Size", "min": 24, "max": 100, "step": 2, "default": 52 },
    { "type": "range", "id": "sub_size", "label": "Body Text Size", "min": 14, "max": 30, "step": 1, "default": 20 },

    { "type": "header", "content": "Colors & Style" },
    { "type": "color", "id": "bg", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Headline Color", "default": "#000000" },
    { "type": "color", "id": "sub_color", "label": "Body Color", "default": "#333333" },
    { "type": "color", "id": "pillar_head_color", "label": "Pillar Label Color", "default": "#000000" },
    { "type": "color", "id": "accent", "label": "Button Color", "default": "#0e3a27" },
    { "type": "color", "id": "btn_text_color", "label": "Button Text Color", "default": "#ffffff" },
    { "type": "range", "id": "btn_vpad", "label": "Button Vert Padding", "min": 5, "max": 40, "step": 1, "default": 16 },
    { "type": "range", "id": "btn_hpad", "label": "Button Horiz Padding", "min": 10, "max": 80, "step": 2, "default": 40 },
    { "type": "range", "id": "btn_radius", "label": "Button Roundness", "min": 0, "max": 100, "step": 2, "default": 0 }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar Label",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "label", "label": "Label" }
      ]
    }
  ],
  "presets": [{ "name": "HT • Mission Micro" }]
}
{% endschema %}