{% comment %}
HT • Best Sellers Header (Clean)
- Minimal, premium banner for "Our Best Sellers"
- Tunable colors, sizes, spacing in Theme Editor
{% endcomment %}

<section id="ht-bestsellers-{{ section.id }}" class="ht-bs">
  <div class="wrap">
    {% if section.settings.eyebrow != blank %}
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
    {% endif %}
    <h2 class="title">{{ section.settings.title | escape }}</h2>
    {% if section.settings.sub != blank %}
      <p class="sub">{{ section.settings.sub }}</p>
    {% endif %}
    {% if section.settings.show_divider %}
      <span class="divider" aria-hidden="true"></span>
    {% endif %}
    {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
      <a class="btn" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
    {% endif %}
  </div>

  <style>
    #ht-bestsellers-{{ section.id }}{
      --bg: {{ section.settings.bg }};
      --fg: {{ section.settings.fg }};
      --muted: {{ section.settings.muted }};
      --accent: {{ section.settings.accent }};
      background: var(--bg);
      color: var(--fg);
    }
    #ht-bestsellers-{{ section.id }} .wrap{
      max-width: {{ section.settings.maxw }}; 
      margin: 0 auto;
      padding: {{ section.settings.vpad }} {{ section.settings.hpad }};
      text-align: center;
    }
    #ht-bestsellers-{{ section.id }} .eyebrow{
      font-size: 12px;
      letter-spacing: .08em;
      text-transform: uppercase;
      opacity: .8;
      color: var(--muted);
      margin-bottom: 10px;
    }
    #ht-bestsellers-{{ section.id }} .title{
      margin: 0;
      font-weight: 700;
      letter-spacing: -0.01em;
      font-size: clamp(20px, 2.8vw, {{ section.settings.title_size }});
      line-height: 1.15;
    }
    #ht-bestsellers-{{ section.id }} .sub{
      margin: 10px auto 0;
      max-width: 42ch;
      font-size: clamp(13px, 1.6vw, {{ section.settings.sub_size }});
      line-height: 1.6;
      color: var(--muted);
    }
    #ht-bestsellers-{{ section.id }} .divider{
      display: block;
      width: 72px;
      height: 1px;
      background: var(--accent);
      opacity: .6;
      margin: 18px auto 0;
      border-radius: 999px;
    }
    #ht-bestsellers-{{ section.id }} .btn{
      display: inline-block;
      margin-top: 18px;
      padding: 10px 16px;
      border-radius: 999px;
      background: var(--fg);
      color: var(--bg);
      font-weight: 600;
      font-size: 14px;
      transition: transform .12s ease, opacity .12s ease;
    }
    #ht-bestsellers-{{ section.id }} .btn:hover{ transform: translateY(-1px); opacity: .92; }
  </style>
</section>

{% schema %}
{
  "name": "HT • Best Sellers",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow (optional)", "default": "Most Loved" },
    { "type": "text", "id": "title", "label": "Title", "default": "Our Best Sellers" },
    { "type": "textarea", "id": "sub", "label": "Subheading", "default": "Premium grass-fed tallow without the luxury markup." },

    { "type": "header", "content": "Design" },
    { "type": "color", "id": "bg", "label": "Background", "default": "#0C2D1E" },
    { "type": "color", "id": "fg", "label": "Text", "default": "#F5F3EE" },
    { "type": "color", "id": "muted", "label": "Muted text", "default": "#EDEAE3" },
    { "type": "color", "id": "accent", "label": "Accent line", "default": "#D9D5CC" },

    { "type": "range", "id": "title_size", "min": 18, "max": 42, "step": 1, "unit": "px", "label": "Title max size", "default": 28 },
    { "type": "range", "id": "sub_size", "min": 12, "max": 18, "step": 1, "unit": "px", "label": "Subheading max size", "default": 14 },

    { "type": "header", "content": "Layout" },
    { "type": "text", "id": "maxw", "label": "Max width", "default": "900px" },
    { "type": "text", "id": "vpad", "label": "Vertical padding", "default": "36px" },
    { "type": "text", "id": "hpad", "label": "Horizontal padding", "default": "20px" },

    { "type": "checkbox", "id": "show_divider", "label": "Show thin divider", "default": true },

    { "type": "header", "content": "Optional CTA" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "-" },
    { "type": "url", "id": "cta_link", "label": "Button link" }
  ],
  "presets": [
    { "name": "HT • Best Sellers" }
  ]
}
{% endschema %}
