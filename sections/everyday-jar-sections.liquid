{% comment %}
Sections > everyday-jar-sections.liquid
{% endcomment %}

<section id="ej-banner" class="ej wrap">
  <div class="ej__banner">
    <div class="ej__banner-copy">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="h1">{{ section.settings.headline }}</h2>
      <p class="sub">{{ section.settings.subhead }}</p>
      {% if section.settings.badges != blank %}
        {% assign badges_array = section.settings.badges | split: "|" %}
        <ul class="badges">
          {% for badge in badges_array %}
            <li>{{ badge | strip }}</li>
          {% endfor %}
        </ul>
      {% endif %}
      {% if section.settings.cta_label != blank %}
        <a href="#product-form-{{ product.id }}" class="btn">{{ section.settings.cta_label }}</a>
      {% endif %}
    </div>
    {% if section.settings.hero_1 != blank %}
      <div class="ej__banner-media">
        <img loading="lazy" src="{{ section.settings.hero_1 | image_url: width: 1200 }}" alt="Everyday Jar"/>
      </div>
    {% endif %}
  </div>
</section>

<section id="ej-tiles" class="ej wrap">
  <h3 class="h2">{{ section.settings.tiles_heading }}</h3>
  <div class="tiles">
    {% for block in section.blocks %}
      {% if block.type == 'tile' %}
      <article class="tile">
        {% if block.settings.image != blank %}
          <img loading="lazy" src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}"/>
        {% endif %}
        <h4 class="tile__title">{{ block.settings.title }}</h4>
        <p class="tile__text">{{ block.settings.text }}</p>
      </article>
      {% endif %}
    {% endfor %}
  </div>
</section>

<section id="ej-why-tallow" class="ej wrap">
  <h3 class="h2">{{ section.settings.why_tallow_heading }}</h3>
  {% assign tallow_points = section.settings.why_tallow_points | split: "|" %}
  <ul class="checks">
    {% for li in tallow_points %}
      <li>{{ li | strip }}</li>
    {% endfor %}
  </ul>
</section>

<section id="ej-why-hide" class="ej wrap">
  <h3 class="h2">{{ section.settings.why_hide_heading }}</h3>
  {% assign hide_points = section.settings.why_hide_points | split: "|" %}
  <ul class="icons">
    {% for li in hide_points %}
      <li>{{ li | strip }}</li>
    {% endfor %}
  </ul>
</section>

<section id="ej-reviews" class="ej wrap">
  <h3 class="h2">{{ section.settings.reviews_heading }}</h3>
  <div class="reviews">
    {% for block in section.blocks %}
      {% if block.type == 'review' %}
      <blockquote class="review">
        <div class="stars">★★★★★</div>
        <p class="review__text">“{{ block.settings.text }}”</p>
        <cite class="review__cite">— {{ block.settings.author }}</cite>
      </blockquote>
      {% endif %}
    {% endfor %}
  </div>
</section>

<section id="ej-faq" class="ej wrap">
  <h3 class="h2">{{ section.settings.faq_heading }}</h3>
  <div class="faq">
    {% for block in section.blocks %}
      {% if block.type == 'faq' %}
      <details class="faq__item" {% if forloop.first %}open{% endif %}>
        <summary>{{ block.settings.q }}</summary>
        <div class="faq__a">{{ block.settings.a }}</div>
      </details>
      {% endif %}
    {% endfor %}
  </div>
</section>

<style>
  .wrap{max-width:var(--page-width,1100px);margin:0 auto;padding:clamp(16px,3vw,32px)}
  .h1{font-size:clamp(28px,4.2vw,48px);line-height:1.05;margin:0 0 8px}
  .h2{font-size:clamp(22px,3vw,32px);line-height:1.1;margin:0 0 12px}
  .sub{font-size:1.05rem;opacity:.9}
  .eyebrow{letter-spacing:.08em;text-transform:uppercase;font-size:.8rem;opacity:.7}
  .btn{display:inline-block;margin-top:12px;padding:12px 16px;border-radius:999px;background:#111;color:#fff;text-decoration:none}
  .badges{display:flex;gap:10px;flex-wrap:wrap;margin:12px 0 0;padding:0;list-style:none}
  .badges li{font-size:.85rem;border:1px solid #ddd;border-radius:999px;padding:6px 10px}
  .ej__banner{display:grid;gap:24px;grid-template-columns:1.1fr .9fr;align-items:center}
  .ej__banner-media img{width:100%;height:auto;border-radius:16px}
  .tiles{display:grid;gap:16px;grid-template-columns:repeat(4,minmax(0,1fr))}
  .tile{background:#fafafa;border:1px solid #eee;border-radius:16px;padding:14px}
  .tile img{width:100%;height:auto;border-radius:12px;margin-bottom:8px}
  .tile__title{margin:.2rem 0 .25rem;font-size:1.05rem}
  .tile__text{opacity:.85;font-size:.95rem}
  .checks,.icons{display:grid;gap:8px;grid-template-columns:repeat(2,minmax(0,1fr));list-style:none;padding:0;margin:0}
  .checks li,.icons li{background:#f6f6f6;border:1px solid #eee;border-radius:12px;padding:10px}
  .reviews{display:grid;gap:14px;grid-template-columns:repeat(3,minmax(0,1fr))}
  .review{background:#fff;border:1px solid #eee;border-radius:16px;padding:14px}
  .stars{font-size:1rem;margin-bottom:6px}
  .review__text{font-size:1rem}
  .review__cite{display:block;margin-top:6px;opacity:.8;font-style:normal}
  .faq__item{background:#fff;border:1px solid #eee;border-radius:12px;padding:12px}
  .faq__item summary{cursor:pointer;font-weight:600}
  .faq__a{opacity:.9;margin-top:8px}
  @media (max-width: 900px){
    .ej__banner{grid-template-columns:1fr}
    .tiles{grid-template-columns:1fr 1fr}
    .reviews{grid-template-columns:1fr}
    .checks,.icons{grid-template-columns:1fr}
  }
</style>

{% schema %}
{
  "name": "Everyday Jar",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Buy 5 Jars — Save 20%"},
    {"type":"text","id":"headline","label":"Headline","default":"Skin Care That Works. A Price That Doesn’t Hurt."},
    {"type":"textarea","id":"subhead","label":"Subhead","default":"Whipped from 100% grass-fed tallow and nothing else. A full 2oz glass jar for daily hydration, healing, and glow — just $10."},
    {"type":"text","id":"badges","label":"Badges (separate with |)","default":"Over 5,000 sold|Made in the USA|Free Shipping $50+"},
    {"type":"image_picker","id":"hero_1","label":"Hero image"},
    {"type":"text","id":"cta_label","label":"CTA label","default":"Get the Everyday Jar for $10"},
    {"type":"text","id":"tiles_heading","label":"Tiles heading","default":"Real Life. Real Skin."},
    {"type":"text","id":"why_tallow_heading","label":"Why Tallow? heading","default":"Why Tallow?"},
    {"type":"textarea","id":"why_tallow_points","label":"Why Tallow? points (separate with |)","default":"Bioavailable & skin-mimicking|100% natural — no fillers|Fast-acting relief for dry skin|Safe for all ages"},
    {"type":"text","id":"why_hide_heading","label":"Why Hide Tallow? heading","default":"Why Hide Tallow?"},
    {"type":"textarea","id":"why_hide_points","label":"Why Hide Tallow? points (separate with |)","default":"Always Grass-Fed & Finished|Actually Affordable|Made in the USA|Built by Real People"},
    {"type":"text","id":"reviews_heading","label":"Reviews heading","default":"Real Skin. Real Results."},
    {"type":"text","id":"faq_heading","label":"FAQ heading","default":"Frequently Asked Questions"}
  ],
  "blocks": [
    {
      "type":"tile",
      "name":"Tile",
      "settings":[
        {"type":"image_picker","id":"image","label":"Image"},
        {"type":"text","id":"title","label":"Title","default":"Gentle Daily Moisturizer"},
        {"type":"textarea","id":"text","label":"Text","default":"Hydrates dry skin, smooths fine lines, and won’t clog pores."}
      ]
    },
    {
      "type":"review",
      "name":"Review",
      "settings":[
        {"type":"textarea","id":"text","label":"Review text","default":"Smells amazing. Not greasy, absorbs well, cleared my son’s eczema. A little goes a long way."},
        {"type":"text","id":"author","label":"Author","default":"Courtney, Dec 8, 2024"}
      ]
    },
    {
      "type":"faq",
      "name":"FAQ Item",
      "settings":[
        {"type":"text","id":"q","label":"Question","default":"Is it safe for sensitive skin?"},
        {"type":"textarea","id":"a","label":"Answer","default":"Absolutely — especially the Unscented. No fillers, fragrance, or synthetics. Just real, nourishing ingredients."}
      ]
    }
  ],
  "max_blocks": 40,
  "presets": [
    {
      "name":"Everyday Jar",
      "category":"Product",
      "blocks":[
        {"type":"tile"},{"type":"tile"},{"type":"tile"},{"type":"tile"},
        {"type":"review"},{"type":"review"},{"type":"review"},
        {"type":"faq"},{"type":"faq"},{"type":"faq"}
      ]
    }
  ]
}
{% endschema %}
