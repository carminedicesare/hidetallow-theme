  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "range", "id": "content_width", "min": 800, "max": 1400, "step": 50, "unit": "px", "label": "Content Width", "default": 1100 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 150, "step": 5, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 150, "step": 5, "unit": "px", "label": "Padding Bottom", "default": 80 },
    { "type": "header", "content": "Typography Control" },
    { "type": "text", "id": "title_font", "label": "Heading Font", "default": "Bricolage Grotesque" },
