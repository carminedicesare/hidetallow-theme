    { "type": "color", "id": "icon_text_color", "label": "Description Text Color", "default": "#666666" },
    { "type": "range", "id": "icon_text_size", "min": 10, "max": 24, "step": 1, "unit": "px", "label": "Pillar Label Font Size", "default": 14 },
    { "type": "header", "content": "Copy Defaults" },
    { "type": "text", "id": "title", "label": "Main Title", "default": "Our Commitment to You" },
    { "type": "textarea", "id": "intro_text", "label": "Intro Text", "default": "We believe pure skincare should be accessible to every family. Our mission is to provide clean, honest products at fair prices, while using our growth to support those walking the path we once did." },
