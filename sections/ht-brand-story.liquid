    { "type": "range", "id": "intro_size", "min": 14, "max": 30, "step": 1, "unit": "px", "label": "Intro Size", "default": 18 },
    { "type": "color", "id": "mission_statement_color", "label": "Mission Statement Color", "default": "#0E3A27" },
    { "type": "range", "id": "mission_size", "min": 18, "max": 60, "step": 2, "unit": "px", "label": "Statement Size", "default": 24 },
    { "type": "header", "content": "Cards & Icons" },
    { "type": "color", "id": "pillar_title_color", "label": "Pillar Title Color", "default": "#0E3A27" },
