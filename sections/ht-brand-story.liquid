{%- style -%}
  #HT-Mission--{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    border-top: 1px solid {{ section.settings.border_color }};
  }

  .ht-mission-inner {
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
    padding: 0 20px;
    text-align: center;
  }

  .ht-mission-title {
    font-family: {{ section.settings.title_font }}, sans-serif;
    font-size: {{ section.settings.title_size }}px;
    color: {{ section.settings.title_color }};
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 15px;
    line-height: 1.1;
  }

  .ht-mission-intro {
    font-family: {{ section.settings.body_font }}, sans-serif;
    font-size: {{ section.settings.intro_size }}px;
    color: {{ section.settings.intro_color }};
    line-height: 1.6;
    margin: 0 auto 30px auto;
    max-width: 750px;
  }

  .ht-mission-statement {
    font-family: {{ section.settings.title_font }}, sans-serif;
    font-size: {{ section.settings.mission_size }}px;
    color: {{ section.settings.mission_statement_color }};
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 50px;
    letter-spacing: 0.05em;
  }

  .ht-mission-grid {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: stretch;
    gap: 20px;
    padding-top: {{ section.settings.padding_icons }}px;
  }

  .ht-mission-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 30px 20px;
    background: #ffffff;
    border: 1px solid {{ section.settings.border_color }};
    border-radius: 8px;
    transition: transform 0.3s ease;
  }

  .ht-mission-item:hover {
    transform: translateY(-5px);
  }

  .ht-mission-item svg {
    width: {{ section.settings.icon_width }}px;
    height: {{ section.settings.icon_width }}px;
    margin-bottom: 20px;
    fill: none !important;
    stroke: {{ section.settings.icon_color }};
  }

  .ht-mission-item h4 {
    font-family: {{ section.settings.title_font }}, sans-serif;
    font-size: {{ section.settings.icon_text_size }}px;
    font-weight: 800;
    text-transform: uppercase;
    color: {{ section.settings.pillar_title_color }};
    margin: 0 0 12px 0;
  }

  .ht-mission-item p {
    font-family: {{ section.settings.body_font }}, sans-serif;
    font-size: calc({{ section.settings.icon_text_size }}px * 0.9);
    color: {{ section.settings.icon_text_color }};
    line-height: 1.5;
    margin: 0;
  }

  .ht-dots-container { display: none; }

  @media (max-width: 767px) {
    .ht-mission-grid { 
      overflow-x: auto; 
      scroll-snap-type: x mandatory;
      padding-bottom: 15px;
      -webkit-overflow-scrolling: touch;
      gap: 15px;
      justify-content: flex-start;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .ht-mission-grid::-webkit-scrollbar {
      display: none;
    }
    .ht-mission-item { 
      min-width: 85%; 
      scroll-snap-align: center;
    }
    .ht-dots-container {
      display: flex;
      justify-content: center;
      gap: 12px;
      margin-top: 20px;
    }
    .ht-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      border: 1px solid {{ section.settings.dot_active_color }};
      background: transparent;
      padding: 0;
      cursor: pointer;
      transition: background 0.3s ease;
    }
    .ht-dot.active { 
      background: {{ section.settings.dot_active_color }}; 
    }
  }
{%- endstyle -%}

<div id="HT-Mission--{{ section.id }}">
  <div class="ht-mission-inner">
    
    <h2 class="ht-mission-title">{{ section.settings.title }}</h2>
    <div class="ht-mission-intro">{{ section.settings.intro_text }}</div>
    <h3 class="ht-mission-statement">{{ section.settings.mission_statement }}</h3>

    <div class="ht-mission-grid" id="MissionGrid-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="ht-mission-item" {{ block.shopify_attributes }}>
          {%- case block.settings.icon_svg -%}
            {%- when 'check' -%}
              <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {%- when 'heart' -%}
              <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            {%- when 'usa' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 5h18v14H3z" />
                <path d="M3 5h9v7H3z" />
                <path d="M12 8h9M12 11h9M3 15h18M3 18h18" />
              </svg>
            {%- when 'piggy' -%}
              <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
