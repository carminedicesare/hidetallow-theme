 6.19245 17.9802 6.29136L15.6077 6.96922C15.5673 6.98074 15.5472 6.9865 15.5267 6.99054C15.5085 6.99414 15.4901 6.99671 15.4716 6.99826C15.4508 7 15.4297 7 15.3874 7H10.9999M4.99993 13H4C2.89543 13 2 12.1046 2 11C2 10.2597 2.4022 9.61337 3 9.26756M10.9999 7H14.9646C14.9879 6.8367 15 6.66976 15 6.5C15 4.567 13.433 3 11.5 3C9.567 3 8 4.567 8 6.5C8 6.9172 8.073 7.31736 8.20692 7.68839C9.04114 7.24881 9.99144 7 10.9999 7Z" />
              </svg>
          {%- endcase -%}
          <h4>{{ block.settings.label }}</h4>
          <p>{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>

    <div class="ht-dots-container">
      {%- for block in section.blocks -%}
        <button class="ht-dot {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
      {%- endfor -%}
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const grid = document.getElementById('MissionGrid-{{ section.id }}');
    const dots = document.querySelectorAll('#HT-Mission--{{ section.id }} .ht-dot');

    if (grid && dots.length > 0) {
      grid.addEventListener('scroll', () => {
        const itemWidth = grid.querySelector('.ht-mission-item').offsetWidth + 15;
        const index = Math.round(grid.scrollLeft / itemWidth);
        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === index);
        });
      });

      dots.forEach(dot => {
        dot.addEventListener('click', () => {
          const index = dot.getAttribute('data-index');
          const itemWidth = grid.querySelector('.ht-mission-item').offsetWidth + 15;
          grid.scrollTo({
            left: itemWidth * index,
            behavior: 'smooth'
          });
        });
      });
    }
  });
</script>

{% schema %}
{
