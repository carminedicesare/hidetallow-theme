<style>
  .ht-benefit-grid-section-{{ section.id }} {
    /* Color Variables */
    --bg-color: {{ section.settings.bg_color }};
    --heading-color: {{ section.settings.heading_color }};
    --text-color: {{ section.settings.text_color }};
    --icon-color: {{ section.settings.icon_color }};

    /* Spacing Variables */
    --padding-mobile: {{ section.settings.padding_mobile }}rem 1.5rem;
    --padding-desktop: {{ section.settings.padding_desktop }}rem 2rem;

    /* Sizing Variables mapped to Schema */
    --title-size-mobile: {{ section.settings.mobile_title_size }}px;
    --title-size-desktop: {{ section.settings.desktop_title_size }}px;
    
    --icon-size-mobile: {{ section.settings.mobile_icon_size }}px;
    --icon-size-desktop: {{ section.settings.desktop_icon_size }}px;
    
    --benefit-title-mobile: {{ section.settings.mobile_benefit_title_size }}px;
    --benefit-title-desktop: {{ section.settings.desktop_benefit_title_size }}px;
    
    --benefit-desc-mobile: {{ section.settings.mobile_benefit_desc_size }}px;
    --benefit-desc-desktop: {{ section.settings.desktop_benefit_desc_size }}px;

    background-color: var(--bg-color);
    color: var(--text-color);
    padding: var(--padding-mobile);
  }

  .ht-benefit-grid-section-{{ section.id }} .ht-benefit-container {
    max-width: 1200px; /* Bumped from 1100px to accommodate larger elements */
    margin: 0 auto;
  }

  .ht-benefit-grid-section-{{ section.id }} .ht-benefit-h2 {
    text-align: center;
    font-size: var(--title-size-mobile);
    font-weight: 700;
    margin-bottom: 3rem;
    color: var(--heading-color);
    line-height: 1.2;
  }

  /* --- Grid Logic --- */
  .ht-benefit-grid-section-{{ section.id }} .ht-benefit-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem 1.5rem;
  }

  .ht-benefit-grid-section-{{ section.id }} .ht-benefit-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .ht-benefit-grid-section-{{ section.id }} .ht-benefit-icon {
    width: var(--icon-size-mobile);
    height: var(--icon-size-mobile);
    margin-bottom: 1.2rem;
    color: var(--icon-color);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .ht-benefit-grid-section-{{ section.id }} .ht-benefit-icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
  }

  .ht-benefit-grid-section-{{ section.id }} .ht-benefit-title {
    font-size: var(--benefit-title-mobile);
    font-weight: 700;
    margin-bottom: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.2;
    color: var(--heading-color);
  }

  .ht-benefit-grid-section-{{ section.id }} .ht-benefit-desc {
    font-size: var(--benefit-desc-mobile);
    line-height: 1.5;
    opacity: 0.85;
    margin: 0;
    max-width: 320px; /* Widened slightly so larger text doesn't break into too many lines */
  }

  /* --- Desktop Scaling --- */
  @media screen and (min-width: 750px) {
    .ht-benefit-grid-section-{{ section.id }} {
      padding: var(--padding-desktop);
    }

    .ht-benefit-grid-section-{{ section.id }} .ht-benefit-h2 {
      font-size: var(--title-size-desktop);
      margin-bottom: 5rem;
    }

    .ht-benefit-grid-section-{{ section.id }} .ht-benefit-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 5rem 2.5rem;
    }

    .ht-benefit-grid-section-{{ section.id }} .ht-benefit-icon {
      width: var(--icon-size-desktop);
      height: var(--icon-size-desktop);
      margin-bottom: 1.5rem;
    }

    .ht-benefit-grid-section-{{ section.id }} .ht-benefit-title {
      font-size: var(--benefit-title-desktop);
    }

    .ht-benefit-grid-section-{{ section.id }} .ht-benefit-desc {
      font-size: var(--benefit-desc-desktop);
    }

    /* Pro Touch: Subtle icon bounce on hover */
    .ht-benefit-grid-section-{{ section.id }} .ht-benefit-item:hover .ht-benefit-icon {
      transform: translateY(-5px) scale(1.05);
    }
  }
</style>

<section class="ht-benefit-grid-section-{{ section.id }}">
  <div class="ht-benefit-container">
    
    {% if section.settings.heading != blank %}
      <h2 class="ht-benefit-h2">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="ht-benefit-grid">
      {% for block in section.blocks %}
        <div class="ht-benefit-item" {{ block.shopify_attributes }}>
          <div class="ht-benefit-icon">
            {% if block.settings.custom_svg != blank %}
              {{ block.settings.custom_svg }}
            {% else %}
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><path d="M12 8v8M8 12h8"></path></svg>
            {% endif %}
          </div>
          
          {% if block.settings.title != blank %}
            <h3 class="ht-benefit-title">{{ block.settings.title }}</h3>
          {% endif %}
          
          {% if block.settings.text != blank %}
            <p class="ht-benefit-desc">{{ block.settings.text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Benefit Grid (Modular)",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    { 
      "type": "header", 
      "content": "Colors & Layout" 
    },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading/Title Color", "default": "#0e3a27" },
    { "type": "color", "id": "text_color", "label": "Description Text Color", "default": "#0e3a27" },
    { "type": "color", "id": "icon_color", "label": "Icon Color", "default": "#0e3a27" },
    { "type": "range", "id": "padding_desktop", "label": "Desktop Padding", "min": 2, "max": 10, "step": 1, "unit": "rem", "default": 5 },
    { "type": "range", "id": "padding_mobile", "label": "Mobile Padding", "min": 2, "max": 6, "step": 1, "unit": "rem", "default": 4 },
    
    { 
      "type": "header", 
      "content": "Section Heading" 
    },
    { "type": "text", "id": "heading", "label": "Main Section Heading", "default": "Made for your toughest skin days." },
    { "type": "range", "id": "desktop_title_size", "label": "Desktop Title Size", "min": 24, "max": 60, "step": 1, "unit": "px", "default": 42 },
    { "type": "range", "id": "mobile_title_size", "label": "Mobile Title Size", "min": 20, "max": 48, "step": 1, "unit": "px", "default": 30 },

    { 
      "type": "header", 
      "content": "Grid Element Sizing (Desktop)" 
    },
    { "type": "range", "id": "desktop_icon_size", "label": "Desktop Icon Size", "min": 24, "max": 100, "step": 2, "unit": "px", "default": 48 },
    { "type": "range", "id": "desktop_benefit_title_size", "label": "Desktop Benefit Title", "min": 14, "max": 36, "step": 1, "unit": "px", "default": 18 },
    { "type": "range", "id": "desktop_benefit_desc_size", "label": "Desktop Benefit Description", "min": 12, "max": 24, "step": 1, "unit": "px", "default": 16 },

    { 
      "type": "header", 
      "content": "Grid Element Sizing (Mobile)" 
    },
    { "type": "range", "id": "mobile_icon_size", "label": "Mobile Icon Size", "min": 20, "max": 60, "step": 1, "unit": "px", "default": 32 },
    { "type": "range", "id": "mobile_benefit_title_size", "label": "Mobile Benefit Title", "min": 12, "max": 28, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "mobile_benefit_desc_size", "label": "Mobile Benefit Description", "min": 10, "max": 20, "step": 1, "unit": "px", "default": 14 }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "html", "id": "custom_svg", "label": "Custom SVG Icon Code" },
        { "type": "text", "id": "title", "label": "Benefit Title", "default": "Benefit Title" },
        { "type": "textarea", "id": "text", "label": "Benefit Description", "default": "Short, punchy description of how the product helps this specific issue." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Landing Page - Benefit Grid",
      "blocks": [
        { "type": "benefit", "settings": { "title": "Dryness + Flaking", "text": "Deeply hydrates to eliminate dry patches and winter flaking." } },
        { "type": "benefit", "settings": { "title": "Redness + Irritation", "text": "Naturally calms inflammation and reactive flare-ups." } },
        { "type": "benefit", "settings": { "title": "Barrier Support", "text": "Strengthens your skin’s defense against environmental stressors." } }
      ]
    }
  ]
}
{% endschema %}