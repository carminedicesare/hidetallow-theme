<style>
  .ht-tallow-edu {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.padding_mobile }}rem 1.5rem;
  }

  .ht-edu-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* --- BULLETPROOF IMAGE WRAPPER --- */
  .ht-edu-image-wrapper {
    width: 100%;
    display: flex;
    justify-content: center; /* Keeps the shrunken image centered */
    align-items: center;
  }

  .ht-edu-image {
    /* The Squeezer: allows you to shrink the natural image */
    width: {{ section.settings.image_width }}%;
    max-width: 100%;
    height: auto !important; /* Forces the image to respect its natural shape */
    object-fit: contain; /* Guarantees no cropping */
    border-radius: {{ section.settings.image_radius }}px; 
    display: block;
  }

  @media screen and (max-width: 749px) {
    .ht-hide-mobile-img {
      display: none !important;
    }
  }

  .ht-edu-text-wrapper {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ht-edu-h2 {
    font-size: {{ section.settings.mobile_title_size }}px;
    text-align: {{ section.settings.title_alignment }};
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 1.5rem;
    color: {{ section.settings.heading_color }};
  }

  .ht-edu-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
  }

  .ht-edu-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 1rem;
    font-size: {{ section.settings.mobile_bullet_size }}px;
    line-height: 1.4;
  }

  .ht-edu-check {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: {{ section.settings.check_color }};
    margin-top: 2px;
  }

  .ht-edu-closer {
    font-weight: 700;
    font-size: {{ section.settings.mobile_closer_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: {{ section.settings.closer_color }};
    padding-top: 1rem;
    border-top: 1px solid rgba(0,0,0,0.1);
    margin-top: 0.5rem;
    text-align: {{ section.settings.closer_alignment }};
  }

  @media screen and (min-width: 750px) {
    .ht-tallow-edu { padding: {{ section.settings.padding_desktop }}rem 2rem; }
    .ht-edu-container { flex-direction: row; align-items: center; gap: 4rem; }
    .ht-edu-image-wrapper { width: 50%; }
    .ht-edu-text-wrapper { width: 50%; padding: 2rem 0; }
    .ht-edu-h2 { font-size: {{ section.settings.desktop_title_size }}px; }
    .ht-edu-item { font-size: {{ section.settings.desktop_bullet_size }}px; }
    .ht-edu-check { width: 24px; height: 24px; }
    .ht-edu-closer { font-size: {{ section.settings.desktop_closer_size }}px; }
  }
</style>

<section class="ht-tallow-edu">
  <div class="ht-edu-container">
    
    <div class="ht-edu-image-wrapper {% if section.settings.hide_on_mobile %}ht-hide-mobile-img{% endif %}">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 1000 }}" 
             class="ht-edu-image" 
             alt="{{ section.settings.image.alt | escape }}"
             loading="lazy">
      {%- else -%}
        <div style="width: 100%; padding: 40px; background: #e0e0e0; display: flex; align-items: center; justify-content: center;">
          <span style="opacity: 0.5;">Upload an image here</span>
        </div>
      {%- endif -%}
    </div>

    <div class="ht-edu-text-wrapper">
      {%- if section.settings.heading != blank -%}
        <h2 class="ht-edu-h2">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <ul class="ht-edu-list">
        {%- if section.settings.bullet_1 != blank -%}
          <li class="ht-edu-item">
            <svg class="ht-edu-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            <span>{{ section.settings.bullet_1 }}</span>
          </li>
        {%- endif -%}
        {%- if section.settings.bullet_2 != blank -%}
          <li class="ht-edu-item">
            <svg class="ht-edu-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            <span>{{ section.settings.bullet_2 }}</span>
          </li>
        {%- endif -%}
        {%- if section.settings.bullet_3 != blank -%}
          <li class="ht-edu-item">
            <svg class="ht-edu-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            <span>{{ section.settings.bullet_3 }}</span>
          </li>
        {%- endif -%}
      </ul>

      {%- if section.settings.closer != blank -%}
        <div class="ht-edu-closer">{{ section.settings.closer }}</div>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Landing Page - Why Tallow",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "Image Styling" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "range", "id": "image_width", "label": "Image Size (Squeezer)", "min": 30, "max": 100, "step": 5, "unit": "%", "default": 100, "info": "Slide left to shrink the photo if it looks too large." },
    { "type": "range", "id": "image_radius", "label": "Image Roundness", "min": 0, "max": 40, "step": 2, "unit": "px", "default": 12 },
    { "type": "checkbox", "id": "hide_on_mobile", "label": "Hide image on mobile", "default": false },
    
    { "type": "header", "content": "Colors & Spacing" },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#0e3a27" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#333333" },
    { "type": "color", "id": "check_color", "label": "Checkmark Color", "default": "#4CAF50" },
    { "type": "color", "id": "closer_color", "label": "Closer Text Color", "default": "#0e3a27" },
    { "type": "range", "id": "padding_desktop", "label": "Desktop Padding", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "range", "id": "padding_mobile", "label": "Mobile Padding", "min": 1, "max": 6, "step": 1, "default": 3 },
    
    { "type": "header", "content": "Typography" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why tallow works so well on human skin." },
    { "type": "select", "id": "title_alignment", "label": "Title Alignment", "options": [{ "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }], "default": "left" },
    { "type": "range", "id": "desktop_title_size", "label": "Desktop Title Size", "min": 24, "max": 60, "step": 1, "default": 42 },
    { "type": "range", "id": "mobile_title_size", "label": "Mobile Title Size", "min": 20, "max": 48, "step": 1, "default": 32 },
    { "type": "range", "id": "desktop_bullet_size", "label": "Desktop Bullet Size", "min": 12, "max": 24, "step": 1, "default": 17 },
    { "type": "range", "id": "mobile_bullet_size", "label": "Mobile Bullet Size", "min": 12, "max": 20, "step": 1, "default": 15 },
    { "type": "select", "id": "closer_alignment", "label": "Closer Alignment", "options": [{ "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }], "default": "left" },
    { "type": "range", "id": "desktop_closer_size", "label": "Desktop Closer Size", "min": 12, "max": 24, "step": 1, "default": 18 },
    { "type": "range", "id": "mobile_closer_size", "label": "Mobile Closer Size", "min": 8, "max": 20, "step": 1, "default": 14 },
    
    { "type": "header", "content": "Copy" },
    { "type": "textarea", "id": "bullet_1", "label": "Bullet 1" },
    { "type": "textarea", "id": "bullet_2", "label": "Bullet 2" },
    { "type": "textarea", "id": "bullet_3", "label": "Bullet 3" },
    { "type": "text", "id": "closer", "label": "The Closer Line" }
  ],
  "presets": [ { "name": "Landing Page - Why Tallow Works" } ]
}
{% endschema %}