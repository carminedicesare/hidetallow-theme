{% style %}
  .mission-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
  }
  
  .mission-container-{{ section.id }} {
    max-width: 100%; 
    margin: 0;
    padding: 0 5%; 
  }

  /* --- DESKTOP SIZES --- */
  @media (min-width: 769px) {
    .mission-{{ section.id }} .mission-intro {
      font-size: {{ section.settings.intro_size_desktop }}px;
    }
    .mission-{{ section.id }} h2 {
      font-size: {{ section.settings.headline_size_desktop }}px;
    }
    .mission-{{ section.id }} .mission-body {
      font-size: {{ section.settings.body_size_desktop }}px;
    }
    /* Editable Footer Desktop Size */
    .mission-{{ section.id }} .mission-footer {
      font-size: {{ section.settings.footer_size_desktop }}px;
    }

    .mission-content-wrapper-{{ section.id }} {
      display: flex;
      align-items: flex-start; 
      justify-content: space-between;
      gap: 40px; 
    }
    .mission-text-side { flex: 0 0 65%; text-align: left; }
    .mission-media-side { flex: 1; max-width: 550px; margin-left: auto; }
  }

  /* --- MOBILE SIZES --- */
  @media (max-width: 768px) {
    .mission-{{ section.id }} .mission-intro {
      font-size: {{ section.settings.intro_size_mobile }}px;
    }
    .mission-{{ section.id }} h2 {
      font-size: {{ section.settings.headline_size_mobile }}px;
    }
    .mission-{{ section.id }} .mission-body {
      font-size: {{ section.settings.body_size_mobile }}px;
    }
    /* Editable Footer Mobile Size */
    .mission-{{ section.id }} .mission-footer {
      font-size: {{ section.settings.footer_size_mobile }}px;
    }
    .mission-container-{{ section.id }} { padding: 0 20px; }
    .mission-media-side { margin-top: 30px; width: 100%; }
  }

  /* --- GENERAL STYLING --- */
  .mission-{{ section.id }} .mission-intro {
    line-height: 1.4;
    color: {{ section.settings.text_color }};
    margin-bottom: 15px;
  }

  .mission-{{ section.id }} .mission-body {
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    margin-bottom: 25px;
  }

  .mission-{{ section.id }} .accent-bar {
    width: {{ section.settings.bar_width }}px;
    background-color: {{ section.settings.accent_color }};
    margin-right: 25px;
    flex-shrink: 0;
  }
  
  .mission-{{ section.id }} .headline-wrapper { 
    display: flex; 
    margin: 25px 0; 
  }

  .mission-{{ section.id }} h2 {
    font-weight: 800; 
    line-height: 1.1; 
    margin: 0;
    color: {{ section.settings.text_color }};
  }

  .mission-{{ section.id }} .mission-footer {
    color: {{ section.settings.text_color }};
  }

  /* Slider Logic */
  .media-slider-{{ section.id }} {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    gap: 0px;
    border-radius: 12px;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .media-slider-{{ section.id }}::-webkit-scrollbar { display: none; }
  
  .media-item-{{ section.id }} {
    flex: 0 0 100%;
    scroll-snap-align: start;
    aspect-ratio: 1 / 1;
  }
  .media-item-{{ section.id }} img, .media-item-{{ section.id }} video {
    width: 100%; height: 100%; object-fit: cover; border-radius: 12px;
  }

  .slider-dots-{{ section.id }} {
    display: flex; justify-content: center; gap: 12px; margin-top: 20px;
  }
  .dot-{{ section.id }} {
    width: 10px; height: 10px; border-radius: 50%;
    border: 1px solid {{ section.settings.text_color }};
    background: transparent; transition: background 0.3s ease; cursor: pointer; padding: 0;
  }
  .dot-{{ section.id }}.active {
    background: {{ section.settings.accent_color }};
    border-color: {{ section.settings.accent_color }};
  }
{% endstyle %}

<section class="mission-{{ section.id }}">
  <div class="mission-container-{{ section.id }}">
    <div class="mission-content-wrapper-{{ section.id }}">
      
      <div class="mission-text-side">
        {%- if section.settings.intro_text != blank -%}
          <p class="mission-intro">{{ section.settings.intro_text }}</p>
        {%- endif -%}

        <div class="headline-wrapper">
          <div class="accent-bar"></div>
          <h2>{{ section.settings.headline_text }}</h2>
        </div>

        {%- if section.settings.body_text != blank -%}
          <div class="mission-body">
            {{ section.settings.body_text }}
          </div>
        {%- endif -%}

        {%- if section.settings.footer_text != blank -%}
          <p class="mission-footer"><strong>{{ section.settings.footer_text }}</strong></p>
        {%- endif -%}
      </div>

      <div class="mission-media-side">
        <div class="media-slider-{{ section.id }}" id="Slider-{{ section.id }}">
          {% for block in section.blocks %}
            <div class="media-item-{{ section.id }}" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
              {% if block.type == 'image' %}
                {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
              {% elsif block.type == 'video' %}
                {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: true }}
              {% endif %}
            </div>
          {% endfor %}
        </div>

        {% if section.blocks.size > 1 %}
          <div class="slider-dots-{{ section.id }}">
            {% for block in section.blocks %}
              <button class="dot-{{ section.id }}{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const slider = document.getElementById('Slider-{{ section.id }}');
    const dots = document.querySelectorAll('.dot-{{ section.id }}');
    if (slider && dots.length > 0) {
      slider.addEventListener('scroll', () => {
        const index = Math.round(slider.scrollLeft / slider.offsetWidth);
        dots.forEach((dot, i) => { dot.classList.toggle('active', i === index); });
      });
      dots.forEach(dot => {
        dot.addEventListener('click', () => {
          const index = dot.getAttribute('data-index');
          slider.scrollTo({ left: slider.offsetWidth * index, behavior: 'smooth' });
        });
      });
    }
  });
</script>

{% schema %}
{
  "name": "Mission w/ Active Slider",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#000000" },
    { "type": "color", "id": "accent_color", "label": "Accent Bar / Active Dot", "default": "#e67e22" },
    { "type": "header", "content": "Desktop Text Sizes" },
    { "type": "range", "id": "headline_size_desktop", "label": "Headline Size (Desktop)", "min": 20, "max": 100, "step": 2, "default": 54 },
    { "type": "range", "id": "intro_size_desktop", "label": "Intro Size (Desktop)", "min": 12, "max": 40, "step": 1, "default": 18 },
    { "type": "range", "id": "body_size_desktop", "label": "Body Size (Desktop)", "min": 12, "max": 40, "step": 1, "default": 20 },
    { "type": "range", "id": "footer_size_desktop", "label": "Footer Size (Desktop)", "min": 12, "max": 40, "step": 1, "default": 20 },
    { "type": "header", "content": "Mobile Text Sizes" },
    { "type": "range", "id": "headline_size_mobile", "label": "Headline Size (Mobile)", "min": 20, "max": 60, "step": 1, "default": 32 },
    { "type": "range", "id": "intro_size_mobile", "label": "Intro Size (Mobile)", "min": 10, "max": 30, "step": 1, "default": 16 },
    { "type": "range", "id": "body_size_mobile", "label": "Body Size (Mobile)", "min": 10, "max": 30, "step": 1, "default": 16 },
    { "type": "range", "id": "footer_size_mobile", "label": "Footer Size (Mobile)", "min": 10, "max": 30, "step": 1, "default": 16 },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "bar_width", "label": "Accent Bar Width", "min": 1, "max": 15, "default": 8 },
    { "type": "range", "id": "padding_top", "label": "Top Padding", "min": 0, "max": 150, "step": 5, "default": 100 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 0, "max": 150, "step": 5, "default": 100 },
    { "type": "header", "content": "Content" },
    { "type": "textarea", "id": "intro_text", "label": "Intro Text", "default": "Hide didn't start as a business — it started at home." },
    { "type": "textarea", "id": "headline_text", "label": "Headline Text", "default": "When a breast cancer diagnosis hit our family..." },
    { "type": "richtext", "id": "body_text", "label": "Body Text", "default": "<p>We source better tallow and keep it truly simple.</p>" },
    { "type": "text", "id": "footer_text", "label": "Footer Bold Text", "default": "From our family to yours" }
  ],
  "blocks": [
    { "type": "image", "name": "Image", "settings": [{ "type": "image_picker", "id": "image", "label": "Image" }] },
    { "type": "video", "name": "Video", "settings": [{ "type": "video", "id": "video", "label": "Video" }] }
  ],
  "presets": [{ "name": "Mission w/ Active Slider" }]
}
{% endschema %}