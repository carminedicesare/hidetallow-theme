{% comment %}
  HT Final CTA - JOIN THE FAMILY
  - Large product/lifestyle image
  - Centered text block with CTA button
  - Full control over typography and spacing
{% endcomment %}

{%- style -%}
  #HT-CTA--{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .ht-cta-inner {
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
    padding: 0 20px;
    text-align: center;
  }

  .ht-cta-image-wrapper {
    width: 100%;
    margin-bottom: {{ section.settings.margin_image }}px;
    border-radius: {{ section.settings.image_radius }}px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .ht-cta-image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ht-cta-sub {
    font-family: {{ section.settings.body_font }}, sans-serif;
    font-size: {{ section.settings.sub_size }}px;
    color: {{ section.settings.sub_color }};
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 10px;
    display: block;
  }

  .ht-cta-title {
    font-family: {{ section.settings.title_font }}, sans-serif;
    font-size: {{ section.settings.title_size }}px;
    color: {{ section.settings.title_color }};
    font-weight: 800;
    margin-bottom: {{ section.settings.margin_text }}px;
    line-height: 1.2;
  }

  .ht-cta-desc {
    font-family: {{ section.settings.body_font }}, sans-serif;
    font-size: {{ section.settings.desc_size }}px;
    color: {{ section.settings.desc_color }};
    line-height: 1.6;
    max-width: 700px;
    margin: 0 auto {{ section.settings.margin_button }}px;
  }

  .ht-cta-btn {
    display: inline-block;
    background-color: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text_color }};
    padding: {{ section.settings.btn_padding_v }}px {{ section.settings.btn_padding_h }}px;
    font-family: {{ section.settings.title_font }}, sans-serif;
    font-weight: 800;
    text-decoration: none;
    text-transform: uppercase;
    border-radius: {{ section.settings.btn_radius }}px;
    font-size: {{ section.settings.btn_font_size }}px;
    transition: opacity 0.3s;
  }

  .ht-cta-btn:hover {
    opacity: 0.9;
  }

  @media (max-width: 767px) {
    .ht-cta-title { font-size: {{ section.settings.title_size | times: 0.8 }}px; }
    .ht-cta-desc { font-size: {{ section.settings.desc_size | times: 0.9 }}px; }
  }
{%- endstyle -%}

<div id="HT-CTA--{{ section.id }}">
  <div class="ht-cta-inner">
    
    <span class="ht-cta-sub">{{ section.settings.subtext }}</span>
    <h2 class="ht-cta-title">{{ section.settings.title }}</h2>
    
    <div class="ht-cta-desc">
      {{ section.settings.description }}
    </div>

    {%- if section.settings.btn_link != blank -%}
      <div style="margin-bottom: {{ section.settings.margin_image }}px;">
        <a href="{{ section.settings.btn_link }}" class="ht-cta-btn">
          {{ section.settings.btn_label }}
        </a>
      </div>
    {%- endif -%}

    {%- if section.settings.main_image != blank -%}
      <div class="ht-cta-image-wrapper">
        <img src="{{ section.settings.main_image | image_url: width: 1400 }}" alt="{{ section.settings.title }}" loading="lazy">
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "HT Final CTA",
  "settings": [
    { "type": "header", "content": "Section Layout" },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#f9f9f9" },
    { "type": "range", "id": "content_width", "min": 600, "max": 1200, "step": 50, "unit": "px", "label": "Max Width", "default": 850 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 150, "step": 5, "unit": "px", "label": "Padding Top", "default": 60 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 150, "step": 5, "unit": "px", "label": "Padding Bottom", "default": 80 },

    { "type": "header", "content": "Image Settings" },
    { "type": "image_picker", "id": "main_image", "label": "Top Image" },
    { "type": "range", "id": "image_radius", "min": 0, "max": 40, "step": 2, "unit": "px", "label": "Corner Radius", "default": 12 },
    { "type": "range", "id": "margin_image", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Image Bottom Margin", "default": 40 },

    { "type": "header", "content": "Typography Settings" },
    { "type": "text", "id": "title_font", "label": "Heading Font Name", "default": "Bricolage Grotesque" },
    { "type": "text", "id": "body_font", "label": "Body Font Name", "default": "Questrial" },
    { "type": "color", "id": "title_color", "label": "Title Color", "default": "#111111" },
    { "type": "range", "id": "title_size", "min": 24, "max": 70, "step": 2, "unit": "px", "label": "Title Size", "default": 42 },
    { "type": "color", "id": "sub_color", "label": "Subtext Color", "default": "#444444" },
    { "type": "range", "id": "sub_size", "min": 10, "max": 20, "step": 1, "unit": "px", "label": "Subtext Size", "default": 13 },
    { "type": "color", "id": "desc_color", "label": "Description Color", "default": "#333333" },
    { "type": "range", "id": "desc_size", "min": 14, "max": 24, "step": 1, "unit": "px", "label": "Description Size", "default": 18 },

    { "type": "header", "content": "Button Settings" },
    { "type": "text", "id": "btn_label", "label": "Button Label", "default": "Shop Hide Tallow" },
    { "type": "url", "id": "btn_link", "label": "Button Link" },
    { "type": "color", "id": "btn_bg", "label": "Button Background", "default": "#111111" },
    { "type": "color", "id": "btn_text_color", "label": "Button Text", "default": "#ffffff" },
    { "type": "range", "id": "btn_radius", "min": 0, "max": 50, "step": 2, "unit": "px", "label": "Button Corner Radius", "default": 8 },
    { "type": "range", "id": "btn_font_size", "min": 12, "max": 24, "step": 1, "unit": "px", "label": "Button Font Size", "default": 14 },
    { "type": "range", "id": "btn_padding_v", "min": 10, "max": 30, "step": 2, "unit": "px", "label": "Button Vertical Padding", "default": 18 },
    { "type": "range", "id": "btn_padding_h", "min": 20, "max": 80, "step": 5, "unit": "px", "label": "Button Horizontal Padding", "default": 60 },

    { "type": "header", "content": "Content Spacing" },
    { "type": "range", "id": "margin_text", "min": 0, "max": 60, "step": 5, "unit": "px", "label": "Title Bottom Margin", "default": 20 },
    { "type": "range", "id": "margin_button", "min": 0, "max": 80, "step": 5, "unit": "px", "label": "Description Bottom Margin", "default": 40 },

    { "type": "header", "content": "Default Text" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "ENJOY THE REAL YOU" },
    { "type": "text", "id": "title", "label": "Title", "default": "Join The Hide Family" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Experience ancestral skincare made with the perfect blend of grass-fed tallow and organic botanicals that support a daily enhancement in skin health and clarity." }
  ],
  "presets": [
    { "name": "HT Final CTA" }
  ]
}
{% endschema %}