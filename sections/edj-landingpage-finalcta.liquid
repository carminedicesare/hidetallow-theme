<style>
  .ht-final-cta-section {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.padding_mobile }}rem 1.5rem;
    text-align: center;
  }

  .ht-final-cta-container {
    max-width: 700px;
    margin: 0 auto;
  }

  .ht-final-h2 {
    font-size: {{ section.settings.mobile_title_size }}px;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    color: {{ section.settings.heading_color }};
  }

  /* --- Trust Bullets --- */
  .ht-final-bullets {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem 2rem;
    margin-bottom: 2.5rem;
    list-style: none;
    padding: 0;
  }

  .ht-final-bullet {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .ht-final-bullet svg {
    width: 18px;
    height: 18px;
    color: {{ section.settings.accent_color }};
  }

  /* --- Button & Reassurance --- */
  .ht-final-button-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .ht-final-btn {
    display: inline-block;
    background-color: {{ section.settings.btn_color }};
    color: {{ section.settings.btn_text_color }};
    padding: 1.2rem 3rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 800;
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: transform 0.2s ease, filter 0.2s ease;
    width: 100%;
    max-width: 350px;
  }

  .ht-final-btn:hover {
    filter: brightness(1.1);
    transform: translateY(-2px);
  }

  .ht-final-reassurance {
    font-size: 0.85rem;
    opacity: 0.7;
    font-style: italic;
  }

  @media screen and (min-width: 750px) {
    .ht-final-cta-section {
      padding: {{ section.settings.padding_desktop }}rem 2rem;
    }
    .ht-final-h2 {
      font-size: {{ section.settings.desktop_title_size }}px;
    }
    .ht-final-bullet {
      font-size: 1.05rem;
    }
  }
</style>

<section class="ht-final-cta-section">
  <div class="ht-final-cta-container">
    
    <h2 class="ht-final-h2">{{ section.settings.heading }}</h2>

    <ul class="ht-final-bullets">
      {% for block in section.blocks %}
        <li class="ht-final-bullet" {{ block.shopify_attributes }}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          {{ block.settings.bullet_text }}
        </li>
      {% endfor %}
    </ul>

    <div class="ht-final-button-wrapper">
      <a href="{{ section.settings.btn_url }}" class="ht-final-btn">
        {{ section.settings.btn_label }}
      </a>
      <span class="ht-final-reassurance">{{ section.settings.reassurance }}</span>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Final CTA Section",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#0e3a27" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#0e3a27" },
    { "type": "color", "id": "accent_color", "label": "Checkmark Color", "default": "#4CAF50" },
    { "type": "color", "id": "btn_color", "label": "Button Color", "default": "#0e3a27" },
    { "type": "color", "id": "btn_text_color", "label": "Button Text Color", "default": "#ffffff" },
    { "type": "range", "id": "padding_desktop", "label": "Desktop Padding", "min": 2, "max": 12, "step": 1, "unit": "rem", "default": 8 },
    { "type": "range", "id": "padding_mobile", "label": "Mobile Padding", "min": 2, "max": 8, "step": 1, "unit": "rem", "default": 5 },
    { "type": "header", "content": "Copywriting" },
    { "type": "text", "id": "heading", "label": "Main Heading", "default": "Better skin is just one ingredient away." },
    { "type": "text", "id": "btn_label", "label": "Button Label", "default": "Get the $10 Jar" },
    { "type": "url", "id": "btn_url", "label": "Button Link" },
    { "type": "text", "id": "reassurance", "label": "Micro-Reassurance", "default": "One-time purchase. Free shipping on $50+." },
    { "type": "range", "id": "desktop_title_size", "label": "Desktop Title Size", "min": 24, "max": 60, "step": 1, "default": 48 },
    { "type": "range", "id": "mobile_title_size", "label": "Mobile Title Size", "min": 20, "max": 48, "step": 1, "default": 32 }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Trust Bullet",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "bullet_text", "label": "Bullet Text", "default": "100% Grass-Fed" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Landing Page - Final CTA",
      "blocks": [
        { "type": "bullet", "settings": { "bullet_text": "Scent-Free" } },
        { "type": "bullet", "settings": { "bullet_text": "Zero Seed Oils" } },
        { "type": "bullet", "settings": { "bullet_text": "Sensitive Skin Safe" } }
      ]
    }
  ]
}
{% endschema %}