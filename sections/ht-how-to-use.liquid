<div class="ht-reviews-container">
  <div class="ht-reviews-header">
    <div class="ht-stars-top">★★★★★ <span>4.9/5 based on 1,000+ reviews</span></div>
    <h2 class="ht-reviews-main-title">{{ section.settings.main_title }}</h2>
    
    <div class="ht-filter-group">
      <button class="ht-filter-btn active" data-filter="all">All</button>
      <button class="ht-filter-btn" data-filter="eczema">Eczema & Dryness</button>
      <button class="ht-filter-btn" data-filter="daily">Daily Face</button>
      <button class="ht-filter-btn" data-filter="sensitive">Sensitive/Baby</button>
    </div>
  </div>

  <div class="ht-reviews-grid" id="htReviewGrid">
    {%- for block in section.blocks -%}
      <div class="ht-review-card" data-category="{{ block.settings.category | handleize }}" {{ block.shopify_attributes }}>
        
        {%- if block.settings.review_image != blank -%}
          <div class="ht-review-image">
            <img src="{{ block.settings.review_image | image_url: width: 600 }}" alt="Reviewer lifestyle" loading="lazy">
          </div>
        {%- endif -%}

        <div class="ht-review-content">
          <div class="ht-stars-row">★★★★★</div>
          <h3 class="ht-review-headline">{{ block.settings.headline }}</h3>
          <p class="ht-review-text">"{{ block.settings.review_text }}"</p>
          
          <div class="ht-reviewer-footer">
            <div class="ht-verified-wrapper">
              <span class="ht-check-icon">✓</span>
              <span class="ht-reviewer-name">{{ block.settings.reviewer_name }}</span>
            </div>
            {%- if block.settings.category != blank -%}
              <span class="ht-category-tag">{{ block.settings.category }}</span>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

<style>
.ht-reviews-container {
  background-color: #000000; /* Dark mode to match the image */
  padding: 60px 0;
  text-align: center;
  font-family: "Bricolage Grotesque", sans-serif;
  color: #ffffff;
}

.ht-stars-top { color: #FFB800; margin-bottom: 10px; font-size: 14px; }
.ht-stars-top span { color: #fff; margin-left: 8px; }

.ht-reviews-main-title {
  font-size: 42px;
  font-weight: 800;
  margin-bottom: 30px;
  text-transform: none;
}

/* Filter Badges */
.ht-filter-group {
  display: flex;
  justify-content: center;
  gap: 12px;
  margin-bottom: 40px;
  flex-wrap: wrap;
}

.ht-filter-btn {
  background: transparent;
  border: 1px solid #fff;
  color: #fff;
  padding: 10px 24px;
  border-radius: 40px;
  cursor: pointer;
  font-weight: 600;
  transition: 0.3s;
}

.ht-filter-btn.active {
  background: #FF6B35; /* Orange accent from the image */
  border-color: #FF6B35;
}

/* Grid & Cards */
.ht-reviews-grid {
  display: flex;
  gap: 20px;
  overflow-x: auto;
  padding: 0 20px 30px;
  scroll-behavior: smooth;
}

.ht-review-card {
  background: #ffffff;
  border-radius: 16px;
  min-width: 320px;
  max-width: 320px;
  overflow: hidden;
  text-align: left;
  flex-shrink: 0;
}

.ht-review-image img {
  width: 100%;
  height: 220px;
  object-fit: cover;
}

.ht-review-content {
  padding: 20px;
  color: #000;
}

.ht-stars-row { color: #FFB800; margin-bottom: 8px; }

.ht-review-headline {
  font-size: 18px;
  font-weight: 800;
  margin-bottom: 10px;
  color: #000;
}

.ht-review-text {
  font-size: 14px;
  line-height: 1.5;
  color: #444;
  margin-bottom: 20px;
}

.ht-reviewer-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid #eee;
  padding-top: 15px;
}

.ht-verified-wrapper { display: flex; align-items: center; gap: 6px; }

.ht-check-icon {
  background: #FF6B35;
  color: #fff;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
}

.ht-reviewer-name { font-weight: 700; font-size: 14px; }

.ht-category-tag {
  background: #f0f0f0;
  padding: 4px 10px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 600;
  color: #666;
}

/* Hide scrollbar */
.ht-reviews-grid::-webkit-scrollbar { display: none; }

@media (max-width: 749px) {
  .ht-reviews-main-title { font-size: 32px; }
  .ht-review-card { min-width: 280px; }
}
</style>

<script>
function filterReviews(category) {
  const cards = document.querySelectorAll('.ht-review-card');
  const buttons = document.querySelectorAll('.ht-filter-btn');
  
  buttons.forEach(btn => {
    btn.classList.toggle('active', btn.getAttribute('data-filter') === category);
  });

  cards.forEach(card => {
    if (category === 'all' || card.getAttribute('data-category') === category) {
      card.style.display = 'block';
    } else {
      card.style.display = 'none';
    }
  });
}

document.querySelectorAll('.ht-filter-btn').forEach(btn => {
  btn.addEventListener('click', () => filterReviews(btn.getAttribute('data-filter')));
});
</script>