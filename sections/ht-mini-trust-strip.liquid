<section class="why-tallow why-tallow--mini section-{{ section.id }}" style="--ht-bg:#0E3A27; --ht-text:#fff; --ht-muted:#9aa7a2; --ht-border:#1e4a3f;">
  <div class="why-tallow__inner">
    {%- comment -%} Hidden in mini mode; kept for reuse {%- endcomment -%}
    {% if section.settings.title != blank %}<h2 class="why-tallow__title">{{ section.settings.title }}</h2>{% endif %}
    {% if section.settings.subtitle != blank %}<p class="why-tallow__text">{{ section.settings.subtitle }}</p>{% endif %}
    {% if section.settings.quote != blank %}<p class="why-tallow__quote"><span class="stars">★★★★★</span><br>{{ section.settings.quote }}</p>{% endif %}

    <div class="why-tallow__grid">
      {% for block in section.blocks %}
        <div class="why-tallow__item" {{ block.shopify_attributes }}>
          <div class="why-tallow__icon">
            {%- if block.settings.icon_img != blank -%}
              {{ block.settings.icon_img | image_url: width: 96 | image_tag: loading: 'lazy', alt: block.settings.heading }}
            {%- elsif block.settings.icon_svg_html != blank and block.settings.icon_svg_html != "-" -%}
              {{ block.settings.icon_svg_html }}
            {%- elsif block.settings.icon_svg_text != blank and block.settings.icon_svg_text != "-" -%}
              {%- assign svg_txt = block.settings.icon_svg_text
                | strip_newlines | replace: '"',"'" | replace: "#","%23" | replace: "<","%3C" | replace: ">","%3E" -%}
              <img src="data:image/svg+xml;utf8,{{ svg_txt }}" alt="{{ block.settings.heading }}" width="28" height="28" />
            {%- else -%}
              <svg width="28" height="28" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4" fill="currentColor" opacity=".85"/></svg>
            {%- endif -%}
          </div>

          {% if block.settings.heading != blank %}<h3 class="why-tallow__heading">{{ block.settings.heading }}</h3>{% endif %}
          {% if block.settings.text != "-" and block.settings.text != "" %}<p class="why-tallow__desc">{{ block.settings.text }}</p>{% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
/* Base */
.why-tallow{width:100%;background:var(--ht-bg);color:var(--ht-text);}
.why-tallow__inner{max-width:1100px;margin:0 auto;padding:72px 24px;text-align:center;}
.why-tallow__title{font-size:34px;line-height:1.1;font-weight:800;margin:0 0 10px;}
.why-tallow__text{font-size:16px;color:var(--ht-muted);margin:0 0 14px;}
.why-tallow__quote{font-size:14px;color:var(--ht-muted);margin:18px 0 6px;}
.stars{font-weight:800;letter-spacing:.1em}

/* Default grid (reusable mode) */
.why-tallow__grid{display:grid;grid-template-columns:repeat(5,1fr);gap:24px;margin-top:28px}
@media (max-width:1024px){.why-tallow__grid{grid-template-columns:repeat(3,1fr)}}
@media (max-width:720px){.why-tallow__grid{grid-template-columns:repeat(2,1fr)} .why-tallow__item:nth-child(5){grid-column:1/-1}}

.why-tallow__item{padding:14px 10px}
.why-tallow__icon{
  width:64px;height:64px;border:1px solid var(--ht-border);border-radius:999px;margin:0 auto 10px;
  display:flex;align-items:center;justify-content:center;background:transparent;overflow:hidden
}
.why-tallow__icon img, .why-tallow__icon svg{width:40px;height:40px;display:block;margin:auto}
.why-tallow__icon svg{fill:currentColor;opacity:.9}
.why-tallow__heading{font-size:16px;font-weight:800;margin:4px 0;color:var(--ht-text)}
.why-tallow__desc{font-size:14px;color:var(--ht-muted);margin:0}

/* ---- MINI STRIP OVERRIDES (homepage) ---- */
.why-tallow--mini .why-tallow__inner{
  padding:16px 14px;           /* tighter vertical */
  margin-top:8px;              /* clear slideshow dots */
}
.why-tallow--mini .why-tallow__title,
.why-tallow--mini .why-tallow__text,
.why-tallow--mini .why-tallow__quote{ display:none !important; }

.why-tallow--mini .why-tallow__grid{
  grid-template-columns:repeat(3, minmax(0,1fr)) !important;
  gap:10px; margin-top:0;
  align-items:center; justify-items:center;
}
.why-tallow--mini .why-tallow__item{
  padding:6px 4px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
}

/* Bigger icon badge + crisp border, transparent bg */
.why-tallow--mini .why-tallow__icon{
  width:56px;height:56px;border-radius:999px;
  border:1px solid rgba(255,255,255,.26); /* contrast on dark green */
  background:transparent;
  margin:0 auto 6px;
  display:flex;align-items:center;justify-content:center;
}

.why-tallow--mini .why-tallow__icon img,
.why-tallow--mini .why-tallow__icon svg{
  width:28px;height:28px;opacity:.95;
  /* If your glyphs are dark on dark bg, uncomment to invert: */
  /* filter: brightness(0) invert(1); */
}

/* Headings: 1–2 lines max, stronger weight */
.why-tallow--mini .why-tallow__heading{
  font-size:15px;font-weight:800;line-height:1.15;margin:6px 0 0;max-width:14ch;
  text-wrap:balance;
}

/* Hide body copy in mini mode even if schema forces defaults */
.why-tallow--mini .why-tallow__desc{ display:none !important; }

/* Small phones */
@media (max-width:390px){
  .why-tallow--mini .why-tallow__inner{padding:10px 10px}
  .why-tallow--mini .why-tallow__grid{gap:8px}
  .why-tallow--mini .why-tallow__icon{width:52px;height:52px}
  .why-tallow--mini .why-tallow__icon img,
  .why-tallow--mini .why-tallow__icon svg{width:26px;height:26px}
  .why-tallow--mini .why-tallow__heading{font-size:14px}
}
</style>

{% schema %}
{
  "name": "Homepage Ministrip",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "-" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "-" },
    { "type": "text", "id": "quote", "label": "Quote", "default": "-" }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Benefit point",
      "limit": 3,
      "settings": [
        { "type": "image_picker", "id": "icon_img", "label": "Icon image (preferred)" },
        { "type": "html", "id": "icon_svg_html", "label": "OR paste inline SVG (raw HTML)", "default": "-" },
        { "type": "textarea", "id": "icon_svg_text", "label": "OR paste SVG (auto-convert if HTML is stripped)", "default": "-" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Grass-Fed & Finished" },
        { "type": "text", "id": "text", "label": "Description", "default": "-" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Homepage Ministrip",
      "category": "Text",
      "blocks": [
        { "type": "point", "settings": { "heading": "Grass-Fed & Finished", "text": "-" } },
        { "type": "point", "settings": { "heading": "Made in the USA", "text": "-" } },
        { "type": "point", "settings": { "heading": "Everyday Honest Pricing", "text": "-" } }
      ]
    }
  ]
}
{% endschema %}
