<section class="custom-product wrap">
  {% if section.settings.heading != blank %}
    <h2 style="text-align:center; font-size:32px; margin-bottom:20px;">
      {{ section.settings.heading }}
    </h2>
  {% endif %}

  {% if section.settings.text != blank %}
    <p style="text-align:center; max-width:700px; margin:0 auto 30px;">
      {{ section.settings.text }}
    </p>
  {% endif %}

  {% if section.settings.image != blank %}
    <div style="text-align:center; margin-bottom:40px;">
      <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="Hero" style="max-width:100%; border-radius:12px;">
    </div>
  {% endif %}

  {% for block in section.blocks %}
    <div style="margin-bottom:30px; text-align:center;">
      {% if block.settings.block_image != blank %}
        <img src="{{ block.settings.block_image | image_url: width:600 }}" style="max-width:100%; border-radius:8px; margin-bottom:10px;">
      {% endif %}
      {% if block.settings.block_title != blank %}
        <h3>{{ block.settings.block_title }}</h3>
      {% endif %}
      {% if block.settings.block_text != blank %}
        <p>{{ block.settings.block_text }}</p>
      {% endif %}
    </div>
  {% endfor %}
</section>

{% schema %}
{
  "name": "Custom Product Section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Custom Section Heading" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Drop in your custom description here." },
    { "type": "image_picker", "id": "image", "label": "Hero Image" }
  ],
  "blocks": [
    {
      "type": "content",
      "name": "Content Block",
      "settings": [
        { "type": "image_picker", "id": "block_image", "label": "Image" },
        { "type": "text", "id": "block_title", "label": "Title" },
        { "type": "textarea", "id": "block_text", "label": "Text" }
      ]
    }
  ],
  "presets": [
    { "name": "Custom Product Section" }
  ]
}
{% endschema %}
