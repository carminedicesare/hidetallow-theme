{% comment %}
  Section: HT • Featured Duo / Best Sellers (hardened)
{% endcomment %}

<section id="ht-feat-{{ section.id }}" class="ht-feat"
  style="--ht-accent:#0F3A2F; --ht-accent-weak: rgba(15,58,47,.25); --ht-text:#1a1a1a; --ht-muted:#6b6b6b;">
  <style>
    #ht-feat-{{ section.id }}{background:transparent;padding:28px 16px;}
    #ht-feat-{{ section.id }} .wrap{max-width:1100px;margin:0 auto;}
    #ht-feat-{{ section.id }} .title{font-size:28px;font-weight:800;line-height:1.15;margin:0 0 6px;color:var(--ht-text);text-align:center;}
    #ht-feat-{{ section.id }} .sub{font-size:14px;color:var(--ht-muted);margin:0 0 16px;text-align:center;}

    /* Mobile: horizontal scroll */
    #ht-feat-{{ section.id }} .track{
      display:flex;gap:14px;overflow-x:auto;-webkit-overflow-scrolling:touch;padding:2px 2px 4px;
      scroll-snap-type:x mandatory;
    }
    #ht-feat-{{ section.id }} .track::-webkit-scrollbar{display:none;}

    /* Desktop: grid */
    @media (min-width:990px){
      #ht-feat-{{ section.id }} .track{
        display:grid;overflow:visible;padding:0;
        grid-template-columns:repeat({{ section.settings.columns_desktop }}, minmax(0,1fr));
        gap:18px;
      }
    }

    /* Card */
    #ht-feat-{{ section.id }} .card{flex:0 0 {{ section.settings.card_width_mobile }}px;scroll-snap-align:start;background:transparent;border:0;box-shadow:none;border-radius:18px;}
    @media (min-width:990px){#ht-feat-{{ section.id }} .card{flex:0 0 auto;}}

    #ht-feat-{{ section.id }} .media{position:relative;border-radius:18px;overflow:hidden;background:#fff;outline:1px solid rgba(0,0,0,.04);}
    #ht-feat-{{ section.id }} .media img{display:block;width:100%;height:auto;transition:transform .35s ease;}
    #ht-feat-{{ section.id }} .media:hover img{transform:scale(1.02);}

    /* Badge */
    #ht-feat-{{ section.id }} .badge{position:absolute;top:10px;left:10px;background:#EEF3F1;color:var(--ht-accent);font-size:12px;font-weight:700;padding:4px 8px;border-radius:999px;}

    /* Info */
    #ht-feat-{{ section.id }} .info{padding:10px 2px 0;text-align:left;}
    #ht-feat-{{ section.id }} .info-wrap{display:flex;align-items:flex-start;justify-content:space-between;gap:10px;}
    #ht-feat-{{ section.id }} .info-left{min-width:0;}
    #ht-feat-{{ section.id }} .name{font-size:16px;font-weight:800;line-height:1.25;margin:0 0 4px;color:var(--ht-accent);}
    #ht-feat-{{ section.id }} .name a{color:inherit;text-decoration:none;}
    #ht-feat-{{ section.id }} .price{font-size:14px;font-weight:600;color:var(--ht-text);margin:0 0 10px;}

    /* CTA */
    #ht-feat-{{ section.id }} .cta{
      display:inline-flex;align-items:center;justify-content:center;gap:8px;
      padding:10px 14px;border-radius:14px;border:1px solid var(--ht-accent-weak);color:var(--ht-accent);background:transparent;
      font-size:14px;font-weight:700;text-decoration:none;transition:background .2s ease,color .2s ease,border-color .2s ease;white-space:nowrap;
    }
    #ht-feat-{{ section.id }} .cta:hover{background:var(--ht-accent);color:#fff;border-color:var(--ht-accent);}
  </style>

  <div class="wrap">
    {% if section.settings.title != blank %}<h2 class="title">{{ section.settings.title }}</h2>{% endif %}
    {% if section.settings.subtitle != blank %}<p class="sub">{{ section.settings.subtitle }}</p>{% endif %}

    <div class="track">
      {%- assign handle = section.settings.collection -%}
      {%- assign coll = collections[handle] -%}
      {%- assign product_limit = section.settings.limit | default: 2 | plus: 0 -%}
      {%- assign count_safe = 0 -%}
      {%- if coll != blank and coll.products_count != blank -%}
        {%- assign count_safe = coll.products_count | plus: 0 -%}
      {%- endif -%}

      {%- if count_safe > 0 -%}
        {%- for product in coll.products limit: product_limit -%}
          <article class="card">
            <a href="{{ product.url }}" class="media" aria-label="{{ product.title | escape }}">
              {%- if product.featured_image -%}
                {{ product.featured_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: product.title }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag }}
              {%- endif -%}
              {%- unless product.available -%}<span class="badge">Sold out</span>{%- endunless -%}
            </a>

            <div class="info">
              <div class="info-wrap">
                <div class="info-left">
                  <h3 class="name"><a href="{{ product.url }}">{{ product.title }}</a></h3>
                  <p class="price">
                    {%- if product.price_varies -%}
                      From {{ product.price_min | money }}
                    {%- else -%}
                      {{ product.price | money }}
                    {%- endif -%}
                  </p>
                </div>
                <a href="{{ product.url }}" class="cta">{{ section.settings.cta_label }}</a>
              </div>
            </div>
          </article>
        {%- endfor -%}
      {%- else -%}
        <p style="margin:8px 0;color:#666;">Select a collection with products in this section’s settings.</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "HT • Featured Duo",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Our Best Sellers" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Premium grass-fed tallow, priced for real life." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "label": "Products to show", "min": 2, "max": 6, "step": 1, "default": 2 },
    { "type": "range", "id": "columns_desktop", "label": "Desktop columns", "min": 2, "max": 4, "step": 1, "default": 2 },
    { "type": "range", "id": "card_width_mobile", "label": "Card width (mobile px)", "min": 200, "max": 300, "step": 10, "default": 240 },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "View product" }
  ],
  "presets": [{ "name": "HT • Featured Duo" }]
}
{% endschema %}
