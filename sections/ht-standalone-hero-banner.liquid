{% comment %}
  HT Standalone Banner - Optimized for Full Gradient (Green to Marble)
{% endcomment %}

<div class="ht-banner-only-container">
  {%- if section.settings.show_banner -%}
    <div class="ht-shop-banner">
      <div class="ht-banner-overlay"></div>
      
      {%- if section.settings.banner_image != blank -%}
        <picture>
          {%- if section.settings.banner_image_mobile != blank -%}
            {% comment %} Mobile Image {% endcomment %}
            <source media="(max-width: 767px)" srcset="{{ section.settings.banner_image_mobile | image_url: width: 1200 }}">
          {%- endif -%}
          
          {% comment %} Desktop Image {% endcomment %}
          <img 
            src="{{ section.settings.banner_image | image_url: width: 2000 }}" 
            class="ht-banner-img" 
            alt="{{ section.settings.banner_title | escape }}" 
            loading="lazy"
          >
        </picture>
      {%- endif -%}

      <div class="ht-banner-content">
        <h1 class="ht-banner-title">{{ section.settings.banner_title }}</h1>
        {%- if section.settings.banner_sub != blank -%}
          <p class="ht-banner-sub">{{ section.settings.banner_sub }}</p>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&family=Questrial&display=swap');

  .ht-banner-only-container { width: 100%; }

  .ht-shop-banner { 
    position: relative; 
    width: 100%; 
    height: 300px; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    overflow: hidden; 
    background: #0E3A27; 
  }

  .ht-banner-img { 
    position: absolute; 
    top: 0;
    left: 0;
    width: 100%; 
    height: 100%; 
    z-index: 0; 
    object-fit: cover;
    object-position: bottom;
  }

  .ht-banner-overlay { 
    position: absolute; top:0; left:0; right:0; bottom:0; 
    background: rgba(0,0,0,0.1); 
    z-index: 1; 
  }

  .ht-banner-content { position: relative; z-index: 2; text-align: center; color: #fff; padding: 0 20px; }
  .ht-banner-title { font-family: "Bricolage Grotesque", sans-serif; font-size: 48px; font-weight: 800; text-transform: uppercase; margin: 0; letter-spacing: 1px; }
  .ht-banner-sub { font-family: "Questrial", sans-serif; font-size: 14px; text-transform: uppercase; letter-spacing: 2px; margin-top: 10px; }

  /* Desktop Fix: Show full image from top to bottom */
  @media (min-width: 1024px) {
    .ht-shop-banner { height: 400px; }
    .ht-banner-img { 
       object-fit: fill; /* Forces top-to-bottom fit to show full green-to-marble gradient */
    }
    .ht-banner-title { font-size: 64px; }
  }

  /* Mobile: Maintains the layout you already liked */
  @media (max-width: 767px) {
    .ht-shop-banner { height: 250px; } 
    .ht-banner-img { 
      object-fit: cover;
      object-position: bottom; 
    }
    .ht-banner-title { font-size: 30px; }
  }
</style>

{% schema %}
{
  "name": "HT Standalone Banner",
  "settings": [
    { "type": "checkbox", "id": "show_banner", "label": "Show Banner", "default": true },
    { "type": "image_picker", "id": "banner_image", "label": "Desktop Banner Image" },
    { "type": "image_picker", "id": "banner_image_mobile", "label": "Mobile Banner Image" },
    { "type": "text", "id": "banner_title", "label": "Banner Title", "default": "Shop All" },
    { "type": "text", "id": "banner_sub", "label": "Banner Subtext", "default": "ANCESTRAL SKIN NUTRITION" }
  ],
  "presets": [
    {
      "name": "HT Standalone Banner"
    }
  ]
}
{% endschema %}