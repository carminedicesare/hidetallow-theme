<div class="sk-guide-section">
  <div class="sk-ritual-guide">
    {% for block in section.blocks %}
      <div class="sk-step">
        <div class="sk-step-num">{{ forloop.index }}</div>
        <div class="sk-step-text">{{ block.settings.text }}</div>
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .sk-guide-section { padding: 20px; }
  .sk-ritual-guide {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    gap: 40px;
    border-top: 1px solid rgba(14, 58, 39, 0.1);
    border-bottom: 1px solid rgba(14, 58, 39, 0.1);
    padding: 30px 0;
  }
  .sk-step { display: flex; align-items: center; gap: 12px; }
  .sk-step-num {
    background: #0E3A27;
    color: white;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    flex-shrink: 0;
  }
  .sk-step-text {
    text-transform: uppercase;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1px;
  }
  @media (max-width: 768px) {
    .sk-ritual-guide { gap: 15px; flex-direction: column; align-items: flex-start; padding-left: 20px; }
  }
</style>

{% schema %}
{
  "name": "Starter Kit Guide",
  "max_blocks": 3,
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "text", "label": "Step Text" }
      ]
    }
  ],
  "presets": [{ "name": "Starter Kit Guide" }]
}
{% endschema %}