<style>
  .ht-simple-section {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.padding_mobile }}rem 1.5rem;
    text-align: center;
  }

  .ht-simple-container {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* --- Typography --- */
  .ht-simple-h2 {
    font-size: {{ section.settings.mobile_title_size }}px;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1rem;
    color: {{ section.settings.heading_color }};
  }

  .ht-simple-sub {
    font-size: {{ section.settings.mobile_sub_size }}px;
    opacity: 0.8;
    margin-bottom: 3rem;
    max-width: 500px;
    line-height: 1.5;
  }

  /* --- Visual Centerpiece --- */
  .ht-simple-visual {
    width: 100%;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .ht-simple-img {
    width: {{ section.settings.image_width }}%; 
    max-width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    margin-bottom: 1.5rem;
    border-radius: {{ section.settings.image_radius }}px;
  }

  /* The Sourcing Line */
  .ht-simple-sourcing {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    display: flex;
    align-items: center;
    gap: 1rem;
    opacity: 0.9;
  }

  .ht-simple-sourcing::before,
  .ht-simple-sourcing::after {
    content: "";
    display: block;
    width: 30px;
    height: 1px;
    background-color: {{ section.settings.heading_color }};
    opacity: 0.3;
  }

  /* --- The "No" List (Blocks) --- */
  .ht-no-list {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    margin-top: 1rem;
  }

  .ht-no-item {
    font-size: {{ section.settings.mobile_no_size }}px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: {{ section.settings.no_list_color }};
    opacity: 0.85; 
    text-decoration: line-through; 
    transition: opacity 0.3s ease;
  }

  .ht-no-item:hover {
    opacity: 1;
    text-decoration: none; 
  }

  @media screen and (min-width: 750px) {
    .ht-simple-section {
      padding: {{ section.settings.padding_desktop }}rem 2rem;
    }
    .ht-simple-h2 {
      font-size: {{ section.settings.desktop_title_size }}px;
    }
    .ht-simple-sub {
      font-size: {{ section.settings.desktop_sub_size }}px;
    }
    .ht-no-item {
      font-size: {{ section.settings.desktop_no_size }}px;
    }
  }
</style>

<section class="ht-simple-section">
  <div class="ht-simple-container">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="ht-simple-h2">{{ section.settings.heading }}</h2>
    {%- endif -%}
    
    {%- if section.settings.subheading != blank -%}
      <p class="ht-simple-sub">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="ht-simple-visual">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 1200 }}" 
             class="ht-simple-img" 
             alt="{{ section.settings.image.alt | default: 'One Ingredient Tallow' }}"
             loading="lazy">
      {%- endif -%}
      
      {%- if section.settings.sourcing_text != blank -%}
        <div class="ht-simple-sourcing">
          {{ section.settings.sourcing_text }}
        </div>
      {%- endif -%}
    </div>

    <div class="ht-no-list">
      {%- for block in section.blocks -%}
        <div class="ht-no-item" {{ block.shopify_attributes }}>
          {{ block.settings.text }}
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Landing Page - Simplicity",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "Colors & Spacing" },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#0e3a27" },
    { "type": "color", "id": "text_color", "label": "Subheading Text Color", "default": "#0e3a27" },
    { "type": "color", "id": "no_list_color", "label": "'No' List Text Color", "default": "#ffffff" },
    { "type": "range", "id": "padding_desktop", "label": "Desktop Padding", "min": 2, "max": 10, "step": 1, "unit": "rem", "default": 6 },
    { "type": "range", "id": "padding_mobile", "label": "Mobile Padding", "min": 2, "max": 6, "step": 1, "unit": "rem", "default": 4 },
    
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "One ingredient. That’s it." },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Radical simplicity for the most sensitive skin." },
    
    { "type": "header", "content": "Visual Centerpiece" },
    { "type": "image_picker", "id": "image", "label": "Ingredient/Jar Image" },
    { "type": "range", "id": "image_width", "label": "Image Size (Squeezer)", "min": 20, "max": 100, "step": 5, "unit": "%", "default": 60 },
    { "type": "range", "id": "image_radius", "label": "Image Roundness", "min": 0, "max": 60, "step": 4, "unit": "px", "default": 0 },
    { "type": "text", "id": "sourcing_text", "label": "Sourcing Line", "default": "100% Grass-Fed & Finished Tallow" },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "desktop_title_size", "label": "Desktop Title Size", "min": 24, "max": 80, "step": 1, "unit": "px", "default": 56 },
    { "type": "range", "id": "mobile_title_size", "label": "Mobile Title Size", "min": 20, "max": 60, "step": 1, "unit": "px", "default": 42 },
    { "type": "range", "id": "desktop_sub_size", "label": "Desktop Subheading Size", "min": 12, "max": 36, "step": 1, "unit": "px", "default": 18 },
    { "type": "range", "id": "mobile_sub_size", "label": "Mobile Subheading Size", "min": 10, "max": 24, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "desktop_no_size", "label": "Desktop 'No' Item Size", "min": 10, "max": 32, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "mobile_no_size", "label": "Mobile 'No' Item Size", "min": 10, "max": 24, "step": 1, "unit": "px", "default": 14 }
  ],
  "blocks": [
    {
      "type": "no_item",
      "name": "'No' List Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text (e.g. No Fragrance)", "default": "No Fragrance" }
      ]
    }
  ],
  "presets": [ 
    { 
      "name": "Landing Page - Simplicity",
      "blocks": [
        { "type": "no_item", "settings": { "text": "No Fillers" } },
        { "type": "no_item", "settings": { "text": "No Fluff" } },
        { "type": "no_item", "settings": { "text": "No Fragrance" } }
      ]
    } 
  ]
}
{% endschema %}