  -%}
{%- when 'rating' -%}
                <div {{ block.shopify_attributes }} class="ht-yotpo-stars ht-yotpo-stars-{{ block.id }}">
                  <div class="yotpo bottomLine"
                    data-yotpo-product-id="{{ product.id }}">
                  </div>
                </div>
                
                <style>
                  .ht-yotpo-stars-{{ block.id }} {
                    margin-top: {{ block.settings.margin_top }}px;
                    margin-bottom: {{ block.settings.margin_bottom }}px;
                    display: flex;
                    justify-content: {% if block.settings.alignment == 'center' %}center{% else %}flex-start{% endif %};
                  }
                  
                  /* Override Yotpo Star Colors */
                  .ht-yotpo-stars-{{ block.id }} .yotpo .yotpo-icon-star,
                  .ht-yotpo-stars-{{ block.id }} .yotpo .yotpo-icon-half-star,
                  .ht-yotpo-stars-{{ block.id }} .yotpo .yotpo-icon-empty-star {
                    color: {{ block.settings.star_color }} !important;
                  }

                  /* Override Yotpo Text (e.g., "5 Reviews") */
