<style>
  .ht-segmenter-section-{{ section.id }} {
    /* Color Variables */
    --bg-color: {{ section.settings.bg_color }};
    --heading-color: {{ section.settings.heading_color }};
    --text-color: {{ section.settings.text_color }};
    --tile-bg-color: {{ section.settings.tile_bg_color }};
    --tile-border-color: {{ section.settings.tile_border_color }};
    --check-color: {{ section.settings.check_color }};
    --redirect-bg-color: {{ section.settings.redirect_bg_color }};

    /* Spacing Variables */
    --padding-mobile: {{ section.settings.padding_mobile }}rem 1.5rem;
    --padding-desktop: {{ section.settings.padding_desktop }}rem 2rem;

    /* Mobile Sizing (Mapped to Schema) */
    --title-size-mobile: {{ section.settings.mobile_title_size }}px;
    --icon-size-mobile: {{ section.settings.mobile_icon_size }}px;
    --tile-text-mobile: {{ section.settings.mobile_tile_size }}px;
    --redirect-text-mobile: {{ section.settings.mobile_redirect_size }}px;

    /* Desktop Sizing (Mapped to Schema) */
    --title-size-desktop: {{ section.settings.desktop_title_size }}px;
    --icon-size-desktop: {{ section.settings.desktop_icon_size }}px;
    --tile-text-desktop: {{ section.settings.desktop_tile_size }}px;
    --redirect-text-desktop: {{ section.settings.desktop_redirect_size }}px;

    background-color: var(--bg-color);
    color: var(--text-color);
    padding: var(--padding-mobile);
  }

  .ht-segmenter-section-{{ section.id }} .ht-segmenter-container {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  /* --- Heading --- */
  .ht-segmenter-section-{{ section.id }} .ht-segmenter-h2 {
    font-size: var(--title-size-mobile);
    font-weight: 700;
    margin-bottom: 2.5rem;
    color: var(--heading-color);
    line-height: 1.2;
  }

  /* --- Grid for the "YES" Tiles --- */
  .ht-segmenter-section-{{ section.id }} .ht-segmenter-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr); /* 2x2 on mobile */
    gap: 12px;
    margin-bottom: 3rem;
  }

  .ht-segmenter-section-{{ section.id }} .ht-segmenter-tile {
    background-color: var(--tile-bg-color);
    border: 1px solid var(--tile-border-color);
    border-radius: 8px;
    padding: 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    transition: transform 0.2s ease, border-color 0.2s ease;
    height: 100%;
  }
  
  /* Subtle hover effect */
  .ht-segmenter-section-{{ section.id }} .ht-segmenter-tile:hover {
    transform: translateY(-2px);
    border-color: var(--check-color);
  }

  .ht-segmenter-section-{{ section.id }} .ht-segmenter-icon {
    width: var(--icon-size-mobile);
    height: var(--icon-size-mobile);
    margin-bottom: 1rem;
    color: var(--check-color);
    opacity: 0.9;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .ht-segmenter-section-{{ section.id }} .ht-segmenter-icon svg {
    width: 100%;
    height: 100%;
  }

  .ht-segmenter-section-{{ section.id }} .ht-segmenter-tile-text {
    font-size: var(--tile-text-mobile);
    font-weight: 700;
    line-height: 1.3;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--heading-color);
  }

  /* --- The Gentle Redirect Box --- */
  .ht-segmenter-section-{{ section.id }} .ht-redirect-box {
    background-color: var(--redirect-bg-color);
    padding: 2rem;
    border-radius: 12px;
    max-width: 650px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .ht-segmenter-section-{{ section.id }} .ht-redirect-text {
    font-size: var(--redirect-text-mobile);
    line-height: 1.6;
    margin: 0;
    color: var(--text-color);
    opacity: 0.85;
  }
  
  .ht-segmenter-section-{{ section.id }} .ht-redirect-note {
    font-size: calc(var(--redirect-text-mobile) * 0.85); /* Scales proportionally smaller than the redirect text */
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--heading-color);
    opacity: 0.5;
    margin-bottom: 0.5rem;
  }

  /* --- Desktop Scaling --- */
  @media screen and (min-width: 750px) {
    .ht-segmenter-section-{{ section.id }} {
      padding: var(--padding-desktop);
    }
    
    .ht-segmenter-section-{{ section.id }} .ht-segmenter-container {
      max-width: 1100px; /* Widened to allow room for larger fonts without wrapping */
    }

    .ht-segmenter-section-{{ section.id }} .ht-segmenter-h2 {
      font-size: var(--title-size-desktop);
    }

    .ht-segmenter-section-{{ section.id }} .ht-segmenter-grid {
      grid-template-columns: repeat(4, 1fr); /* 4 in a row on desktop */
      gap: 1.5rem;
    }

    .ht-segmenter-section-{{ section.id }} .ht-segmenter-tile {
      padding: 2.5rem 1.5rem;
    }
    
    .ht-segmenter-section-{{ section.id }} .ht-segmenter-icon {
      width: var(--icon-size-desktop);
      height: var(--icon-size-desktop);
      margin-bottom: 1.25rem;
    }
    
    .ht-segmenter-section-{{ section.id }} .ht-segmenter-tile-text {
      font-size: var(--tile-text-desktop);
    }
    
    .ht-segmenter-section-{{ section.id }} .ht-redirect-text {
      font-size: var(--redirect-text-desktop);
    }
    
    .ht-segmenter-section-{{ section.id }} .ht-redirect-note {
      font-size: calc(var(--redirect-text-desktop) * 0.85);
    }
  }
</style>

<section class="ht-segmenter-section-{{ section.id }}">
  <div class="ht-segmenter-container">
    
    {% if section.settings.heading != blank %}
      <h2 class="ht-segmenter-h2">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="ht-segmenter-grid">
      {% for block in section.blocks %}
        <div class="ht-segmenter-tile" {{ block.shopify_attributes }}>
          <div class="ht-segmenter-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
          <span class="ht-segmenter-tile-text">{{ block.settings.tile_text }}</span>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.redirect_text != blank %}
      <div class="ht-redirect-box">
        <span class="ht-redirect-note">Honest Note</span>
        <p class="ht-redirect-text">{{ section.settings.redirect_text }}</p>
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Landing Page - Segmenter",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading & Text Color", "default": "#0e3a27" },
    { "type": "color", "id": "text_color", "label": "Body Text Color", "default": "#0e3a27" },
    
    { "type": "header", "content": "Tile Styling" },
    { "type": "color", "id": "tile_bg_color", "label": "Tile Background", "default": "#ffffff" },
    { "type": "color", "id": "tile_border_color", "label": "Tile Border", "default": "#e0e0e0" },
    { "type": "color", "id": "check_color", "label": "Icon Color", "default": "#4CAF50" },
    
    { "type": "header", "content": "Redirect Box" },
    { "type": "color", "id": "redirect_bg_color", "label": "Box Background", "default": "#F7F7F7" },
    
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_desktop", "label": "Desktop Padding", "min": 2, "max": 10, "step": 1, "unit": "rem", "default": 6 },
    { "type": "range", "id": "padding_mobile", "label": "Mobile Padding", "min": 2, "max": 6, "step": 1, "unit": "rem", "default": 4 },
    
    { "type": "header", "content": "Typography (Desktop)" },
    { "type": "range", "id": "desktop_title_size", "label": "Main Heading Size", "min": 24, "max": 60, "step": 1, "unit": "px", "default": 42 },
    { "type": "range", "id": "desktop_icon_size", "label": "Tile Icon Size", "min": 24, "max": 64, "step": 2, "unit": "px", "default": 40 },
    { "type": "range", "id": "desktop_tile_size", "label": "Tile Text Size", "min": 10, "max": 24, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "desktop_redirect_size", "label": "Redirect Text Size", "min": 12, "max": 28, "step": 1, "unit": "px", "default": 18 },

    { "type": "header", "content": "Typography (Mobile)" },
    { "type": "range", "id": "mobile_title_size", "label": "Main Heading Size", "min": 20, "max": 48, "step": 1, "unit": "px", "default": 30 },
    { "type": "range", "id": "mobile_icon_size", "label": "Tile Icon Size", "min": 20, "max": 48, "step": 1, "unit": "px", "default": 28 },
    { "type": "range", "id": "mobile_tile_size", "label": "Tile Text Size", "min": 10, "max": 20, "step": 1, "unit": "px", "default": 14 },
    { "type": "range", "id": "mobile_redirect_size", "label": "Redirect Text Size", "min": 12, "max": 24, "step": 1, "unit": "px", "default": 16 },

    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Section Heading", "default": "Is the Everyday Jar for you?" },
    { "type": "textarea", "id": "redirect_text", "label": "Redirect Text", "default": "If you prefer scented skincare or lightweight water-based lotions, this probably isn’t your jar." }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Checklist Tile",
      "settings": [
        { "type": "text", "id": "tile_text", "label": "Tile Text", "default": "Dry / Tight Skin" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Landing Page - Segmenter",
      "blocks": [
        { "type": "tile", "settings": { "tile_text": "Dry / Tight Skin" } },
        { "type": "tile", "settings": { "tile_text": "Sensitive / Reactive" } },
        { "type": "tile", "settings": { "tile_text": "Minimalist Routine" } },
        { "type": "tile", "settings": { "tile_text": "Want Fragrance-Free" } }
      ]
    }
  ]
}
{% endschema %}