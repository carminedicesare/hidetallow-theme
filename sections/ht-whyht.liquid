{% comment %}
  Section: HT — Why Hide Tallow (scrollable pillars)
  File: sections/ht-why-hide.liquid
{% endcomment %}

<section id="ht-wht-{{ section.id }}" class="ht-wht" style="background: {{ section.settings.bg }}; text-align: center; padding: 48px 20px;">
  <style>
    #ht-wht-{{ section.id }} .title{font-size:28px;font-weight:800;margin:0 0 12px;color:{{ section.settings.heading_color }}}
    #ht-wht-{{ section.id }} .sub{font-size:16px;color:{{ section.settings.text_color }};max-width:600px;margin:0 auto 28px;line-height:1.6}

    #ht-wht-{{ section.id }} .track{
      display:flex;gap:16px;padding-bottom:12px;overflow-x:auto;-webkit-overflow-scrolling:touch;
      
      justify-content:center;
    }
    

    #ht-wht-{{ section.id }} .card{
      flex:0 0 {{ section.settings.tile_width }}px;
      scroll-snap-align:start;
      background:{{ section.settings.tile_bg }};
      border-radius:16px;
      padding:20px;
      text-align:center;

      /* keep cards tidy */
      min-height:200px;
      display:flex;
      flex-direction:column;
      justify-content:flex-start; /* or center if you want */
    }

    #ht-wht-{{ section.id }} .icon{display:block;margin:0 auto 10px;width:{{ section.settings.icon_size }}px;height:{{ section.settings.icon_size }}px}
    #ht-wht-{{ section.id }} .head{font-weight:700;font-size:16px;margin:0 0 8px;color:{{ section.settings.heading_color }}}
    #ht-wht-{{ section.id }} .body{font-size:14px;color:{{ section.settings.text_color }};margin:0;line-height:1.6}

    /* Mobile progress bar (optional) */
    #ht-wht-{{ section.id }} .prog-wrap{margin:10px auto 0;height:4px;background:#eee;width:100%;max-width:320px;border-radius:2px;overflow:hidden;display:none}
    #ht-wht-{{ section.id }} .prog{height:100%;width:0%;background:{{ section.settings.progress_color }};transition:width .2s ease}

    /* Desktop options */
    @media (min-width:990px){
      {% if section.settings.desktop_layout == 'grid' %}
        #ht-wht-{{ section.id }} .track{overflow:visible;flex-wrap:wrap;justify-content:center}
        #ht-wht-{{ section.id }} .card{flex:0 0 calc(25% - 12px)}
      {% elsif section.settings.desktop_layout == 'left' %}
        #ht-wht-{{ section.id }} .track{justify-content:flex-start}
      {% else %}
        #ht-wht-{{ section.id }} .track{justify-content:center}
      {% endif %}
    }

    /* Mobile: force starting at the first item */
    @media (max-width:989px){
      #ht-wht-{{ section.id }} .track{
        justify-content:flex-start;           /* pack from the left */
        scroll-padding-left:0;                /* snap baseline */
        scroll-padding-inline-start:0;
      }
      {% if section.settings.show_progress_bar %}
        #ht-wht-{{ section.id }} .prog-wrap{display:block}
      {% endif %}
    }
  </style>

  {% if section.settings.title != blank %}<h2 class="title">{{ section.settings.title }}</h2>{% endif %}
  {% if section.settings.subtitle != blank %}<p class="sub">{{ section.settings.subtitle }}</p>{% endif %}

  <div class="track" id="wht-track-{{ section.id }}">
    {% for block in section.blocks %}
      {% if block.type == 'pillar' %}
        <article class="card">
          {% if block.settings.icon != blank %}
            {{ block.settings.icon | image_url: width: 100 | image_tag: class: 'icon', loading: 'lazy', alt: block.settings.heading }}
          {% endif %}
          {% if block.settings.heading != blank %}<p class="head">{{ block.settings.heading }}</p>{% endif %}
          {% if block.settings.body != blank %}<p class="body">{{ block.settings.body }}</p>{% endif %}
        </article>
      {% endif %}
    {% endfor %}
  </div>

  {% if section.settings.show_progress_bar %}
    <div class="prog-wrap"><div class="prog" id="wht-prog-{{ section.id }}"></div></div>
  {% endif %}

  <!-- Progress bar updater -->
  {% if section.settings.show_progress_bar %}
  <script>
    (function(){
      var t=document.getElementById('wht-track-{{ section.id }}');
      var p=document.getElementById('wht-prog-{{ section.id }}');
      if(!t||!p) return;
      function u(){
        var m=t.scrollWidth - t.clientWidth;
        if(m<=0){ p.style.width='100%'; return; }
        p.style.width=(t.scrollLeft/m)*100+'%';
      }
      t.addEventListener('scroll',u,{passive:true});
      if('IntersectionObserver' in window){
        var once=false,io=new IntersectionObserver(function(es){
          es.forEach(function(e){ if(e.isIntersecting && !once){ once=true; u(); }});
        },{threshold:0.1});
        io.observe(t);
      } else { u(); }
    })();
  </script>
  {% endif %}

  <!-- Force scroll to the first card on load/orientation change (helps iOS start-at-center quirk) -->
  <script>
    (function(){
      var t=document.getElementById('wht-track-{{ section.id }}');
      if(!t) return;
      function toStart(){ try{ t.scrollLeft = 0; }catch(e){} }
      if (document.readyState !== 'loading') toStart();
      else document.addEventListener('DOMContentLoaded', toStart, {once:true});
      window.addEventListener('orientationchange', function(){ setTimeout(toStart, 0); }, {passive:true});
    })();
  </script>
</section>

{% schema %}
{
  "name": "Why Hide Tallow",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Why Hide Tallow?" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "A different kind of skincare — made for real people, priced for real life." },

    { "type": "select", "id": "desktop_layout", "label": "Desktop layout", "default": "center",
      "options": [
        { "value": "center", "label": "Centered row (scroll if needed)" },
        { "value": "left", "label": "Left-aligned row" },
        { "value": "grid", "label": "Grid (4-up)" }
      ]
    },
    { "type": "range", "id": "tile_width", "label": "Card width (px) on mobile", "min": 200, "max": 260, "step": 10, "default": 220 },
    { "type": "checkbox", "id": "show_progress_bar", "label": "Show mobile progress bar", "default": true },

    { "type": "color", "id": "bg", "label": "Background", "default": "#fefcf9" },
    { "type": "color", "id": "tile_bg", "label": "Card background", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#1a1a1a" },
    { "type": "color", "id": "text_color", "label": "Body text color", "default": "#555555" },
    { "type": "color", "id": "progress_color", "label": "Progress bar color", "default": "#000000" },
    { "type": "range", "id": "icon_size", "label": "Optional icon size (px)", "min": 24, "max": 64, "step": 4, "default": 40 }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon (optional)" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Actually Affordable" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Tired of $45 jars? Us too. We kept it real — only $10 to try, no gimmicks or markups." }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Why Hide Tallow",
      "category": "Product",
      "blocks": [
        { "type": "pillar", "settings": { "heading": "Always Grass-Fed & Finished", "body": "No shortcuts. Our tallow is 100% grass-fed, grass-finished, and sourced from trusted farms." } },
        { "type": "pillar", "settings": { "heading": "Actually Affordable", "body": "Tired of $45 jars? Us too. We kept it real — real pricing, no gimmicks or markups." } },
        { "type": "pillar", "settings": { "heading": "Made in the USA", "body": "Poured, packed, and shipped right here — supporting small farms and suppliers across the U.S." } },
        { "type": "pillar", "settings": { "heading": "Built by Real People", "body": "We started Hide out of frustration with overpriced, overcomplicated “natural” skincare. So we fixed it." } },
        { "type": "pillar", "settings": { "heading": "No Fluff. No Fillers.", "body": "Always pure, always powerful — priced right, with nothing extra." } }
      ]
    }
  ]
}
{% endschema %}
