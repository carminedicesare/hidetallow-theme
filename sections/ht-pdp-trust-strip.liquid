{%- assign s = b.settings -%}

<style>
  .why-tallow__inner{max-width:1100px;margin:0 auto;padding:16px 14px;text-align:center;}
  .why-tallow__grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;margin-top:0;align-items:center;justify-items:center;}
  .why-tallow__item{padding:6px 4px;display:flex;flex-direction:column;align-items:center;justify-content:center;}
  .why-tallow__icon{width:56px;height:56px;border:1px solid rgba(255,255,255,.26);border-radius:999px;background:transparent;margin:0 auto 6px;display:flex;align-items:center;justify-content:center;overflow:hidden}
  .why-tallow__icon img{width:28px;height:28px;display:block}
  .why-tallow__heading{font-size:15px;font-weight:800;line-height:1.15;margin:6px 0 0;max-width:14ch;text-wrap:balance;color:#fff}
  @media (max-width:390px){
    .why-tallow__inner{padding:10px 10px}
    .why-tallow__grid{gap:8px}
    .why-tallow__icon{width:52px;height:52px}
    .why-tallow__icon img{width:26px;height:26px}
    .why-tallow__heading{font-size:14px}
  }
</style>

<section class="why-tallow why-tallow--mini section-ht-pdp-strip"
  style="--ht-bg: {{ s.bg | default: '#0f3a2f' }};">
  <div class="why-tallow__inner" style="margin-top:8px;">
    <div class="why-tallow__grid">

      {% for i in (1..3) %}
        {%- assign icon_key = 'item' | append: i | append: '_icon_img' -%}
        {%- assign emoji_key = 'item' | append: i | append: '_emoji' -%}
        {%- assign heading_key = 'item' | append: i | append: '_heading' -%}

        {%- assign icon_img = s[icon_key] -%}
        {%- assign emoji = s[emoji_key] -%}
        {%- assign heading = s[heading_key] -%}

        {% if heading != blank %}
        <div class="why-tallow__item">
          <div class="why-tallow__icon">
            {% if icon_img != blank %}
              {{ icon_img | image_url: width: 96 | image_tag: loading: 'lazy', alt: '' }}
            {% elsif emoji != blank %}
              <span style="font-size:20px;line-height:1">{{ emoji }}</span>
            {% else %}
              <svg width="28" height="28" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4" fill="currentColor" opacity=".85"/></svg>
            {% endif %}
          </div>
          <h3 class="why-tallow__heading">{{ heading }}</h3>
        </div>
        {% endif %}

      {% endfor %}

    </div>
  </div>
</section>
