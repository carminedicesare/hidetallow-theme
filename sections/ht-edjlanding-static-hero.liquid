<style>
  /* --- Global Section Reset (Mobile First) --- */
  .ht-split-hero {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    overflow: hidden;
    background-color: {{ section.settings.bg_color_mobile }};
    color: {{ section.settings.text_color_mobile }};
  }

  /* --- Mobile Background Image (Optional) --- */
  .ht-mobile-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  /* Mobile Overlay for text readability if using a BG image */
  .ht-mobile-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #000000;
    opacity: {{ section.settings.mobile_overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  /* --- Desktop Image Column (Hidden on Mobile) --- */
  .ht-desktop-img-col {
    display: none;
  }

  /* --- Text Column (Stacks on mobile, right side on desktop) --- */
  .ht-text-col {
    position: relative;
    z-index: 3; /* Above mobile background & overlay */
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
    text-align: center;
  }

  .ht-split-text-inner {
    max-width: 500px;
    width: 100%;
  }

  /* --- Typography & Elements --- */
  .ht-split-h1 {
    font-size: {{ section.settings.mobile_title_size }}px;
    line-height: 1.1;
    margin-bottom: 0.8rem;
    font-weight: 700;
    color: inherit;
  }

  .ht-split-sub {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    line-height: 1.4;
    color: inherit;
  }

  /* Pill Bullets */
  .ht-split-bullets {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin-bottom: 2rem;
  }

  .ht-split-bullet {
    border: 1px solid currentColor;
    border-radius: 30px;
    padding: 6px 16px;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.9;
  }

  /* Product Image (Transparent Jar) */
  .ht-split-product-img {
    max-width: 220px; /* Adjust size of jar here */
    width: 100%;
    height: auto;
    margin: 0 auto 2rem auto;
    display: block;
  }

  /* CTA Button */
  .ht-split-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.btn_bg_color }};
    color: {{ section.settings.btn_text_color }};
    padding: 1rem 2rem;
    width: 100%;
    max-width: 320px;
    border-radius: 8px;
    text-transform: uppercase;
    letter-spacing: 0.1rem;
    font-weight: 600;
    font-size: 1.1rem;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .ht-split-btn:hover {
    opacity: 0.85;
  }

  /* Risk Reversal */
  .ht-split-risk {
    font-size: 0.8rem;
    margin-top: 12px;
    opacity: 0.7;
  }

  /* --- Desktop Layout (Side-by-Side) --- */
  @media screen and (min-width: 750px) {
    .ht-split-hero {
      flex-direction: row;
      align-items: stretch;
      min-height: {{ section.settings.desktop_height }}px;
      background-color: transparent; 
    }

    .ht-mobile-bg,
    .ht-mobile-overlay {
      display: none; /* Hide mobile background elements on desktop */
    }

    .ht-desktop-img-col {
      display: block;
      width: 50%;
      position: relative;
    }

    .ht-desktop-img {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
    }

    .ht-text-col {
      width: 50%;
      padding: 4rem;
      background-color: {{ section.settings.bg_color_desktop }};
      color: {{ section.settings.text_color_desktop }};
    }

    .ht-split-h1 {
      font-size: {{ section.settings.desktop_title_size }}px;
    }

    .ht-split-sub {
      font-size: 1.2rem;
    }
  }
</style>

<section class="ht-split-hero">
  {%- if section.settings.image_mobile != blank -%}
    <img src="{{ section.settings.image_mobile | image_url: width: 800 }}" 
         class="ht-mobile-bg" 
         alt="{{ section.settings.image_mobile.alt | escape }}"
         loading="eager">
    <div class="ht-mobile-overlay"></div>
  {%- endif -%}

  <div class="ht-desktop-img-col">
    {%- if section.settings.image_desktop != blank -%}
      <img src="{{ section.settings.image_desktop | image_url: width: 1500 }}" 
           class="ht-desktop-img" 
           alt="{{ section.settings.image_desktop.alt | escape }}"
           loading="eager">
    {%- endif -%}
  </div>

  <div class="ht-text-col">
    <div class="ht-split-text-inner">
      
      {%- if section.settings.heading != blank -%}
        <h1 class="ht-split-h1">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="ht-split-sub">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <div class="ht-split-bullets">
        {%- if section.settings.bullet_1 != blank -%}
          <span class="ht-split-bullet">{{ section.settings.bullet_1 }}</span>
        {%- endif -%}
        {%- if section.settings.bullet_2 != blank -%}
          <span class="ht-split-bullet">{{ section.settings.bullet_2 }}</span>
        {%- endif -%}
        {%- if section.settings.bullet_3 != blank -%}
          <span class="ht-split-bullet">{{ section.settings.bullet_3 }}</span>
        {%- endif -%}
      </div>

      {%- if section.settings.product_image != blank -%}
        <img src="{{ section.settings.product_image | image_url: width: 400 }}" 
             class="ht-split-product-img" 
             alt="{{ section.settings.product_image.alt | escape }}"
             loading="lazy">
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.link }}" class="ht-split-btn">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}

      {%- if section.settings.risk_reversal != blank -%}
        <p class="ht-split-risk">{{ section.settings.risk_reversal }}</p>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Split Offer Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Desktop Colors"
    },
    { "type": "color", "id": "bg_color_desktop", "label": "Desktop Text Box Background", "default": "#F8F8F8" },
    { "type": "color", "id": "text_color_desktop", "label": "Desktop Text Color", "default": "#0e3a27" },

    {
      "type": "header",
      "content": "Mobile Colors & Background"
    },
    { "type": "color", "id": "bg_color_mobile", "label": "Mobile Background Color", "default": "#F8F8F8", "info": "Shows if no mobile image is uploaded." },
    { "type": "color", "id": "text_color_mobile", "label": "Mobile Text Color", "default": "#0e3a27" },
    { "type": "range", "id": "mobile_overlay_opacity", "label": "Mobile Image Overlay Darkening", "min": 0, "max": 100, "step": 5, "default": 20, "unit": "%", "info": "Darkens the mobile background image so text is readable." },

    {
      "type": "header",
      "content": "Images"
    },
    { "type": "image_picker", "id": "image_desktop", "label": "Split Image (Desktop Only)" },
    { "type": "image_picker", "id": "image_mobile", "label": "Background Image (Mobile Only)", "info": "Leave blank to use the solid background color instead." },
    { "type": "image_picker", "id": "product_image", "label": "Product Image (Displays above button)" },

    {
      "type": "header",
      "content": "Typography & Sizing"
    },
    { "type": "range", "id": "desktop_height", "label": "Desktop Minimum Height", "min": 500, "max": 900, "step": 10, "unit": "px", "default": 650 },
    { "type": "range", "id": "desktop_title_size", "label": "Desktop Title Size", "min": 30, "max": 80, "step": 1, "default": 48 },
    { "type": "range", "id": "mobile_title_size", "label": "Mobile Title Size", "min": 24, "max": 60, "step": 1, "default": 36 },

    {
      "type": "header",
      "content": "Copywriting"
    },
    { "type": "text", "id": "heading", "default": "Your first Everyday Jar for $10", "label": "H1 Heading" },
    { "type": "textarea", "id": "subheading", "default": "Sensitive-skin safe, 1 ingredient, grass-fed", "label": "Subheading" },
    
    { "type": "text", "id": "bullet_1", "default": "100% Grass-Fed", "label": "Trust Bullet 1" },
    { "type": "text", "id": "bullet_2", "default": "1 Ingredient", "label": "Trust Bullet 2" },
    { "type": "text", "id": "bullet_3", "default": "Sensitive Skin Safe", "label": "Trust Bullet 3" },

    {
      "type": "header",
      "content": "Call To Action"
    },
    { "type": "text", "id": "button_label", "default": "Get the $10 Jar", "label": "Button Label" },
    { "type": "url", "id": "link", "label": "Button Link" },
    { "type": "color", "id": "btn_bg_color", "label": "Button Background", "default": "#0e3a27" },
    { "type": "color", "id": "btn_text_color", "label": "Button Text", "default": "#ffffff" },
    { "type": "text", "id": "risk_reversal", "default": "Free Shipping • 30-Day Guarantee • Easy Returns", "label": "Micro Risk Reversal text" }
  ],
  "presets": [ { "name": "Split Offer Hero" } ]
}
{% endschema %}