

  <div style="font-weight:600; font-size:16px; margin:20px 0 10px;">
 Purchase Options:
  </div>
<section class="htb section-{{ section.id }}">
  {%- assign v = product.selected_or_first_available_variant -%}
  {%- assign sp = product.selling_plan_groups -%}

  <div class="htb__inner" data-htb data-product-id="{{ product.id }}">
    <div class="htb__section">
      <div class="htb__label">{{ section.settings.serving_label }}</div>
      <div class="htb__cards" role="radiogroup">
        {%- assign sizes = section.settings.serving_sizes | split: "," -%}
        {%- for s in sizes -%}
          {%- assign p = s | strip | split: "|" -%}
          <label class="htb__card htb__serving {% if forloop.first %}is-active{% endif %}">
            <input type="radio" name="htb-serving-{{ product.id }}" value="{{ p[0] | strip }}" {% if forloop.first %}checked{% endif %} hidden>
            <div class="htb__card-body">
              <div class="htb__thumb"></div>
              <div class="htb__card-title">{{ p[1] | strip }}</div>
            </div>
          </label>
        {%- endfor -%}
      </div>
    </div>

    <div class="htb__section">
      <div class="htb__label">{{ section.settings.purchase_label }}</div>
      <div class="htb__cards">
        <label class="htb__card htb__po is-active" data-mode="subscribe">
          <input type="radio" name="htb-mode-{{ product.id }}" value="subscribe" checked hidden>
          <div class="htb__ribbon">{{ section.settings.sub_ribbon }}</div>
          <div class="htb__po-title">{{ section.settings.sub_title }}</div>
          <div class="htb__price"><span class="htb__price-main" data-price="sub"></span></div>
          <div class="htb__fine">
            <span class="htb__compare" data-compare="reg"></span>
            <span class="htb__muted" data-compare="sub"></span> / unit
          </div>
        </label>

        <label class="htb__card htb__po" data-mode="one">
          <input type="radio" name="htb-mode-{{ product.id }}" value="one" hidden>
          <div class="htb__ribbon is-dark">{{ section.settings.one_ribbon }}</div>
          <div class="htb__po-title">{{ section.settings.one_title }}</div>
          <div class="htb__price"><span class="htb__price-main" data-price="one"></span></div>
          <div class="htb__fine">
            <span class="htb__muted">{{ section.settings.reg_label }}</span>
            <span class="htb__compare" data-compare="reg-full"></span> / unit
          </div>
        </label>
      </div>
    </div>

    <input type="hidden" class="htb__sellplan" value="">
    <input type="hidden" class="htb__qty" value="1">

    <script type="application/json" class="htb__data">{
      "money_format": {{ shop.money_format | json }},
      "variant_price": {{ v.price | json }},
      "variant_compare_at": {{ v.compare_at_price | json }},
      "fallback_sub_pct": {{ section.settings.fallback_sub_pct | json }},
      "selling_plan_groups": [
        {%- for g in sp -%}
          { "id": {{ g.id | json }}, "plans": [
            {%- for p in g.selling_plans -%}
              { "id": {{ p.id | json }}, "adj": {{ p.price_adjustments | first | json }} }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          ] }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }</script>
  </div>
</section>

<script>
(function(){
  const root=document.currentScript.previousElementSibling.querySelector('[data-htb]'); if(!root) return;
  const data=JSON.parse(root.querySelector('.htb__data').textContent||"{}");
  const form=document.querySelector('form[action*="/cart/add"]')||document.querySelector('product-form form'); if(!form) return;
  const qty=form.querySelector('input[name="quantity"]')||form.querySelector('[name="quantity"]');
  const sp=form.querySelector('input[name="selling_plan"]')||(function(){const i=document.createElement('input');i.type='hidden';i.name='selling_plan';form.appendChild(i);return i;})();

  const $qa=s=>Array.prototype.slice.call(root.querySelectorAll(s));
  const fmt=c=> (data.money_format||'${{amount}}').replace(/\{\{.*?\}\}/,(c/100).toFixed(2));
  const firstPlan=()=>{const g=(data.selling_plan_groups||[])[0];return g&&g.plans&&g.plans[0]?g.plans[0]:null;}
  const adj=(b,a)=>!a?b:(a.value_type==='percentage'?Math.round(b*(100-a.value)/100):a.value_type==='price'?Math.max(0,b-a.value):a.value_type==='fixed_amount'?Math.max(0,a.value):b);
  const subUnit=b=>{const p=firstPlan(); if(p&&p.adj) return adj(b,p.adj); const pct=Number(data.fallback_sub_pct||0); return Math.round(b*(100-pct)/100);};
  const curQty=()=>{const r=root.querySelector('input[name^="htb-serving-"]:checked'); return r?parseInt(r.value,10):1;}
  const mode =()=>{const a=root.querySelector('.htb__po.is-active'); return a?a.getAttribute('data-mode'):'subscribe';}
  const setHidden=()=>{ if(qty) qty.value=curQty(); sp.value=(mode()==='subscribe'&&firstPlan())?String(firstPlan().id):''; }
  function updatePrices(){
    const base=+data.variant_price||0, msrp=+data.variant_compare_at||base, q=curQty(), subU=subUnit(base), oneU=base;
    const Q=s=>root.querySelector(s); if(Q('[data-price="sub"]')) Q('[data-price="sub"]').textContent=fmt(subU*q);
    if(Q('[data-price="one"]')) Q('[data-price="one"]').textContent=fmt(oneU*q);
    if(Q('[data-compare="reg"]')) Q('[data-compare="reg"]').textContent=fmt(base);
    if(Q('[data-compare="sub"]')) Q('[data-compare="sub"]').textContent=fmt(subU);
    if(Q('[data-compare="reg-full"]')) Q('[data-compare="reg-full"]').textContent=fmt(msrp);
  }
  const select=(list,el)=>{list.forEach(c=>c.classList.remove('is-active')); el.classList.add('is-active');};
  $qa('.htb__serving').forEach(card=>card.addEventListener('click',function(){this.querySelector('input').checked=true;select($qa('.htb__serving'),this);setHidden();updatePrices();}));
  $qa('.htb__po').forEach(card=>card.addEventListener('click',function(){this.querySelector('input').checked=true;select($qa('.htb__po'),this);setHidden();updatePrices();}));
  setHidden(); updatePrices();
})();
</script>

<style>
.htb__inner{padding:0;margin:0}
.htb__section{margin-bottom:16px}
.htb__label{font-weight:700;margin-bottom:8px}
.htb__cards{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
.htb__card{position:relative;border:1px solid #dcdcdc;border-radius:12px;padding:14px;background:#fff;cursor:pointer;transition:.15s ease}
.htb__card:hover{border-color:#000}
.htb__card.is-active{border-color:#000;box-shadow:0 0 0 1px #000 inset}
.htb__card-title{font-weight:600}
.htb__thumb{width:36px;height:48px;border-radius:6px;background:#f3f3f3;margin-bottom:8px}
.htb__po .htb__po-title{font-weight:800;text-transform:uppercase;margin:6px 0 4px}
.htb__price{font-size:26px;font-weight:800;letter-spacing:.3px}
.htb__fine{font-size:12px;margin-top:4px}
.htb__compare{text-decoration:line-through;margin-right:6px}
.htb__muted{opacity:.75}
.htb__ribbon{position:absolute;top:-10px;left:12px;background:#000;color:#fff;padding:3px 8px;border-radius:6px;font-size:11px;font-weight:700}
.htb__ribbon.is-dark{background:#333}
@media (min-width:720px){.htb__cards{grid-template-columns:repeat(3,1fr)}}
</style>

{% schema %}
{
  "name": "HT – Buy Box",
  "settings": [
    { "type": "text", "id": "serving_label", "label": "Serving", "default": "Serving" },
    { "type": "text", "id": "purchase_label", "label": "Purchase", "default": "Purchase" },
    { "type": "text", "id": "serving_sizes", "label": "Sizes", "default": "1|1 MONTH, 3|3 MONTH, 6|6 MONTH" },
    { "type": "text", "id": "sub_ribbon", "label": "Sub ribbon", "default": "SUBSCRIBE" },
    { "type": "text", "id": "one_ribbon", "label": "One ribbon", "default": "ONE-TIME" },
    { "type": "text", "id": "sub_title", "label": "Sub title", "default": "Subscribe & Save" },
    { "type": "text", "id": "one_title", "label": "One title", "default": "One-time Purchase" },
    { "type": "text", "id": "reg_label", "label": "Reg", "default": "REG:" },
    { "type": "range", "id": "fallback_sub_pct", "label": "Fallback %", "min": 0, "max": 40, "step": 1, "default": 20 }
  ],
  "presets": [{ "name": "HT – Buy Box" }]
}
{% endschema %}
