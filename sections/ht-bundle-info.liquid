      "label": "Line 1",
      "default": "Everyday Jar – 2oz whipped tallow for face & body."
    },
    {
      "type": "text",
      "id": "whats_inside_item_2",
      "label": "Line 2",
      "default": "On The Go Tin – 1oz travel-size balm for pockets and bags."
    },
    {
      "type": "text",
      "id": "whats_inside_item_3",
      "label": "Line 3",
      "default": "Pocket Stick – concentrated tallow stick for lips and dry spots."
    },

    {
      "type": "header",
      "content": "How it works"
    },
    {
      "type": "checkbox",
      "id": "show_how_it_works",
