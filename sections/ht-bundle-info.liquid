    },
    {
      "type": "text",
      "id": "how_it_works_title",
      "label": "Title",
      "default": "How it works"
    },
    {
      "type": "text",
      "id": "how_item_1",
      "label": "Step 1",
      "default": "Choose 1 scent for your Everyday Jar."
    },
    {
      "type": "text",
      "id": "how_item_2",
      "label": "Step 2",
      "default": "Choose 1 scent for your On The Go Tin."
    },
    {
      "type": "text",
      "id": "how_item_3",
      "label": "Step 3",
      "default": "Choose 1 scent for your Pocket Stick."
    },
    {
      "type": "text",
      "id": "how_item_4",
      "label": "Step 4",
      "default": "20% off applies automatically once all three are in your cart."
    },

    {
      "type": "header",
      "content": "Why this bundle"
    },
    {
      "type": "checkbox",
      "id": "show_why_bundle",
      "label": "Show \"Why this bundle\" accordion",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "why_open_default",
      "label": "Open by default",
      "default": false
    },
    {
      "type": "text",
      "id": "why_bundle_title",
      "label": "Title",
      "default": "Why start with this kit"
    },
    {
      "type": "text",
      "id": "why_item_1",
      "label": "Reason 1",
      "default": "Try all three formats – jar, tin, and stick."
    },
    {
      "type": "text",
      "id": "why_item_2",
      "label": "Reason 2",
      "default": "Dial in your personal scent combo."
    },
    {
      "type": "text",
      "id": "why_item_3",
      "label": "Reason 3",
      "default": "Save 20% on a full everyday routine."
