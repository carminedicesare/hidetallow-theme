{% comment %}
  HT • Bundle Info (Accordion)
  Lightweight accordion-style info section for bundle-style products.

  Blocks:
    - What's inside
    - How it works
    - Why start with this kit
    - Quick questions (mini FAQ)
{% endcomment %}

{% if section.settings.limit_to_bundles == false or product.metafields.custom.bundle_type != blank %}

<section id="ht-bundle-info-{{ section.id }}" class="section-{{ section.id }}-padding">
  <div class="page-width ht-bundle-info__wrap">

    <div class="ht-bundle-info__accordion">

      {%- if section.settings.show_whats_inside -%}
        <details class="ht-acc" {% if section.settings.whats_inside_open_default %}open{% endif %}>
          <summary class="ht-acc__summary">
            <span class="ht-acc__title">
              {{ section.settings.whats_inside_title }}
            </span>
            <span class="ht-acc__icon" aria-hidden="true">
              <span class="ht-acc__icon-line ht-acc__icon-line--vert"></span>
              <span class="ht-acc__icon-line ht-acc__icon-line--horiz"></span>
            </span>
          </summary>
          <div class="ht-acc__content">
            <ul class="ht-bundle-info__list">
              {%- if section.settings.whats_inside_item_1 != blank -%}
                <li>{{ section.settings.whats_inside_item_1 }}</li>
              {%- endif -%}
              {%- if section.settings.whats_inside_item_2 != blank -%}
                <li>{{ section.settings.whats_inside_item_2 }}</li>
              {%- endif -%}
              {%- if section.settings.whats_inside_item_3 != blank -%}
                <li>{{ section.settings.whats_inside_item_3 }}</li>
              {%- endif -%}
            </ul>
          </div>
        </details>
      {%- endif -%}

      {%- if section.settings.show_how_it_works -%}
        <details class="ht-acc" {% if section.settings.how_open_default %}open{% endif %}>
          <summary class="ht-acc__summary">
            <span class="ht-acc__title">
              {{ section.settings.how_it_works_title }}
            </span>
            <span class="ht-acc__icon" aria-hidden="true">
              <span class="ht-acc__icon-line ht-acc__icon-line--vert"></span>
              <span class="ht-acc__icon-line ht-acc__icon-line--horiz"></span>
            </span>
          </summary>
          <div class="ht-acc__content">
            <ul class="ht-bundle-info__list">
              {%- if section.settings.how_item_1 != blank -%}
                <li>{{ section.settings.how_item_1 }}</li>
              {%- endif -%}
              {%- if section.settings.how_item_2 != blank -%}
                <li>{{ section.settings.how_item_2 }}</li>
              {%- endif -%}
              {%- if section.settings.how_item_3 != blank -%}
                <li>{{ section.settings.how_item_3 }}</li>
              {%- endif -%}
              {%- if section.settings.how_item_4 != blank -%}
                <li>{{ section.settings.how_item_4 }}</li>
              {%- endif -%}
            </ul>
          </div>
        </details>
      {%- endif -%}

      {%- if section.settings.show_why_bundle -%}
        <details class="ht-acc" {% if section.settings.why_open_default %}open{% endif %}>
          <summary class="ht-acc__summary">
            <span class="ht-acc__title">
              {{ section.settings.why_bundle_title }}
            </span>
            <span class="ht-acc__icon" aria-hidden="true">
              <span class="ht-acc__icon-line ht-acc__icon-line--vert"></span>
              <span class="ht-acc__icon-line ht-acc__icon-line--horiz"></span>
            </span>
          </summary>
          <div class="ht-acc__content">
            <ul class="ht-bundle-info__list">
              {%- if section.settings.why_item_1 != blank -%}
                <li>{{ section.settings.why_item_1 }}</li>
              {%- endif -%}
              {%- if section.settings.why_item_2 != blank -%}
                <li>{{ section.settings.why_item_2 }}</li>
              {%- endif -%}
              {%- if section.settings.why_item_3 != blank -%}
                <li>{{ section.settings.why_item_3 }}</li>
              {%- endif -%}
            </ul>
          </div>
        </details>
      {%- endif -%}

      {%- if section.settings.show_faq -%}
        <details class="ht-acc" {% if section.settings.faq_open_default %}open{% endif %}>
          <summary class="ht-acc__summary">
            <span class="ht-acc__title">
              {{ section.settings.faq_title }}
            </span>
            <span class="ht-acc__icon" aria-hidden="true">
              <span class="ht-acc__icon-line ht-acc__icon-line--vert"></span>
              <span class="ht-acc__icon-line ht-acc__icon-line--horiz"></span>
            </span>
          </summary>
          <div class="ht-acc__content">
            <ul class="ht-bundle-info__list">
              {%- if section.settings.faq_q1 != blank -%}
                <li>
                  <strong>{{ section.settings.faq_q1 }}</strong>
                  {% if section.settings.faq_a1 != blank %}
                    &nbsp;{{ section.settings.faq_a1 }}
                  {% endif %}
                </li>
              {%- endif -%}
              {%- if section.settings.faq_q2 != blank -%}
                <li>
                  <strong>{{ section.settings.faq_q2 }}</strong>
                  {% if section.settings.faq_a2 != blank %}
                    &nbsp;{{ section.settings.faq_a2 }}
                  {% endif %}
                </li>
              {%- endif -%}
              {%- if section.settings.faq_q3 != blank -%}
                <li>
                  <strong>{{ section.settings.faq_q3 }}</strong>
                  {% if section.settings.faq_a3 != blank %}
                    &nbsp;{{ section.settings.faq_a3 }}
                  {% endif %}
                </li>
              {%- endif -%}
            </ul>
          </div>
        </details>
      {%- endif -%}

    </div>
  </div>
</section>

{% endif %}

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.v_margin_mobile }}px;
    padding-bottom: {{ section.settings.v_margin_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.v_margin_desktop }}px;
      padding-bottom: {{ section.settings.v_margin_desktop }}px;
    }
  }

  #shopify-section-{{ section.id }} .ht-bundle-info__wrap {
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .ht-bundle-info__accordion {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  #shopify-section-{{ section.id }} .ht-acc {
    background: #F9FAFB;
    border-radius: 16px;
    padding: 0;
    border: 1px solid rgba(15, 23, 42, 0.04);
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .ht-acc__summary {
    list-style: none;
    cursor: pointer;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  /* hide default arrow */
  #shopify-section-{{ section.id }} .ht-acc__summary::-webkit-details-marker {
    display: none;
  }

  #shopify-section-{{ section.id }} .ht-acc__title {
    font-size: 1.45rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #111827;
  }

  #shopify-section-{{ section.id }} .ht-acc__icon {
    width: 18px;
    height: 18px;
    position: relative;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .ht-acc__icon-line {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 14px;
    height: 1.6px;
    background: #111827;
    border-radius: 999px;
    transform: translate(-50%, -50%);
    transition: transform 0.18s ease, opacity 0.18s ease;
  }

  #shopify-section-{{ section.id }} .ht-acc__icon-line--vert {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  #shopify-section-{{ section.id }} .ht-acc__icon-line--horiz {
    transform: translate(-50%, -50%) rotate(0deg);
  }

  /* when open, collapse "+" into "-" */
  #shopify-section-{{ section.id }} .ht-acc[open] .ht-acc__icon-line--vert {
    opacity: 0;
  }

  #shopify-section-{{ section.id }} .ht-acc__content {
    padding: 0 16px 12px 16px;
  }

  #shopify-section-{{ section.id }} .ht-bundle-info__list {
    margin: 0 0 0 1.1rem;
    padding: 0;
    font-size: 1.3rem;
    line-height: 1.45;
    color: #4B5563;
  }

  #shopify-section-{{ section.id }} .ht-bundle-info__list li {
    margin-bottom: 3px;
  }

  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .ht-acc__summary {
      padding: 14px 20px;
    }

    #shopify-section-{{ section.id }} .ht-acc__content {
      padding: 0 20px 14px 20px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "HT • Bundle Info",
  "settings": [
    {
      "type": "checkbox",
      "id": "limit_to_bundles",
      "label": "Show only when product has a bundle_type metafield",
