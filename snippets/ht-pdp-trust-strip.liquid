{%- assign s = b.settings -%}

<style>
  .htpdp-strip{
    width:100%;max-width:100%;overflow-x:hidden;box-sizing:border-box;
    --ht-bg: {{ s.bg | default: '#0f3a2f' }};
    --ht-text: {{ s.text | default: '#ffffff' }};
    --ht-border: {{ s.border | default: '#1e4a3f' }};
  }
  .htpdp-strip *{box-sizing:border-box}

  .htpdp-strip__wrap{max-width:1100px;margin:0 auto;padding:14px;background:var(--ht-bg);color:var(--ht-text)}
  .htpdp-strip__row{
    display:flex;flex-wrap:nowrap;gap:12px;width:100%;
    align-items:center;justify-content:space-between;
  }
  .htpdp-strip__item{
    flex:1 1 0%;            /* equal thirds */
    min-width:0;            /* allow shrink */
    text-align:center;
  }

  /* icon badge */
  .htpdp-strip__icon{
    width:56px;height:56px;border:1px solid var(--ht-border);border-radius:999px;
    margin:0 auto 6px;display:flex;align-items:center;justify-content:center;overflow:hidden;
    color:var(--ht-text);background:transparent;
  }
  .htpdp-strip__icon img{width:28px;height:28px;display:block}
  .htpdp-strip__icon svg{width:28px !important;height:28px !important;display:block;fill:currentColor;opacity:.95}

  /* single-line title with ellipsis */
  .htpdp-strip__title{
    margin:0;display:block;width:100%;
    color:var(--ht-text);text-align:center;
    white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
    line-height:1.05;font-size:clamp(12.5px,3.6vw,15px);
  }
  .htpdp-strip__title{
  margin:0;display:block;width:100%;
  color:var(--ht-text);text-align:center;
  white-space:normal;          /* allow wrapping */
  overflow:visible;
  text-overflow:unset;
  line-height:1.15;
  font-size:clamp(12.5px,3.6vw,15px);
  padding:0 4px;               /* little breathing room */
}

</style>

<section class="htpdp-strip">
  <div class="htpdp-strip__wrap">
    <div class="htpdp-strip__row">
      {% for i in (1..3) %}
        {%- assign icon_key = 'item' | append: i | append: '_icon_img' -%}
        {%- assign svg_key  = 'item' | append: i | append: '_svg' -%}
        {%- assign emo_key  = 'item' | append: i | append: '_emoji' -%}
        {%- assign txt_key  = 'item' | append: i | append: '_heading' -%}

        {%- assign icon_img = s[icon_key] -%}
        {%- assign icon_svg = s[svg_key]  -%}
        {%- assign emoji    = s[emo_key]  -%}
        {%- assign heading  = s[txt_key]  | strip_newlines | strip -%}

        {% if heading != blank %}
          <div class="htpdp-strip__item">
            <div class="htpdp-strip__icon" aria-hidden="true">
              {% if icon_svg != blank %}
                {{ icon_svg }}
              {% elsif icon_img != blank %}
                {{ icon_img | image_url: width: 96 | image_tag: loading: 'lazy', alt: '' }}
              {% elsif emoji != blank %}
                <span style="font-size:20px;line-height:1">{{ emoji }}</span>
              {% else %}
                <!-- fallback dot appears only when no SVG/image/emoji provided -->
                <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4" fill="currentColor" opacity=".85"/></svg>
              {% endif %}
            </div>
            <h3 class="htpdp-strip__title">{{ heading }}</h3>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
