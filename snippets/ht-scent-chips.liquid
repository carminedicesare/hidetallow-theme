{%- comment -%}
  HT • Scent Chips (clean)
{%- endcomment -%}

{%- assign scent_opt = nil -%}
{%- for opt in product.options_with_values -%}
  {%- if opt.name == 'Scent' -%}
    {%- assign scent_opt = opt -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- if scent_opt -%}
  {%- assign scent_index0 = scent_opt.position | minus: 1 -%}
  {%- assign selected_val = product.selected_or_first_available_variant.options[scent_index0] -%}

  <div id="ht-scent-chips-{{ section.id }}" class="ht-sc" data-option-name="Scent" data-index="{{ scent_index0 }}">
    <div class="ht-sc__label">Scent:</div>
    <div class="ht-sc__grid">
      {%- for v in scent_opt.values -%}
        {%- assign is_active = false -%}
        {%- if v == selected_val -%}{%- assign is_active = true -%}{%- endif -%}
        <button type="button"
                class="ht-sc__chip{% if is_active %} is-active{% endif %}"
                data-value="{{ v | escape }}">
          <span class="ht-sc__icon" aria-hidden="true">
            {%- case v -%}
              {%- when 'Lavender' -%}
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22c4-2 6-6 6-10V4"/><path d="M12 22c-4-2-6-6-6-10V4"/><path d="M12 15V2"/></svg>
              {%- when 'Lemongrass' -%}
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 20 18 6M8 20 20 8M12 20 20 12"/></svg>
              {%- when 'Vanilla' -%}
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 8a4 4 0 1 1 8 0c0 4-4 6-4 6s-4-2-4-6Z"/><circle cx="12" cy="8" r="1"/></svg>
              {%- when 'Unscented' -%}
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="8"/><path d="M5 19 19 5"/></svg>
              {%- else -%}
              <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="4"/></svg>
            {%- endcase -%}
          </span>
          <span class="ht-sc__text">{{ v }}</span>
        </button>
      {%- endfor -%}
    </div>
  </div>

  <style>
    #ht-scent-chips-{{ section.id }} .ht-sc__label{font-weight:600;font-size:16px;margin:10px 0 8px}
    #ht-scent-chips-{{ section.id }} .ht-sc__grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
    #ht-scent-chips-{{ section.id }} .ht-sc__chip{display:flex;flex-direction:column;align-items:center;justify-content:center;border-radius:18px;border:2px solid #d9e0d8;background:#fff;padding:16px 10px;cursor:pointer;transition:box-shadow .2s,border-color .2s,background .2s}
    #ht-scent-chips-{{ section.id }} .ht-sc__text{font-size:13px;font-weight:600;margin-top:6px;color:#111}
    #ht-scent-chips-{{ section.id }} .ht-sc__icon{line-height:0;color:#111}
    #ht-scent-chips-{{ section.id }} .ht-sc__chip.is-active{border-color:#1f3b2f;background:#c7edc9}
    @media(min-width:640px){#ht-scent-chips-{{ section.id }} .ht-sc__grid{grid-template-columns:repeat(4,minmax(0,1fr))}}
  </style>

  <script>
  (function(){
    const root = document.getElementById('ht-scent-chips-{{ section.id }}');
    if(!root) return;

    const optionName = 'options[Scent]';
    const chips = root.querySelectorAll('.ht-sc__chip');
    const form = root.closest('product-form') || document.querySelector('product-form') ||
                 root.closest('form[action*="/cart/add"]') || document.querySelector('form[action*="/cart/add"]');

    function nativeInputs(){ return form ? form.querySelectorAll('[name="'+optionName+'"]') : []; }

    function fireVariantChange(){
      const vr = form && (form.querySelector('variant-radios, variant-selects'));
      if (vr) vr.dispatchEvent(new Event('change',{bubbles:true}));
      if (form) form.dispatchEvent(new Event('change',{bubbles:true}));
    }

    function setOption(value){
      const inputs = nativeInputs();
      inputs.forEach(el=>{
        if (el.tagName==='INPUT' && el.type==='radio'){
          if (el.value === value) el.click();
        } else {
          el.value = value;
          el.dispatchEvent(new Event('change',{bubbles:true}));
        }
      });
      fireVariantChange();
    }

    function syncActiveFromNative(){
      const inputs = nativeInputs();
      let val = null;
      inputs.forEach(el=>{
        if (el.type==='radio' && el.checked) val = el.value;
        if (el.tagName==='SELECT') val = el.value;
      });
      if(!val) return;
      chips.forEach(c => c.classList.toggle('is-active', c.dataset.value === val));
    }

    chips.forEach(chip=>{
      chip.addEventListener('click', ()=>{
        const v = chip.dataset.value;
        chips.forEach(c=>c.classList.remove('is-active'));
        chip.classList.add('is-active');
        setOption(v);
      });
    });

    function hideNativeScent(){
      const groups = (form || document).querySelectorAll('fieldset.product-form__input, fieldset');
      groups.forEach(fs=>{
        if (fs.contains(root)) return;
        const byData = fs.getAttribute && fs.getAttribute('data-option-name') === 'Scent';
        const byInput = fs.querySelector && fs.querySelector('[name="'+optionName+'"]');
        const leg = fs.querySelector && fs.querySelector('legend');
        const byLegend = leg && leg.textContent && leg.textContent.trim().toLowerCase().replace(':','') === 'scent';
        if (byData || byInput || byLegend) fs.style.display = 'none';
      });
    }

    const init = setInterval(()=>{
      if (nativeInputs().length){
        clearInterval(init);
        syncActiveFromNative();
        hideNativeScent();
      }
    }, 60);

    const mo = new MutationObserver(()=>{ syncActiveFromNative(); hideNativeScent(); });
    mo.observe(document.documentElement, {subtree:true, childList:true});
  })();
  </script>
{%- endif -%}
