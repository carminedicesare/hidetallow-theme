{%- comment -%} HT • FAQ (editor-proof) {%- endcomment -%}
{%- assign _id = 'ht-faq-' | append: block.id -%}
<div id="{{ _id }}" class="ht-faq-wrap">
  <style>
    #{{ _id }}{background:{{ block.settings.bg }};color:{{ block.settings.text }};border-radius:10px;padding:28px 18px;margin:8px 0 16px}
    #{{ _id }} .ht-faq__title{
  font-weight: 800;
  font-size: 22px;
  line-height: 1.2;
  margin: 0 0 18px;
  color: {{ block.settings.title_color }};
}
    #{{ _id }} .ht-faq__list details{border-bottom:1px solid {{ block.settings.accent }};padding:14px 0}
    #{{ _id }} .ht-faq__list details:last-child{border-bottom:0}
    #{{ _id }} summary{list-style:none;cursor:pointer;font-weight:700;font-size:16px;display:flex;align-items:center;justify-content:space-between}
    #{{ _id }} summary::-webkit-details-marker{display:none}
    #{{ _id }} .ht-faq__plus{width:22px;height:22px;border-radius:50%;border:2px solid {{ block.settings.accent }};display:inline-flex;align-items:center;justify-content:center;font-weight:800;color:{{ block.settings.accent }};flex:0 0 22px;margin-left:10px}
    #{{ _id }} details[open] .ht-faq__plus{transform:rotate(45deg)}
    #{{ _id }} .ht-faq__answer{margin-top:10px;font-size:15px;line-height:1.6;opacity:.9}
    #{{ _id }} .ht-faq__cta{text-align:center;margin-top:18px}
    #{{ _id }} .ht-faq__cta a{color:inherit;text-decoration:;font-weight:600}
  </style>

  {%- if block.settings.title != blank -%}
    <h3 class="ht-faq__title">{{ block.settings.title }}</h3>
  {%- endif -%}

  <div class="ht-faq__list">
    {%- assign any_items = false -%}
    {%- for i in (1..8) -%}
      {%- assign q_key = 'q' | append: i -%}
      {%- assign a_key = 'a' | append: i -%}
      {%- assign q_val = block.settings[q_key] | default: '' | strip_html | replace: '&nbsp;', '' | strip -%}
      {%- assign a_val = block.settings[a_key] | default: '' | strip_html | replace: '&nbsp;', '' | strip -%}
      {%- if q_val != '' and a_val != '' -%}
        {%- assign any_items = true -%}
        <details>
          <summary>
            <span>{{ block.settings[q_key] }}</span>
            <span class="ht-faq__plus">+</span>
          </summary>
          <div class="ht-faq__answer">{{ block.settings[a_key] }}</div>
        </details>
      {%- endif -%}
    {%- endfor -%}

    {%- unless any_items -%}
      <div class="ht-faq__answer">Add questions in the block settings to display your FAQ.</div>
    {%- endunless -%}
  </div>

  {%- assign cta_href = block.settings.cta_link | default: '/pages/contact' -%}
{%- if block.settings.cta_label or block.settings.cta_link -%}
  <div class="ht-faq__cta" style="text-align: {{ block.settings.cta_align | default: 'center' }};">
    <a href="{{ cta_href }}"
       class="ht-faq__btn"
       style="
         background: {{ block.settings.cta_bg | default: '#0E3A27' }};
         color: {{ block.settings.cta_text | default: '#ffffff' }};
         border: 1px solid {{ block.settings.cta_border | default: '#0E3A27' }};
         border-radius: {{ block.settings.cta_radius | default: 12 }}px;
         padding: 10px 14px;
         font-weight: 700;
         display: inline-block;
       ">
      {{ block.settings.cta_label | default: 'Contact us' }}
    </a>
  </div>
{%- endif -%}

</div>
