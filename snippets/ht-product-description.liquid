{%- comment -%} HT • Description: Text + Microstrip Checklist (Dynamic) {%- endcomment -%}

{%- assign use_meta = use_metafields | default: true -%}
{%- assign p_body = product.metafields.custom.product_description | default: product.description | strip_html -%}
{%- assign bid = block.id | default: product.id -%}

{%- comment -%} 
  MICROSTRIP LOGIC: 
  Checks custom.product_microstrip1 - 4. 
  Falls back to defaults if the metafield is empty.
{%- endcomment -%}
{%- assign b1 = product.metafields.custom.product_microstrip1 | default: 'Deeply Hydrating' -%}
{%- assign b2 = product.metafields.custom.product_microstrip2 | default: 'Absorbs Quickly' -%}
{%- assign b3 = product.metafields.custom.product_microstrip3 | default: 'Zero Residue' -%}
{%- assign b4 = product.metafields.custom.product_microstrip4 | default: 'Whole Body Safe' -%}

<section id="ht-compact-desc-{{ bid }}" class="ht-compact-desc">
  
  <div class="ht-body-text">
    {{ p_body | newline_to_br }}
  </div>

  <div class="ht-benefit-grid">
    
    <div class="ht-check-item">
      <div class="ht-check-circle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
      </div>
      <span>{{ b1 }}</span>
    </div>

    <div class="ht-check-item">
      <div class="ht-check-circle">
         <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
      </div>
      <span>{{ b2 }}</span>
    </div>

    <div class="ht-check-item">
      <div class="ht-check-circle">
         <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
      </div>
      <span>{{ b3 }}</span>
    </div>

    <div class="ht-check-item">
      <div class="ht-check-circle">
         <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
      </div>
      <span>{{ b4 }}</span>
    </div>

  </div>

  <style>
    #ht-compact-desc-{{ bid }} {
      padding: 10px 0 25px 0;
      max-width: 800px; 
    }

    /* TEXT */
    .ht-body-text {
      font-size: 15px;
      line-height: 1.6;
      opacity: 0.95;
      color: #ffffff;
      margin-bottom: 20px;
    }
    .ht-body-text br { content:""; display:block; margin-bottom:8px; }

    /* GRID */
    .ht-benefit-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px 20px;
    }

    /* ITEM */
    .ht-check-item {
      display: flex;
      align-items: center;
      font-size: 13px;
      font-weight: 700;
      color: #ffffff;
      letter-spacing: 0.02em;
    }

    /* ICON CONTAINER */
    .ht-check-circle {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 18px;
      height: 18px;
      background: #ffffff; /* White Circle */
      border-radius: 50%;
      margin-right: 10px;
      flex-shrink: 0;
    }

    /* THE SVG ICON ITSELF */
    .ht-check-circle svg {
      width: 10px;
      height: 10px;
      color: #0E3A27; /* Dark Green Check Color */
      display: block;
    }
    
    @media (max-width: 480px) {
      .ht-benefit-grid { gap: 10px 10px; }
      .ht-check-item { font-size: 12px; }
    }
  </style>
</section>