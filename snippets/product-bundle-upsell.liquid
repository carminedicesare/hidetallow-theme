{%- comment -%}
snippets/product-bundle-upsell.liquid
- Uses settings from the parent block (pass `settings: block.settings` in the render)
- Sticky active state, quantity sync, line item property, and price recalcs on variant change
Expected block settings (already in your schema):
  title, show_three, show_six, discount_3, discount_6, badge_text, default_pack
  bb_active_bg, bb_active_bd, bb_active_tx, bb_idle_bg, bb_idle_bd, bb_idle_tx
{%- endcomment -%}

{%- assign _title        = settings.title        | default: 'Choose your bundle' -%}
{%- assign _show_three   = settings.show_three   | default: true -%}
{%- assign _show_six     = settings.show_six     | default: true -%}
{%- assign _d3           = settings.discount_3   | plus: 0 -%}
{%- assign _d6           = settings.discount_6   | plus: 0 -%}
{%- assign _badge        = settings.badge_text   | default: 'BEST VALUE' -%}
{%- assign _default_pack = settings.default_pack | default: '3' -%}

{%- assign _idle_bg  = settings.bb_idle_bg   | default: '#ffffff' -%}
{%- assign _idle_bd  = settings.bb_idle_bd   | default: '#d9e0d8' -%}
{%- assign _idle_tx  = settings.bb_idle_tx   | default: '#1f1f1f' -%}
{%- assign _act_bg   = settings.bb_active_bg | default: '#ffffff' -%}
{%- assign _act_bd   = settings.bb_active_bd | default: '#1f3b2f' -%}
{%- assign _act_tx   = settings.bb_active_tx | default: '#1f1f1f' -%}

<style>
  .bundle-{{ section_id }} .bu-wrap{margin:18px 0}
  .bundle-{{ section_id }} .bu-head{display:flex;align-items:center;gap:10px;margin-bottom:10px}
  .bundle-{{ section_id }} .bu-title{font-weight:800}
  .bundle-{{ section_id }} .bu-price{margin-left:auto;font-weight:800}
  .bundle-{{ section_id }} .bu-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .bundle-{{ section_id }} .bu-card{
    border:2px solid var(--idle-bd);border-radius:16px;padding:14px;cursor:pointer;position:relative;
    background:var(--idle-bg);color:var(--idle-tx);text-align:left;display:flex;flex-direction:column;gap:8px
  }
  .bundle-{{ section_id }} .bu-card[aria-pressed="true"]{
    border-color:var(--active-bd);background:var(--active-bg);color:var(--active-tx);
    box-shadow:0 0 0 2px color-mix(in srgb, var(--active-bd) 15%, transparent)
  }
  .bundle-{{ section_id }} .bu-top{display:flex;align-items:center;gap:8px}
  .bundle-{{ section_id }} .bu-pack{font-weight:900}
  .bundle-{{ section_id }} .bu-badge{margin-left:auto;font-size:.72rem;border-radius:999px;padding:3px 8px;border:1px solid rgba(0,0,0,.12)}
  .bundle-{{ section_id }} .bu-sub{font-size:.85rem;opacity:.8;margin-top:2px}
  .bundle-{{ section_id }} .bu-row{display:flex;align-items:center;gap:10px;margin-top:6px}
  .bundle-{{ section_id }} .bu-total{font-weight:800}
  .bundle-{{ section_id }} .bu-old{opacity:.5;text-decoration:line-through}
</style>

<div class="bundle-{{ section_id }}">
  <div class="bu-wrap"
      data-bu
      data-form="#{{ product_form_id }}"
      data-section="{{ section_id }}"
      data-default-pack="{{ _default_pack | escape }}"
      style="
        --idle-bg:  {{ _idle_bg }};
        --idle-bd:  {{ _idle_bd }};
        --idle-tx:  {{ _idle_tx }};
        --active-bg: {{ _act_bg }};
        --active-bd: {{ _act_bd }};
        --active-tx: {{ _act_tx }};
      "
  >
    <div class="bu-head">
      <div class="bu-title">{{ _title }}</div>
      <div class="bu-price" data-bu-price></div>
    </div>

    <fieldset class="bu-grid" role="radiogroup" aria-label="{{ _title | escape }}">
      <input type="hidden" name="properties[bundle_pack]" value="" data-bu-prop>

      {%- if _show_three -%}
        <button type="button" class="bu-card" data-pack="3" aria-pressed="{% if _default_pack == '3' %}true{% else %}false{% endif %}">
          <div class="bu-top">
            <div class="bu-pack">3-Pack</div>
          </div>
          <div class="bu-sub">
            {%- if _d3 > 0 -%}Save {{ _d3 }}%{%- else -%}Great to start{%- endif -%}
          </div>
          <div class="bu-row">
            <div class="bu-total" data-total="3"></div>
            <div class="bu-old" data-old="3" hidden></div>
          </div>
        </button>
      {%- endif -%}

      {%- if _show_six -%}
        <button type="button" class="bu-card" data-pack="6" aria-pressed="{% if _default_pack == '6' %}true{% else %}false{% endif %}">
          <div class="bu-top">
            <div class="bu-pack">6-Pack</div>
            <div class="bu-badge">{{ _badge }}</div>
          </div>
          <div class="bu-sub">
            {%- if _d6 > 0 -%}Save {{ _d6 }}%{%- else -%}Stock up & save{%- endif -%}
          </div>
          <div class="bu-row">
            <div class="bu-total" data-total="6"></div>
            <div class="bu-old" data-old="6" hidden></div>
          </div>
        </button>
      {%- endif -%}
    </fieldset>

    <script>
    (() => {
      const wrap = document.currentScript.closest('[data-bu]');
      const defaultPack = parseInt(wrap?.getAttribute('data-default-pack') || '3', 10);
      const d3 = {{ _d3 | json }};
      const d6 = {{ _d6 | json }};
      const priceBox = wrap.querySelector('[data-bu-price]');
      const cards = Array.from(wrap.querySelectorAll('[data-pack]'));
      const sectionId = wrap.getAttribute('data-section');
      const formSel = wrap.getAttribute('data-form');
      const propInput = wrap.querySelector('[data-bu-prop]');

      const findForm = () => document.querySelector(formSel);
      const ensureQty = (form) => {
        let q = form.querySelector('input[name="quantity"]');
        if (!q) { q = document.createElement('input'); q.type='hidden'; q.name='quantity'; q.value='1'; form.appendChild(q); }
        return q;
      };

      const unitPriceCents = () => {{ product.selected_or_first_available_variant.price | json }};
      const discountFor = (pack) => (pack === 3 ? (d3 || 0) : (pack === 6 ? (d6 || 0) : 0));

      const money = (cents) => {
        try { return new Intl.NumberFormat({{ request.locale.iso_code | json }}, {style:'currency', currency: {{ cart.currency.iso_code | json }} }).format((cents||0)/100); }
        catch(e){ return (cents/100).toFixed(2); }
      };

      function updateCardTotals(pack){
        const unit = unitPriceCents();
        const sub = unit * pack;
        const disc = discountFor(pack);
        const fin = disc ? Math.round(sub * (100 - disc)/100) : sub;
        const totalEl = wrap.querySelector(`[data-total="${pack}"]`);
        const oldEl   = wrap.querySelector(`[data-old="${pack}"]`);
        if (totalEl) totalEl.textContent = money(fin);
        if (oldEl) { if (disc){ oldEl.textContent = money(sub); oldEl.hidden = false; } else { oldEl.hidden = true; oldEl.textContent=''; } }
      }

      function currentPack(){
        const act = cards.find(c => c.getAttribute('aria-pressed') === 'true');
        return act ? parseInt(act.dataset.pack,10) : defaultPack;
      }

      function updateAll(){
        cards.forEach(c => updateCardTotals(parseInt(c.dataset.pack,10)));
        const pack = currentPack();
        const unit = unitPriceCents();
        const sub = unit * pack;
        const disc = discountFor(pack);
        const fin = disc ? Math.round(sub * (100 - disc)/100) : sub;
        priceBox.innerHTML = disc ? `<span>${money(fin)}</span> <span class="bu-old">${money(sub)}</span>` : money(fin);
      }

      function setActive(card){
        cards.forEach(c => c.setAttribute('aria-pressed','false'));
        card.setAttribute('aria-pressed','true');

        const pack = currentPack();

        const form = findForm();
        if (form){
          const qty = ensureQty(form);
          qty.value = String(pack);

          const visible = document.querySelector(`#Quantity-${sectionId} input.quantity__input, #Quantity-${sectionId}.quantity__input, #Quantity-${sectionId}`);
          if (visible && visible.tagName === 'INPUT') visible.value = qty.value;
        }
        if (propInput) propInput.value = `${pack}-Pack`;

        updateAll();
      }

      function init(){
        const form = findForm();
        if (!form) return false;

        const def = cards.find(c => c.dataset.pack === String(defaultPack)) || cards[0];
        if (def) setActive(def);

        cards.forEach(c => c.addEventListener('click', () => setActive(c)));

        document.addEventListener('change', (e) => {
          if (e.target && e.target.matches('input[type="radio"][name^="options["]')) updateAll();
        });

        form.addEventListener('submit', () => {
          const qty = ensureQty(form);
          qty.value = String(currentPack());
          if (propInput) propInput.value = `${qty.value}-Pack`;
        });

        updateAll();
        return true;
      }

      if (!init()){
        document.addEventListener('DOMContentLoaded', init, { once: true });
        const mo = new MutationObserver(() => { if (init()) mo.disconnect(); });
        mo.observe(document.documentElement, { childList: true, subtree: true });
      }
    })();
    </script>
  </div>
</div>
