{% comment %}
  HT • How/Why/Storage Snippet
  Dynamic per product (reads metafields.custom.how_to_use, why_it_works, storage)
{% endcomment %}

{% assign how_text = product.metafields.custom.how_to_use.value %}
{% assign why_text = product.metafields.custom.why_it_works.value %}
{% assign shelf_text = product.metafields.custom.storage.value | default: product.metafields.custom.shelf_life_storage.value %}

{% if how_text or why_text or shelf_text %}
  <div class="ht-hws container">
    {% if how_text %}
      <div class="ht-hws__block">
        <h3 class="ht-hws__title">How to Use</h3>
        <div class="ht-hws__content rte">{{ how_text }}</div>
      </div>
    {% endif %}

    {% if why_text %}
      <div class="ht-hws__block">
        <h3 class="ht-hws__title">Why It Works</h3>
        <div class="ht-hws__content rte">{{ why_text }}</div>
      </div>
    {% endif %}

    {% if shelf_text %}
      <div class="ht-hws__block">
        <h3 class="ht-hws__title">Shelf Life & Storage</h3>
        <div class="ht-hws__content rte">{{ shelf_text }}</div>
      </div>
    {% endif %}
  </div>
{% endif %}

<style>
  .ht-hws.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 28px 20px;
  }

  .ht-hws__block + .ht-hws__block {
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid rgba(0,0,0,.06);
  }

  .ht-hws__title {
    margin: 0 0 6px;
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: .2px;
  }

  .ht-hws__content {
    line-height: 1.55;
    font-size: .975rem;
  }
</style>
