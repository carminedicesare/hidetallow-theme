{%- comment -%} HT • Ingredients: Collapsible Accordion (Premium Stack) {%- endcomment -%}
{%- assign show = show | default: '' -%}

{%- comment -%} --- DATA SETUP --- {%- endcomment -%}
{%- assign current = product.selected_or_first_available_variant -%}
{%- assign base_text_1 = product.metafields.custom.base_ingredient | default: '' -%}
{%- assign base_img_obj_1 = product.metafields.custom.base_image | default: block.settings.base_image -%}
{%- assign base_text_2 = product.metafields.custom.second_ingredient | default: '' -%}
{%- assign base_img_obj_2 = product.metafields.custom.second_ingredient_image -%}
{%- assign var_ing = current.metafields.custom.variant_ingredient | default: '' -%}
{%- assign eo_img  = current.metafields.custom.scent_eo_image -%}

<div class="ht-desc-ing-container" style="display: block !important; visibility: visible !important; margin: 10px 0; border-top: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">

  {% if show == 'ingredients' or show == '' %}
    
    <style>
      /* CONTENT DRAWER LOGIC */
      .ht-acc-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease-out;
        opacity: 0;
      }

      .ht-desc-ing-container.is-open .ht-acc-content {
        max-height: 500px;
        opacity: 1;
        transition: max-height 0.4s ease-in, opacity 0.3s ease-in;
      }

      .ht-icon-group {
        display: flex !important;
        align-items: flex-start;
        gap: 12px;
        padding-bottom: 20px;
        padding-top: 10px;
      }

      .ht-icon-item {
        width: 80px;
        text-align: center;
        display: flex !important;
        flex-direction: column;
        align-items: center;
      }

      /* Protection from Ticker Strip SVGs */
      .ht-icon-item svg, .ht-icon-item img {
        stroke: none !important;
        fill: initial !important; 
      }

      .ht-icon-circle {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        overflow: hidden;
        background: #f4f4f4;
        margin-bottom: 8px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
      }

      .ht-icon-circle img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .ht-hidden { display: none !important; }
    </style>

    <div class="ht-acc-header" 
         onclick="this.parentElement.classList.toggle('is-open')" 
         style="display: flex !important; align-items: center; justify-content: space-between; padding: 15px 0; cursor: pointer;">
      
      <div class="ht-widget-label" 
           style="display: block !important; visibility: visible !important; font-family: 'Bricolage Grotesque', sans-serif !important; font-weight: 800 !important; font-size: 14px !important; text-transform: uppercase !important; letter-spacing: 1.5px !important; color: #ffffff !important; opacity: 1 !important; text-align: left !important; margin: 0 !important;">
        Key Ingredients
      </div>

      <div class="ht-acc-icon" style="font-size: 20px; font-weight: 400; color: #ffffff !important;">+</div>
    </div>

    <div class="ht-acc-content">
      <div class="ht-icon-group">
        
        {%- if base_text_1 != blank -%}
          <div class="ht-icon-item">
            {%- if base_img_obj_1 -%}
              <div class="ht-icon-circle">
                <img src="{{ base_img_obj_1 | image_url: width:120 }}" alt="{{ base_text_1 | escape }}">
              </div>
            {%- endif -%}
            <div class="ht-icon-text" style="font-size: 11px; font-weight: 500; color: #ffffff; opacity: 0.9;">{{ base_text_1 }}</div>
          </div>
        {%- endif -%}

        {%- if base_text_2 != blank -%}
          <div class="ht-icon-item">
            {%- if base_img_obj_2 -%}
              <div class="ht-icon-circle">
                <img src="{{ base_img_obj_2 | image_url: width:120 }}" alt="{{ base_text_2 | escape }}">
              </div>
            {%- endif -%}
            <div class="ht-icon-text" style="font-size: 11px; font-weight: 500; color: #ffffff; opacity: 0.9;">{{ base_text_2 }}</div>
          </div>
        {%- endif -%}

        <div class="ht-var-wrap ht-icon-item {% if var_ing == blank %}ht-hidden{% endif %}">
          <div class="ht-var-img-cont ht-icon-circle {% unless eo_img %}ht-hidden{% endunless %}">
            <img class="ht-var-img" src="{{ eo_img | image_url: width:120 | default: '' }}" alt="">
          </div>
          <div class="ht-var-lbl ht-icon-text" style="font-size: 11px; font-weight: 500; color: #ffffff; opacity: 0.9;">{{ var_ing }}</div>
        </div>

      </div>
    </div>

    <script>
    (function(){
      var DB_IMG = {
        {% for v in product.variants %}
          {% assign vimg = v.metafields.custom.scent_eo_image %}
          {% if vimg %}"{{ v.id }}":"{{ vimg | image_url: width:120 }}",{% endif %}
        {% endfor %}
      };
      
      var DB_TEXT = {
        {% for v in product.variants %}
          {% assign ving = v.metafields.custom.variant_ingredient | default: '' %}
          "{{ v.id }}": {{ ving | json }},
        {% endfor %}
      };

      var currentScript = document.currentScript;
      var container = currentScript ? currentScript.closest('.ht-desc-ing-container') : null;
      if (!container) container = document.querySelector('.ht-desc-ing-container:last-of-type');
      if (!container) return; 

      var wrap = container.querySelector('.ht-var-wrap');
      var imgCont = container.querySelector('.ht-var-img-cont');
      var img = container.querySelector('.ht-var-img');
      var lbl = container.querySelector('.ht-var-lbl');

      function update(variantId) {
        if (!wrap || !lbl) return;
        var vID = String(variantId);
        var text = DB_TEXT[vID];

        if (!text) {
          wrap.classList.add('ht-hidden');
          return;
        }

        wrap.classList.remove('ht-hidden');
        lbl.innerText = text;
        var url = DB_IMG[vID];
        if (img) {
          if (url) {
            img.src = url;
            img.removeAttribute('srcset'); 
            if (imgCont) imgCont.classList.remove('ht-hidden');
          } else {
            if (imgCont) imgCont.classList.add('ht-hidden');
          }
        }
      }

      function checkVariant() {
        var idInput = document.querySelector('form[action*="/cart/add"] input[name="id"]');
        if (idInput && idInput.value) return idInput.value;
        var match = window.location.search.match(/variant=(\d+)/);
        if (match) return match[1];
        return "{{ product.selected_or_first_available_variant.id }}";
      }

      var lastId = null;
      var poller = setInterval(function() {
        if (!document.body.contains(container)) { clearInterval(poller); return; }
        var currentId = checkVariant();
        if (currentId && currentId !== lastId) {
           lastId = currentId;
           update(currentId);
        }
      }, 250);
    })();
    </script>
  {% endif %}
</div>