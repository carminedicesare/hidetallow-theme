{%- comment -%}
  HT • Bundle Upsell Block
  Shows a bundle card on product pages IF the product metafield
  custom.bundle_upsell_product is set to a product (e.g. The Starter Kit).
{%- endcomment -%}

{%- assign bundle_product = product.metafields.custom.bundle_upsell_product.value -%}

{%- if bundle_product -%}
  <section class="ht-bundle-upsell">
    <div class="ht-bundle-upsell__inner">
      <div class="ht-bundle-upsell__text">
        <p class="ht-bundle-upsell__eyebrow">Bundle & save</p>
        <h3 class="ht-bundle-upsell__title">
          {{ bundle_product.title | escape }}
        </h3>
        <p class="ht-bundle-upsell__subtitle">
          Complete your tallow routine with our curated starter bundle.
        </p>

        <div class="ht-bundle-upsell__price-row">
          <span class="ht-bundle-upsell__price">
            {{ bundle_product.price | money_without_trailing_zeros }}
          </span>
          {%- if bundle_product.compare_at_price_max > bundle_product.price -%}
            <span class="ht-bundle-upsell__compare">
              {{ bundle_product.compare_at_price_max | money_without_trailing_zeros }}
            </span>
            <span class="ht-bundle-upsell__badge">
              Save {{
                bundle_product.compare_at_price_max | minus: bundle_product.price
                | money_without_trailing_zeros
              }}
            </span>
          {%- endif -%}
        </div>

        <a href="{{ bundle_product.url }}"
          class="button button--primary ht-bundle-upsell__button">
          View The Starter Kit
        </a>

        <p class="ht-bundle-upsell__hint">
          Includes an Everyday Jar, On-The-Go Tin, and Chapstick in your choice of scents.
        </p>
      </div>

      {%- if bundle_product.featured_image -%}
        <div class="ht-bundle-upsell__media">
          <img
            src="{{ bundle_product.featured_image | image_url: width: 600 }}"
            alt="{{ bundle_product.featured_image.alt | escape }}"
            loading="lazy"
            class="ht-bundle-upsell__image">
        </div>
      {%- endif -%}
    </div>
  </section>

  <style>
    .ht-bundle-upsell {
      margin-top: 2.5rem;
      padding: 1.5rem;
      border-radius: 16px;
      border: 1px solid rgba(0,0,0,0.06);
      background: #faf8f4;
    }

    .ht-bundle-upsell__inner {
      display: flex;
      flex-wrap: wrap;
      gap: 1.25rem;
      align-items: center;
      justify-content: space-between;
    }

    .ht-bundle-upsell__text {
      flex: 1 1 220px;
      min-width: 0;
    }

    .ht-bundle-upsell__media {
      flex: 0 0 180px;
      text-align: right;
    }

    .ht-bundle-upsell__image {
      max-width: 180px;
      width: 100%;
      border-radius: 12px;
      object-fit: cover;
    }

    .ht-bundle-upsell__eyebrow {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: .08em;
      margin: 0 0 0.25rem;
      opacity: 0.7;
    }

    .ht-bundle-upsell__title {
      margin: 0 0 0.4rem;
      font-size: 1.1rem;
      font-weight: 700;
    }

    .ht-bundle-upsell__subtitle {
      margin: 0 0 0.9rem;
      font-size: 0.9rem;
      opacity: 0.85;
    }

    .ht-bundle-upsell__price-row {
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
      margin-bottom: 0.75rem;
    }

    .ht-bundle-upsell__price {
      font-weight: 700;
      font-size: 1rem;
    }

    .ht-bundle-upsell__compare {
      font-size: 0.85rem;
      text-decoration: line-through;
      opacity: 0.6;
    }

    .ht-bundle-upsell__badge {
      font-size: 0.75rem;
      padding: 0.15rem 0.5rem;
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,0.1);
    }

    .ht-bundle-upsell__button {
      margin-bottom: 0.4rem;
    }

    .ht-bundle-upsell__hint {
      margin: 0;
      font-size: 0.8rem;
      opacity: 0.75;
    }

    @media (max-width: 749px) {
      .ht-bundle-upsell {
        padding: 1.25rem;
      }

      .ht-bundle-upsell__inner {
        flex-direction: row-reverse;
      }

      .ht-bundle-upsell__media {
        flex: 0 0 120px;
        text-align: left;
      }

      .ht-bundle-upsell__image {
        max-width: 120px;
      }
    }
  </style>
{%- endif -%}
