<!-- HT – PACK SIZE -->
<div class="ht-pack-box">
  <p class="ht-pack-title">PACK SIZE</p>

  <div class="ht-pack-options" role="radiogroup" aria-label="Pack size">
    <label class="ht-pack-option is-active">
      <input type="radio" name="ht_pack_size" value="1" checked hidden>
      <span class="ht-pack-main">1 Pack</span>
    </label>

    <label class="ht-pack-option">
      <input type="radio" name="ht_pack_size" value="3" hidden>
      <span class="ht-pack-main">3 Pack</span>
    </label>

    <label class="ht-pack-option">
      <input type="radio" name="ht_pack_size" value="6" hidden>
      <span class="ht-pack-main">6 Pack</span>
    </label>
  </div>
</div>

<script>
(() => {
  const box  = document.currentScript.previousElementSibling;
  if (!box) return;

  const options = box.querySelectorAll('.ht-pack-option');
  const radios  = box.querySelectorAll('input[name="ht_pack_size"]');

  // Find the product form + quantity input
  const form = document.querySelector('form[action*="/cart/add"]');
  if (!form) return;
  const qtyInput = form.querySelector('input[name="quantity"]');
  if (!qtyInput) return;

  function setActive(optionEl) {
    options.forEach(o => o.classList.remove('is-active'));
    optionEl.classList.add('is-active');
  }

  function setQuantity(val) {
    qtyInput.value = val;
  }

  radios.forEach(radio => {
    radio.addEventListener('change', () => {
      const label = radio.closest('.ht-pack-option');
      if (!label) return;
      setActive(label);
      setQuantity(radio.value);
    });
  });

  // Initial sync: default checked radio -> quantity
  const checked = box.querySelector('input[name="ht_pack_size"]:checked');
  if (checked) {
    setQuantity(checked.value);
  }
})();
</script>

<style>
.ht-pack-box {
  background: #fcfbf7;
  border-radius: 18px;
  padding: 14px 16px 16px;
  margin: 12px 0 18px;
}

.ht-pack-title {
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin: 0 0 10px;
  color: #222222;
}

.ht-pack-options {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.ht-pack-option {
  display: block;
  border-radius: 14px;
  border: 1px solid #e1e1e1;
  background: #ffffff;
  padding: 10px 14px;
  cursor: pointer;
  transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
}

.ht-pack-main {
  font-size: 0.95rem;
  font-weight: 600;
}

.ht-pack-option.is-active {
  background: #000000;
  border-color: #000000;
  color: #ffffff;
}

.ht-pack-option.is-active .ht-pack-main {
  color: #ffffff;
}
</style>
